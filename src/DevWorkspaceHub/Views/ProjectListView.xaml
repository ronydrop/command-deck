<UserControl x:Class="DevWorkspaceHub.Views.ProjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignWidth="280" d:DesignHeight="600">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />
        <conv:HexColorToBrushConverter x:Key="HexToBrush" />
    </UserControl.Resources>

    <Grid Margin="8,0,8,0">
        <Grid.RowDefinitions>
            <!-- Search -->
            <RowDefinition Height="Auto" />
            <!-- Action buttons -->
            <RowDefinition Height="Auto" />
            <!-- Project list -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             SEARCH BAR
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="4,4,4,8">
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="30,8,10,8"
                     FontSize="12" />
            <Path Data="{StaticResource SearchIcon}"
                  Style="{StaticResource IconPathSmall}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Margin="10,0,0,0"
                  IsHitTestVisible="False" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ACTION BUTTONS
             ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="4,0,4,8">
            <Button Style="{StaticResource AccentButton}"
                    Command="{Binding AddProjectCommand}"
                    Padding="10,6"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource PlusIcon}"
                          Stroke="White" StrokeThickness="2"
                          Width="12" Height="12"
                          Stretch="Uniform"
                          Margin="0,0,6,0" />
                    <TextBlock Text="Adicionar Projeto" FontSize="12" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════
             PROJECT LIST
             ═══════════════════════════════════════════════════════════════ -->
        <ListBox Grid.Row="2"
                 Style="{StaticResource DarkListBox}"
                 ItemsSource="{Binding FilteredProjects}"
                 SelectedItem="{Binding SelectedProject}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource DarkListBoxItem}">
                    <Setter Property="Padding" Value="8,8" />
                    <Setter Property="Margin" Value="0,1" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}" />
                        </Grid.InputBindings>
                        <Grid.ColumnDefinitions>
                            <!-- Color indicator + icon -->
                            <ColumnDefinition Width="Auto" />
                            <!-- Name and path -->
                            <ColumnDefinition Width="*" />
                            <!-- Actions -->
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Color dot -->
                        <Border Grid.Column="0"
                                Width="32" Height="32"
                                CornerRadius="6"
                                Background="{Binding Color, Converter={StaticResource HexToBrush}}"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Opacity="0.8">
                            <TextBlock Text="{Binding Name, Converter={x:Static conv:FirstLetterConverter.Instance}}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Name and Path -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <DockPanel>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis" />
                                <!-- Favorite star -->
                                <Path Data="{StaticResource StarIcon}"
                                      Width="10" Height="10"
                                      Stroke="{StaticResource AccentYellowBrush}"
                                      Fill="{StaticResource AccentYellowBrush}"
                                      Stretch="Uniform"
                                      Margin="4,0,0,0"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                            </DockPanel>
                            <TextBlock Text="{Binding Path}"
                                       Style="{StaticResource CaptionText}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="180"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <!-- Favorite toggle -->
                            <Button Style="{StaticResource IconButton}"
                                    Width="24" Height="24"
                                    Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Favoritar">
                                <Path Data="{StaticResource StarIcon}"
                                      Style="{StaticResource IconPathSmall}"
                                      Width="10" Height="10" />
                            </Button>

                            <!-- Context menu button -->
                            <Button Style="{StaticResource IconButton}"
                                    Width="24" Height="24"
                                    ToolTip="Mais opções">
                                <TextBlock Text="..." FontSize="14"
                                           Foreground="{StaticResource SubtextBrush}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="0,-4,0,0" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Abrir"
                                                  Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="Editar"
                                                  Command="{Binding DataContext.EditProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}" />
                                        <Separator />
                                        <MenuItem Header="Excluir"
                                                  Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Empty state -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding FilteredProjects.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}">
            <Path Data="{StaticResource FolderIcon}"
                  Style="{StaticResource IconPathLarge}"
                  Stroke="{StaticResource Surface2Brush}"
                  Width="32" Height="32"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,12" />
            <TextBlock Text="Nenhum projeto"
                       Foreground="{StaticResource Surface2Brush}"
                       FontSize="13"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Adicione um projeto para começar"
                       Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
