<UserControl x:Class="DevWorkspaceHub.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:GitStatusToColorConverter x:Key="GitStatusToColor" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="32,24">
        <StackPanel MaxWidth="900">

            <!-- ═══════════════════════════════════════════════════════════
                 WELCOME HEADER
                 ═══════════════════════════════════════════════════════════ -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="{Binding WelcomeMessage}"
                           Style="{StaticResource HeadingText}"
                           FontSize="24" />
                <TextBlock Style="{StaticResource BodyText}">
                    <Run Text="{Binding CurrentDate}" />
                    <Run Text=" — " />
                    <Run Text="{Binding CurrentTime}" />
                </TextBlock>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════
                 PROJECT INFO CARD
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding CurrentProject, Converter={StaticResource NullToVis}}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding CurrentProject.Name}"
                                   Style="{StaticResource SubheadingText}"
                                   FontSize="18" />
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding RefreshCommand}"
                                ToolTip="Refresh">
                            <Path Data="{StaticResource RefreshIcon}"
                                  Style="{StaticResource IconPathSmall}" />
                        </Button>
                    </DockPanel>
                    <TextBlock Text="{Binding CurrentProject.Path}"
                               Style="{StaticResource MonoText}"
                               Foreground="{StaticResource SubtextBrush}"
                               Margin="0,0,0,4" />
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 STATS CARDS ROW
                 ═══════════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Active Terminals -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Terminais Ativos"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource TerminalIcon}"
                                  Style="{StaticResource IconPath}"
                                  Stroke="{StaticResource AccentGreenBrush}"
                                  Margin="0,0,10,0" />
                            <TextBlock Text="{Binding ActiveTerminalCount}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Running Processes -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Processos em Execução"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource ProcessIcon}"
                                  Style="{StaticResource IconPath}"
                                  Stroke="{StaticResource AccentBlueBrush}"
                                  Margin="0,0,10,0" />
                            <TextBlock Text="{Binding RunningProcessCount}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Git Status -->
                <Border Grid.Column="4" Style="{StaticResource Card}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Status Git"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource GitBranchIcon}"
                                  Style="{StaticResource IconPath}"
                                  Stroke="{StaticResource AccentMauveBrush}"
                                  Margin="0,0,10,0" />
                            <TextBlock Text="{Binding GitInfo.BranchDisplay, FallbackValue='—'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 GIT DETAILS CARD
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding HasGitInfo, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Repositório Git"
                               Style="{StaticResource SubheadingText}"
                               Margin="0,0,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Branch -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                            <TextBlock Text="Branch" Style="{StaticResource CaptionText}" /> <!-- manter -->
                            <TextBlock Text="{Binding GitInfo.BranchDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="13" />
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                            <TextBlock Text="Status" Style="{StaticResource CaptionText}" /> <!-- manter -->
                            <TextBlock Text="{Binding GitInfo.StatusSummary}"
                                       Foreground="{Binding GitInfo.RepoStatus, Converter={StaticResource GitStatusToColor}}"
                                       FontSize="13" />
                        </StackPanel>

                        <!-- Last Commit -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                            <TextBlock Text="Último Commit" Style="{StaticResource CaptionText}" />
                            <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13">
                                <Run Text="{Binding GitInfo.LastCommitHash}"
                                     FontFamily="{StaticResource MonoFont}"
                                     Foreground="{StaticResource AccentYellowBrush}" />
                                <Run Text=" " />
                                <Run Text="{Binding GitInfo.LastCommitMessage}" />
                                <Run Text=" (" /><Run Text="{Binding GitInfo.LastCommitRelativeTime}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>

                        <!-- Modified / Staged / Untracked -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Modificados: " Style="{StaticResource CaptionText}" />
                            <TextBlock Text="{Binding GitInfo.ModifiedFiles}"
                                       Foreground="{StaticResource AccentYellowBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Preparados: " Style="{StaticResource CaptionText}" />
                            <TextBlock Text="{Binding GitInfo.StagedFiles}"
                                       Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Não Rastreados: " Style="{StaticResource CaptionText}" />
                            <TextBlock Text="{Binding GitInfo.UntrackedFiles}"
                                       Foreground="{StaticResource SubtextBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 QUICK COMMANDS CARD
                 ═══════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding CurrentProject, Converter={StaticResource NullToVis}}">
                <StackPanel>
                    <TextBlock Text="Comandos Rápidos"
                               Style="{StaticResource SubheadingText}"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding StartupCommands}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource GhostButton}"
                                        Command="{Binding DataContext.RunStartupCommandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        HorizontalContentAlignment="Left"
                                        Margin="0,0,0,4"
                                        Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource PlayIcon}"
                                              Style="{StaticResource IconPathSmall}"
                                              Stroke="{StaticResource AccentGreenBrush}"
                                              Width="10" Height="10"
                                              Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state for commands -->
                    <TextBlock Text="Nenhum comando de inicialização configurado para este projeto."
                               Style="{StaticResource CaptionText}"
                               Visibility="{Binding StartupCommands.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}" />
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 NO PROJECT SELECTED
                 ═══════════════════════════════════════════════════════════ -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="0,60,0,0"
                        Visibility="{Binding CurrentProject, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                <Path Data="{StaticResource DashboardIcon}"
                      Style="{StaticResource IconPathLarge}"
                      Width="64" Height="64"
                      Stroke="{StaticResource Surface1Brush}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20" />
                <TextBlock Text="Selecione um projeto para começar"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource Surface2Brush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Escolha um projeto na barra lateral ou adicione um novo"
                           Style="{StaticResource BodyText}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- Status footer -->
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Right"
                       Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
