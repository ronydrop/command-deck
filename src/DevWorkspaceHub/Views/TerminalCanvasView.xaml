<UserControl x:Class="DevWorkspaceHub.Views.TerminalCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             Background="{StaticResource BaseBgBrush}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:TerminalStatusToColorConverter x:Key="StatusToColor" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="40" />
            <!-- Canvas area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             BARRA DE FERRAMENTAS DO CANVAS
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource MantelBgBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">

                <!-- Lado direito: indicador de zoom + ver todos -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Botão "Ver Todos" - visível quando focado em um terminal -->
                    <Button x:Name="BtnVerTodos"
                            Style="{StaticResource GhostButton}"
                            Padding="10,4"
                            Margin="4,0"
                            Visibility="Collapsed"
                            Click="OnVerTodosClick"
                            ToolTip="Voltar à visão geral (todos os terminais)">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M 2 2 L 10 2 L 10 10 L 2 10 Z M 14 2 L 22 2 L 22 10 L 14 10 Z M 2 14 L 10 14 L 10 22 L 2 22 Z M 14 14 L 22 14 L 22 22 L 14 22 Z"
                                  Stroke="{StaticResource SubtextBrush}"
                                  Fill="Transparent"
                                  StrokeThickness="1.5"
                                  Width="12" Height="12"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0" />
                            <TextBlock Text="Ver Todos"
                                       Style="{StaticResource BodyText}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Indicador de zoom -->
                    <Border Background="{StaticResource Surface0Brush}"
                            CornerRadius="4"
                            Padding="8,3"
                            Margin="4,0">
                        <TextBlock x:Name="ZoomLabel"
                                   Text="100%"
                                   Style="{StaticResource CaptionText}"
                                   FontFamily="{StaticResource MonoFont}"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- Lado esquerdo: botão novo terminal + título -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Novo Terminal -->
                    <Button Style="{StaticResource AccentButton}"
                            Padding="12,4"
                            Command="{Binding DataContext.NewTerminalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Novo Terminal (Ctrl+Shift+T)">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource PlusIcon}"
                                  Style="{StaticResource IconPathSmall}"
                                  Margin="0,0,6,0" />
                            <TextBlock Text="Novo Terminal"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Título da seção -->
                    <TextBlock Text="Canvas de Terminais"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Opacity="0.6" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ÁREA DO CANVAS (FUNDO ARRASTÁVEL)
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              x:Name="CanvasArea"
              Background="{StaticResource CrustBgBrush}"
              ClipToBounds="True"
              MouseDown="OnCanvasMouseDown"
              MouseMove="OnCanvasMouseMove"
              MouseUp="OnCanvasMouseUp"
              MouseWheel="OnCanvasMouseWheel"
              Cursor="Arrow">

            <!-- Container principal com TranslateTransform + ScaleTransform -->
            <Grid x:Name="RootCanvas"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Visibility="Collapsed">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0" />
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- WrapPanel que contém os cards dos terminais -->
                <WrapPanel x:Name="TerminalsPanel"
                           Orientation="Horizontal"
                           Margin="24" />
            </Grid>

            <!-- Estado vazio: nenhum terminal aberto -->
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        IsHitTestVisible="False">
                <Path Data="{StaticResource TerminalIcon}"
                      Style="{StaticResource IconPathLarge}"
                      Width="56" Height="56"
                      Stroke="{StaticResource Surface2Brush}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20" />
                <TextBlock Text="Nenhum terminal aberto"
                           Style="{StaticResource SubheadingText}"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource Surface2Brush}" />
                <TextBlock Text="Clique em &quot;Novo Terminal&quot; ou pressione Ctrl+Shift+T"
                           Style="{StaticResource CaptionText}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
