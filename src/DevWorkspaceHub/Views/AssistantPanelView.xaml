<UserControl x:Class="DevWorkspaceHub.Views.AssistantPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DevWorkspaceHub.ViewModels"
             xmlns:models="clr-namespace:DevWorkspaceHub.Models"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AssistantPanelViewModel}"
             Background="{DynamicResource MantelBgBrush}"
             Width="320">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />

        <!-- Converts IsUser bool to HorizontalAlignment: True=Right, False=Left -->
        <BooleanToVisibilityConverter x:Key="BoolToVisWpf" />

        <!-- Message bubble DataTemplate -->
        <DataTemplate x:Key="ChatMessageTemplate" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="8,3">
                <!-- User message: right-aligned -->
                <Border x:Name="UserBubble"
                        HorizontalAlignment="Right"
                        MaxWidth="240"
                        CornerRadius="8,8,2,8"
                        Padding="10,7"
                        Margin="32,0,0,0"
                        Background="#337C3AED"
                        Visibility="Collapsed">
                    <TextBlock Text="{Binding Content}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Assistant message: left-aligned -->
                <Border x:Name="AssistantBubble"
                        HorizontalAlignment="Left"
                        MaxWidth="270"
                        CornerRadius="8,8,8,2"
                        Padding="10,7"
                        Margin="0,0,32,0"
                        Background="{DynamicResource Surface0Brush}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <!-- Actual content (always visible so streaming updates show live) -->
                        <TextBlock Text="{Binding Content}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <!-- Streaming indicator (shown while chunks are arriving) -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4,0,0"
                                    Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                                     Margin="0,0,3,0" Opacity="0.9" />
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                                     Margin="0,0,3,0" Opacity="0.6" />
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                                     Opacity="0.3" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                    <Setter TargetName="AssistantBubble" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUser}" Value="False">
                    <Setter TargetName="UserBubble" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AssistantBubble" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto" />
            <!-- Provider badge -->
            <RowDefinition Height="Auto" />
            <!-- Chat messages -->
            <RowDefinition Height="*" />
            <!-- Quick action buttons -->
            <RowDefinition Height="Auto" />
            <!-- Input area -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             HEADER
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource MantelBgBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- AI icon -->
                <Border Grid.Column="0"
                        Width="28" Height="28"
                        CornerRadius="6"
                        Background="{DynamicResource AccentBrush}"
                        Margin="0,0,8,0">
                    <TextBlock Text="AI"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Assistente IA"
                               Style="{StaticResource SubheadingText}"
                               FontSize="13"
                               Margin="0" />
                </StackPanel>

                <!-- Clear history button -->
                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Width="26" Height="26"
                        Command="{Binding ClearHistoryCommand}"
                        ToolTip="Limpar histórico">
                    <Path Data="{StaticResource TrashIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>

                <!-- Close button — command binding is set from MainWindow via Tag property trick -->
                <Button Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Width="26" Height="26"
                        Command="{Binding DataContext.ToggleAIPanelCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Fechar painel (Ctrl+I)">
                    <Path Data="{StaticResource CloseIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             PROVIDER BADGE
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource Surface0Brush}"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status dot -->
                <Ellipse Grid.Column="0"
                         Width="7" Height="7"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource AccentRedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProviderAvailable}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- Provider info text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding ProviderInfo}"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" />

                <!-- Provider badge (configured via Settings screen) -->
                <Border Grid.Column="2"
                        CornerRadius="4"
                        Background="{DynamicResource Surface1Brush}"
                        Padding="8,3"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedProviderLabel}"
                               Style="{StaticResource CaptionText}"
                               FontSize="11" />
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             CHAT MESSAGES
             ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource BaseBgBrush}"
                      Padding="0,4">
            <StackPanel>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="16,40"
                            Visibility="{Binding Messages.Count, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                    <Border Width="48" Height="48"
                            CornerRadius="12"
                            Background="{DynamicResource Surface0Brush}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <TextBlock Text="AI"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Assistente IA"
                               Style="{StaticResource SubheadingText}"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Use os botões abaixo para&#x0a;analisar o terminal ou&#x0a;fazer uma pergunta."
                               Style="{StaticResource BodyText}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Messages list -->
                <ItemsControl ItemsSource="{Binding Messages}"
                              ItemTemplate="{StaticResource ChatMessageTemplate}" />
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════
             QUICK ACTION BUTTONS
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource Surface1Brush}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <StackPanel>
                <TextBlock Text="Ações rápidas"
                           Style="{StaticResource CaptionText}"
                           Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ExplainOutputCommand}"
                            Padding="6,5"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource TerminalIcon}"
                                  Style="{StaticResource IconPathSmall}"
                                  Margin="0,0,4,0" />
                            <TextBlock Text="Explicar Output"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding SuggestCommandCommand}"
                            Padding="6,5"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource SearchIcon}"
                                  Style="{StaticResource IconPathSmall}"
                                  Margin="0,0,4,0" />
                            <TextBlock Text="Sugerir Comando"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             INPUT AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{DynamicResource MantelBgBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,1,0,0"
                Padding="8">
            <StackPanel>
                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource CaptionText}"
                           Margin="2,0,0,4"
                           TextTrimming="CharacterEllipsis" />

                <!-- Input row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Digite uma pergunta..."
                             Padding="8,6"
                             FontSize="12"
                             AcceptsReturn="False"
                             ToolTip="Digite sua pergunta ou descrição do comando">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SendMessageCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Send / Cancel button -->
                    <Button Grid.Column="2"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding SendMessageCommand}"
                            Padding="10,6"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis},
                                         ConverterParameter=Invert}">
                        <Path Data="{StaticResource ChevronRightIcon}"
                              Style="{StaticResource IconPathSmall}"
                              Stroke="White" />
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding CancelRequestCommand}"
                            Padding="10,6"
                            ToolTip="Cancelar"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <Path Data="{StaticResource StopIcon}"
                              Style="{StaticResource IconPathSmall}"
                              Stroke="White" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
