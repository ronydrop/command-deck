<UserControl x:Class="DevWorkspaceHub.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             xmlns:helpers="clr-namespace:DevWorkspaceHub.Helpers"
             mc:Ignorable="d"
             d:DesignWidth="1100" d:DesignHeight="900"
             Background="{DynamicResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:InverseStringToVisibilityConverter x:Key="InvStringToVis" />
    </UserControl.Resources>

    <Grid Margin="24,24" MaxWidth="1800" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             TITULO
             ═══════════════════════════════════════════════════════════════ -->
        <TextBlock Grid.Row="0"
                   Text="Configurações"
                   Style="{StaticResource HeadingText}"
                   Margin="0,0,0,20" />

        <!-- ═══════════════════════════════════════════════════════════════
             FORMULARIO — Cards em seções
             ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <StackPanel>

                <!-- ─── Card 1: Aparência ─────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Aparência" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tema"
                                       Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card: Wallpaper do Canvas ────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Header com icone -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Data="M4 5C4 3.89543 4.89543 3 6 3H14L20 9V19C20 20.1046 19.1046 21 18 21H6C4.89543 21 4 20.1046 4 19V5Z M14 3V9H20 M9 13L11 17L13 13L15 17"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="20" Height="20" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Wallpaper do Canvas" Style="{StaticResource SubheadingText}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="Imagem de fundo na area de terminais"
                                   Style="{StaticResource CaptionText}" Margin="0,0,0,16" />

                        <!-- Drop zone / Preview area -->
                        <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16"
                                MinHeight="160" MaxHeight="200"
                                Background="{DynamicResource Surface0Brush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}" Value="Collapsed">
                                            <Setter Property="BorderBrush">
                                                <Setter.Value>
                                                    <VisualBrush TileMode="Tile" Viewport="0,0,12,12" ViewportUnits="Absolute"
                                                                 Viewbox="0,0,12,12" ViewboxUnits="Absolute">
                                                        <VisualBrush.Visual>
                                                            <Grid Width="12" Height="12">
                                                                <Path Data="M0,0 L12,0" Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5"
                                                                      StrokeDashArray="3,3" Opacity="0.4" />
                                                            </Grid>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <!-- Preview da imagem quando selecionada -->
                                <Image Source="{Binding CanvasWallpaperPath}"
                                       Stretch="UniformToFill"
                                       Opacity="{Binding CanvasWallpaperOpacity}"
                                       Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}" />

                                <!-- Empty state -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource InvStringToVis}}">
                                    <Path Data="M4 16L8 12L12 16M14 14L16 12L20 16M6 20H18C19.1046 20 20 19.1046 20 18V6C20 4.89543 19.1046 4 18 4H6C4.89543 4 4 4.89543 4 6V18C4 19.1046 4.89543 20 6 20Z M14.5 9.5C14.5 10.3284 13.8284 11 13 11C12.1716 11 11.5 10.3284 11.5 9.5C11.5 8.67157 12.1716 8 13 8C13.8284 8 14.5 8.67157 14.5 9.5Z"
                                          Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="40" Height="40" Stretch="Uniform" Opacity="0.4"
                                          HorizontalAlignment="Center" Margin="0,0,0,10" />
                                    <TextBlock Text="Nenhuma imagem selecionada"
                                               Style="{StaticResource CaptionText}" Opacity="0.5"
                                               HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Button Style="{StaticResource AccentButton}"
                                            Content="Escolher Imagem"
                                            Command="{Binding BrowseWallpaperCommand}"
                                            HorizontalAlignment="Center"
                                            Padding="20,8" FontSize="12" />
                                </StackPanel>

                                <!-- Botoes sobre a imagem quando selecionada -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                            Margin="8"
                                            Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <Button Style="{StaticResource GhostButton}"
                                            Content="Trocar" FontSize="11"
                                            Command="{Binding BrowseWallpaperCommand}"
                                            Padding="12,5" Margin="0,0,4,0">
                                        <Button.Background>
                                            <SolidColorBrush Color="#000000" Opacity="0.6" />
                                        </Button.Background>
                                    </Button>
                                    <Button Style="{StaticResource DangerButton}"
                                            Content="Remover" FontSize="11"
                                            Command="{Binding ClearWallpaperCommand}"
                                            Padding="12,5">
                                        <Button.Background>
                                            <SolidColorBrush Color="#000000" Opacity="0.6" />
                                        </Button.Background>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Controles agrupados -->
                        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,4"
                                Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}">
                            <StackPanel>
                                <!-- Opacidade -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Opacidade" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                            Value="{Binding CanvasWallpaperOpacity}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}"
                                            CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionText}"
                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <Binding Path="CanvasWallpaperOpacity" StringFormat="{}{0:P0}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Ajuste -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ajuste" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                              ItemsSource="{Binding AvailableStretchModes}"
                                              SelectedItem="{Binding CanvasWallpaperStretch}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ─── Card: Canvas - Zoom ───────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Canvas — Zoom" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Comportamento de zoom na área de trabalho"
                                   Style="{StaticResource CaptionText}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Modo de Zoom"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding AvailableZoomModes}"
                                      SelectedItem="{Binding CanvasZoomMode}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Ctrl + Scroll" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="FreeScroll">
                                                            <Setter Property="Text" Value="Scroll Livre" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card: Fundo dos Terminais ────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Header com icone -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Data="{StaticResource TerminalIcon}"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="20" Height="20" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Fundo dos Terminais" Style="{StaticResource SubheadingText}" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="Personalize o fundo dentro de cada terminal"
                                   Style="{StaticResource CaptionText}" Margin="0,0,0,16" />

                        <!-- Preview / Drop zone grande -->
                        <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16"
                                MinHeight="180" MaxHeight="220"
                                Background="{DynamicResource Surface0Brush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1.5">
                            <Grid>
                                <!-- Preview com overlay quando tem imagem -->
                                <Image Source="{Binding TerminalWallpaperPath}"
                                       Stretch="UniformToFill"
                                       Opacity="{Binding TerminalWallpaperOpacity}"
                                       Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}" />
                                <Rectangle Opacity="{Binding TerminalWallpaperOverlayOpacity}"
                                           Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="#000000" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TerminalWallpaperDarkOverlay}" Value="False">
                                                    <Setter Property="Fill" Value="#FFFFFF" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>

                                <!-- Fake terminal text no preview -->
                                <StackPanel VerticalAlignment="Center" Margin="20,16"
                                            Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}" Opacity="0.8"
                                               Text="~/projects/devworkspacehub" Margin="0,0,0,2" />
                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{DynamicResource TextBrush}" Opacity="0.6"
                                               Text="$ dotnet build" Margin="0,0,0,2" />
                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}" Opacity="0.5"
                                               Text="Build succeeded. 0 Warning(s) 0 Error(s)" />
                                </StackPanel>

                                <!-- Empty state -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource InvStringToVis}}">
                                    <Path Data="{StaticResource TerminalIcon}"
                                          Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="40" Height="40" Stretch="Uniform" Opacity="0.3"
                                          HorizontalAlignment="Center" Margin="0,0,0,10" />
                                    <TextBlock Text="Nenhuma imagem de fundo"
                                               Style="{StaticResource CaptionText}" Opacity="0.5"
                                               HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Button Style="{StaticResource AccentButton}"
                                            Content="Escolher Imagem"
                                            Command="{Binding BrowseTerminalWallpaperCommand}"
                                            HorizontalAlignment="Center"
                                            Padding="20,8" FontSize="12" />
                                </StackPanel>

                                <!-- Botoes flutuantes sobre a imagem -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                            Margin="8"
                                            Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <Button Style="{StaticResource GhostButton}"
                                            Content="Trocar" FontSize="11"
                                            Command="{Binding BrowseTerminalWallpaperCommand}"
                                            Padding="12,5" Margin="0,0,4,0">
                                        <Button.Background>
                                            <SolidColorBrush Color="#000000" Opacity="0.6" />
                                        </Button.Background>
                                    </Button>
                                    <Button Style="{StaticResource DangerButton}"
                                            Content="Remover" FontSize="11"
                                            Command="{Binding ClearTerminalWallpaperCommand}"
                                            Padding="12,5">
                                        <Button.Background>
                                            <SolidColorBrush Color="#000000" Opacity="0.6" />
                                        </Button.Background>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Status de erro -->
                        <TextBlock Text="{Binding TerminalWallpaperStatusText}"
                                   Foreground="#F38BA8"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding TerminalWallpaperStatusText, Converter={StaticResource StringToVis}}" />

                        <!-- ── Grupo: Imagem ── -->
                        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,8"
                                Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                            <StackPanel>
                                <TextBlock Text="IMAGEM" Style="{StaticResource CaptionText}"
                                           FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                                           Margin="0,0,0,10" />

                                <!-- Opacidade -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Opacidade" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                            Value="{Binding TerminalWallpaperOpacity}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}"
                                            CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionText}"
                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <Binding Path="TerminalWallpaperOpacity" StringFormat="{}{0:P0}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Desfoque -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Desfoque" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <Slider Grid.Column="1" Minimum="0" Maximum="30"
                                            Value="{Binding TerminalWallpaperBlurRadius}"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}"
                                            CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionText}"
                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <Binding Path="TerminalWallpaperBlurRadius" StringFormat="{}{0:F0}px" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Ajuste -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ajuste" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                              ItemsSource="{Binding AvailableStretchModes}"
                                              SelectedItem="{Binding TerminalWallpaperStretch}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Grupo: Overlay e Cor ── -->
                        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,8"
                                Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                            <StackPanel>
                                <TextBlock Text="OVERLAY" Style="{StaticResource CaptionText}"
                                           FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                                           Margin="0,0,0,10" />

                                <!-- Modo do overlay -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Modo" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <RadioButton GroupName="TerminalOverlay"
                                                     IsChecked="{Binding TerminalWallpaperDarkOverlay}"
                                                     VerticalAlignment="Center" Margin="0,0,4,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="12" Height="12" Fill="#1E1E2E" Stroke="{DynamicResource GlassBorderBrush}" StrokeThickness="1" Margin="0,0,5,0" />
                                                <TextBlock Text="Escuro" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton GroupName="TerminalOverlay"
                                                     VerticalAlignment="Center" Margin="16,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="12" Height="12" Fill="#FFFFFF" Stroke="{DynamicResource GlassBorderBrush}" StrokeThickness="1" Margin="0,0,5,0" />
                                                <TextBlock Text="Claro" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </Grid>

                                <!-- Overlay Opacidade -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Intensidade" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                            Value="{Binding TerminalWallpaperOverlayOpacity}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}"
                                            CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionText}"
                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <Binding Path="TerminalWallpaperOverlayOpacity" StringFormat="{}{0:P0}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Grupo: Ajustes Finos ── -->
                        <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,8"
                                Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                            <StackPanel>
                                <TextBlock Text="AJUSTES" Style="{StaticResource CaptionText}"
                                           FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                                           Margin="0,0,0,10" />

                                <!-- Brilho -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Brilho" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <Slider Grid.Column="1" Minimum="0.5" Maximum="1.5"
                                            Value="{Binding TerminalWallpaperBrightness}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}"
                                            CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionText}"
                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <Binding Path="TerminalWallpaperBrightness" StringFormat="{}{0:F2}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Contraste -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Contraste" Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" Opacity="0.7" />
                                    <Slider Grid.Column="1" Minimum="0.5" Maximum="1.5"
                                            Value="{Binding TerminalWallpaperContrast}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}"
                                            CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionText}"
                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <Binding Path="TerminalWallpaperContrast" StringFormat="{}{0:F2}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Restaurar padrao -->
                        <Button Content="Restaurar Padrao"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding ClearTerminalWallpaperCommand}"
                                HorizontalAlignment="Left"
                                Padding="16,6" FontSize="11" Opacity="0.7"
                                Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}" />
                    </StackPanel>
                </Border>

                <!-- ─── Card 2: Terminal ──────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Terminal" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Fonte do Terminal"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding TerminalFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Cascadia Code, Consolas"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tamanho da Fonte"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding TerminalFontSize, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="14"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Shell Padrão"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding AvailableShells}"
                                      SelectedItem="{Binding DefaultShell}"
                                      Margin="0,0,0,10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Redimensionamento"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="3" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding AvailableResizeBehaviors}"
                                      SelectedItem="{Binding TerminalResizeBehavior}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card 3: Projetos ─────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Projetos" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Diretório de Busca"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding ProjectScanDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="C:\Users\..."
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Profundidade Máxima"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding ProjectScanMaxDepth, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="3"
                                     Margin="0,0,0,10" />

                            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                      Content="Abrir último projeto ao iniciar"
                                      IsChecked="{Binding StartWithLastProject}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card 4: Monitoramento ────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Monitoramento" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Refresh do Git"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding GitRefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="5"
                                     Margin="0,0,8,10" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="seg"
                                       Style="{StaticResource CaptionText}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Monitor de Processos"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding ProcessMonitorIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="3"
                                     Margin="0,0,8,0" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="seg"
                                       Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card 5: Atalhos de Teclado ───────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Atalhos de Teclado" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Novo Terminal"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding NewTerminalShortcut, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ctrl+Shift+T"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fechar Terminal"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding CloseTerminalShortcut, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ctrl+Shift+W"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Próximo Terminal"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding NextTerminalShortcut, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ctrl+Tab"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Terminal Anterior"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding PreviousTerminalShortcut, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ctrl+Shift+Tab"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Alternar Sidebar"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding ToggleSidebarShortcut, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ctrl+B"
                                     Margin="0,0,0,10" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Focar Terminal"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding FocusTerminalShortcut, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ctrl+`" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card 6: Assistente IA ────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Assistente IA" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Provedor -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Provedor"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding AvailableAiProviders}"
                                      SelectedItem="{Binding AiProvider}"
                                      Margin="0,0,0,10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Autenticação Anthropic (visível quando provider = anthropic) -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Autenticação"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Visibility="{Binding IsAnthropicProvider, Converter={StaticResource BoolToVis}}" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding AvailableAnthropicAuthModes}"
                                      SelectedItem="{Binding AnthropicAuthMode}"
                                      Margin="0,0,0,10"
                                      Visibility="{Binding IsAnthropicProvider, Converter={StaticResource BoolToVis}}" />

                            <!-- Claude Code Status (visível quando OAuth selecionado) -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Claude Code"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Visibility="{Binding IsAnthropicOAuthMode, Converter={StaticResource BoolToVis}}" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10"
                                        Visibility="{Binding IsAnthropicOAuthMode, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource AccentRedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsClaudeCodeDetected}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding ClaudeSubscriptionInfo}"
                                           Style="{StaticResource BodyText}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Modelo (visível quando AI habilitado) -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Modelo"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVis}}" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="claude-haiku-4-5-20251001"
                                     Margin="0,0,0,10"
                                     Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVis}}" />

                            <!-- URL Base (visível quando provider = local) -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="URL Base"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Visibility="{Binding IsLocalProvider, Converter={StaticResource BoolToVis}}" />
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding AiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="http://localhost:11434"
                                     Margin="0,0,0,10"
                                     Visibility="{Binding IsLocalProvider, Converter={StaticResource BoolToVis}}" />

                            <!-- Chave API (visível quando provider = openai ou anthropic+apikey) -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Chave API"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Visibility="{Binding IsApiKeyProvider, Converter={StaticResource BoolToVis}}" />
                            <PasswordBox Grid.Row="5" Grid.Column="1"
                                         Style="{StaticResource DarkPasswordBox}"
                                         helpers:PasswordBoxHelper.BoundPassword="{Binding AiApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="sk-ant-... ou sk-..."
                                         Margin="0,0,0,10"
                                         Visibility="{Binding IsApiKeyProvider, Converter={StaticResource BoolToVis}}" />

                            <!-- Máximo de Mensagens (visível quando AI habilitado) -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Mensagens de Contexto"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVis}}" />
                            <TextBox Grid.Row="6" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding AiMaxContextMessages, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="20"
                                     Margin="0,0,0,10"
                                     Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVis}}" />

                            <!-- Assistente Visível -->
                            <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                      Content="Mostrar painel do assistente"
                                      IsChecked="{Binding AiAssistantVisible}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card 7: Modelos IA (Terminal) ────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Modelos IA (Terminal)" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Configure os modelos usados nas sessões AI do terminal"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,16" />

                        <ItemsControl ItemsSource="{Binding AiModelSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Surface0Brush}"
                                            CornerRadius="8"
                                            Padding="14,12"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Short label badge -->
                                            <Border Grid.Column="0"
                                                    CornerRadius="6"
                                                    Padding="10,4"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    MinWidth="48">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.2" />
                                                </Border.Background>
                                                <TextBlock Text="{Binding ShortLabel}"
                                                           FontSize="12" FontWeight="Bold"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{DynamicResource AccentMauveBrush}"
                                                           HorizontalAlignment="Center" />
                                            </Border>

                                            <!-- Slot name -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DisplayName}"
                                                       Style="{StaticResource BodyText}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />

                                            <!-- Model ID input -->
                                            <TextBox Grid.Column="4"
                                                     Style="{StaticResource DarkTextBox}"
                                                     Text="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="modelo-id (ex: gpt-4o, llama3)"
                                                     FontFamily="{StaticResource MonoFont}"
                                                     FontSize="12"
                                                     VerticalAlignment="Center" />

                                            <!-- Active indicator -->
                                            <RadioButton Grid.Column="6"
                                                         GroupName="AiActiveSlot"
                                                         IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                         VerticalAlignment="Center">
                                                <RadioButton.Template>
                                                    <ControlTemplate TargetType="RadioButton">
                                                        <Border x:Name="OuterBorder"
                                                                Background="Transparent"
                                                                CornerRadius="10"
                                                                Padding="10,5"
                                                                Cursor="Hand"
                                                                BorderThickness="1.5"
                                                                BorderBrush="{DynamicResource Surface2Brush}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="Dot" Width="10" Height="10"
                                                                         Fill="{DynamicResource Surface2Brush}"
                                                                         Margin="0,0,6,0"
                                                                         VerticalAlignment="Center" />
                                                                <TextBlock x:Name="Label" Text="Ativo"
                                                                           FontSize="11" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource SubtextBrush}"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Dot" Property="Fill"
                                                                        Value="{DynamicResource AccentGreenBrush}" />
                                                                <Setter TargetName="Label" Property="Foreground"
                                                                        Value="{DynamicResource AccentGreenBrush}" />
                                                                <Setter TargetName="OuterBorder" Property="BorderBrush"
                                                                        Value="{DynamicResource AccentGreenBrush}" />
                                                                <Setter TargetName="OuterBorder" Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#A6E3A1" Opacity="0.08" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </RadioButton.Template>
                                            </RadioButton>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ─── Card 7: Notificações ──────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <!-- Inline toggle style for themed checkboxes -->
                        <StackPanel.Resources>
                            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="Track"
                                                    Width="40" Height="22"
                                                    CornerRadius="11"
                                                    Background="{DynamicResource Surface2Brush}"
                                                    Cursor="Hand"
                                                    VerticalAlignment="Center">
                                                <Ellipse x:Name="Thumb"
                                                         Width="16" Height="16"
                                                         Fill="{DynamicResource SubtextBrush}"
                                                         HorizontalAlignment="Left"
                                                         Margin="3,0,0,0" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Track" Property="Background"
                                                            Value="{DynamicResource AccentBrush}" />
                                                    <Setter TargetName="Thumb" Property="Fill" Value="White" />
                                                    <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                                            Value="Right" />
                                                    <Setter TargetName="Thumb" Property="Margin"
                                                            Value="0,0,3,0" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Track" Property="Opacity" Value="0.35" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock Text="Notificações" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,16" />

                        <!-- Master toggle -->
                        <Border Background="{DynamicResource Surface0Brush}"
                                CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Notificações ativas"
                                               Style="{StaticResource BodyText}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Habilita ou desabilita todas as notificações do sistema"
                                               Style="{StaticResource CaptionText}"
                                               Opacity="0.6" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding NotificationsEnabled}" />
                            </Grid>
                        </Border>

                        <!-- Per-source toggles -->
                        <TextBlock Text="FONTES DE NOTIFICAÇÃO"
                                   Style="{StaticResource CaptionText}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Opacity="0.7"
                                   FontSize="10"
                                   Margin="4,0,0,8" />

                        <Border Background="{DynamicResource Surface0Brush}"
                                CornerRadius="8" Padding="0" Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Terminal -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Terminal"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NotifyTerminalEvents}"
                                              IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                <!-- Git -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Git"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NotifyGitEvents}"
                                              IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                <!-- Processos -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Processos"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NotifyProcessEvents}"
                                              IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                <!-- Assistente IA -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Assistente IA"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NotifyAiEvents}"
                                              IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                <!-- Sistema -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Sistema"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding NotifySystemEvents}"
                                              IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Sound toggle -->
                        <Border Background="{DynamicResource Surface0Brush}"
                                CornerRadius="8" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Som de notificação"
                                               Style="{StaticResource BodyText}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Reproduz um som ao receber notificações"
                                               Style="{StaticResource CaptionText}"
                                               Opacity="0.6" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding NotificationSoundEnabled}"
                                          IsEnabled="{Binding NotificationsEnabled}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ─── Card: Sobre ───────────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Sobre" Style="{StaticResource SubheadingText}"
                                   Margin="0,0,0,16" />

                        <!-- App identity hero -->
                        <Border Background="{DynamicResource Surface0Brush}"
                                CornerRadius="10" Padding="20,18" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <!-- App icon placeholder -->
                                    <Border Width="42" Height="42" CornerRadius="10"
                                            Background="{DynamicResource AccentBrush}"
                                            Margin="0,0,14,0">
                                        <TextBlock Text="DW" FontSize="16" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Dev Workspace Hub"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border CornerRadius="4" Padding="8,2"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Margin="0,0,8,0">
                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="v" FontWeight="SemiBold" Foreground="White" />
                                                    <Run Text="{Binding AppVersion, Mode=OneWay}"
                                                         FontFamily="{StaticResource MonoFont}"
                                                         FontWeight="SemiBold" Foreground="White" />
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="MIT License"
                                                       Style="{StaticResource CaptionText}"
                                                       Opacity="0.5"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Terminal manager e dashboard de desenvolvimento para Windows."
                                           Style="{StaticResource BodyText}"
                                           TextWrapping="Wrap"
                                           Opacity="0.75"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Credits in a single grouped card -->
                        <TextBlock Text="INFORMAÇÕES"
                                   Style="{StaticResource CaptionText}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Opacity="0.7"
                                   FontSize="10"
                                   Margin="4,0,0,8" />

                        <Border Background="{DynamicResource Surface0Brush}"
                                CornerRadius="8" Padding="0" Margin="0,0,0,20">
                            <StackPanel>
                                <!-- Dev -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Dev"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontWeight="SemiBold" FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Rony Oliveira"
                                               Style="{StaticResource BodyText}"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                <!-- Repo -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Repo"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontWeight="SemiBold" FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="github.com/ronydrop/dev-workspace-hub"
                                               Style="{StaticResource BodyText}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                <!-- Stack -->
                                <Grid Margin="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Stack"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontWeight="SemiBold" FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text=".NET 8 + WPF + CommunityToolkit.Mvvm"
                                               Style="{StaticResource BodyText}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Update check -->
                        <TextBlock Text="ATUALIZAÇÕES"
                                   Style="{StaticResource CaptionText}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Opacity="0.7"
                                   FontSize="10"
                                   Margin="4,0,0,8" />

                        <Border Background="{DynamicResource Surface0Brush}"
                                CornerRadius="8" Padding="16,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Style="{StaticResource AccentButton}"
                                            Content="Verificar Atualizações"
                                            Command="{Binding CheckForUpdateCommand}"
                                            Padding="16,8"
                                            FontSize="13"
                                            Margin="0,0,10,0" />
                                    <Button Style="{StaticResource GhostButton}"
                                            Content="Baixar Atualização"
                                            Command="{Binding OpenUpdatePageCommand}"
                                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                                            Padding="16,8"
                                            FontSize="13" />
                                </StackPanel>
                                <TextBlock Text="{Binding UpdateStatusText}"
                                           Style="{StaticResource CaptionText}"
                                           Opacity="0.6"
                                           Visibility="{Binding UpdateStatusText, Converter={StaticResource NullToVis}}" />
                            </StackPanel>
                        </Border>

                        <!-- Footer -->
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource CaptionText}"
                                   Opacity="0.35"
                                   FontSize="11"
                                   Margin="0,20,0,0">
                            <Run Text="Made with C# and WPF" />
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════
             BOTOES DE ACAO
             ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Style="{StaticResource GhostButton}"
                    Content="Restaurar Padrões"
                    Command="{Binding ResetDefaultsCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0" />
            <Button Style="{StaticResource GhostButton}"
                    Content="Cancelar"
                    Command="{Binding CancelCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0" />
            <Button Style="{StaticResource AccentButton}"
                    Content="Salvar"
                    Command="{Binding SaveCommand}"
                    Padding="24,8" />
        </StackPanel>
    </Grid>
</UserControl>
