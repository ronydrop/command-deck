<UserControl x:Class="DevWorkspaceHub.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignWidth="500" d:DesignHeight="620"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Título -->
            <RowDefinition Height="*" />    <!-- Formulário -->
            <RowDefinition Height="Auto" /> <!-- Botões -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             TÍTULO
             ═══════════════════════════════════════════════════════════════ -->
        <TextBlock Grid.Row="0"
                   Text="Configurações"
                   Style="{StaticResource HeadingText}"
                   Margin="0,0,0,16" />

        <!-- ═══════════════════════════════════════════════════════════════
             FORMULÁRIO
             ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Fonte do Terminal -->
                <TextBlock Text="Fonte do Terminal" Style="{StaticResource BodyText}"
                           Margin="0,0,0,4" />
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding TerminalFontFamily, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <!-- Tamanho da Fonte -->
                <TextBlock Text="Tamanho da Fonte" Style="{StaticResource BodyText}"
                           Margin="0,0,0,4" />
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding TerminalFontSize, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <!-- Shell Padrão -->
                <TextBlock Text="Shell Padrão" Style="{StaticResource BodyText}"
                           Margin="0,0,0,4" />
                <ComboBox Style="{StaticResource DarkComboBox}"
                          ItemsSource="{Binding AvailableShells}"
                          SelectedItem="{Binding DefaultShell}"
                          Margin="0,0,0,16">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Intervalo de Refresh do Git -->
                <TextBlock Text="Intervalo de Refresh do Git (segundos)" Style="{StaticResource BodyText}"
                           Margin="0,0,0,4" />
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding GitRefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <!-- Intervalo do Monitor de Processos -->
                <TextBlock Text="Intervalo do Monitor de Processos (segundos)" Style="{StaticResource BodyText}"
                           Margin="0,0,0,4" />
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding ProcessMonitorIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <!-- Abrir último projeto ao iniciar -->
                <CheckBox Content="Abrir último projeto ao iniciar"
                          IsChecked="{Binding StartWithLastProject}"
                          Margin="0,0,0,16" />

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════
             BOTÕES DE AÇÃO
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource GhostButton}"
                    Content="Restaurar Padrões"
                    Command="{Binding ResetDefaultsCommand}"
                    Padding="16,8" />

            <Button Grid.Column="2"
                    Style="{StaticResource GhostButton}"
                    Content="Cancelar"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"
                    Padding="16,8" />

            <Button Grid.Column="3"
                    Style="{StaticResource AccentButton}"
                    Content="Salvar"
                    Command="{Binding SaveCommand}"
                    Padding="24,8" />
        </Grid>
    </Grid>
</UserControl>
