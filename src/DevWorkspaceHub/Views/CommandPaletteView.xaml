<UserControl x:Class="DevWorkspaceHub.Views.CommandPaletteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:DevWorkspaceHub.Models"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Focusable="False"
             Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />

        <!-- Style for command palette list items -->
        <Style x:Key="CommandPaletteItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Surface0Brush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Surface1Brush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template for each command item in the list -->
        <DataTemplate DataType="{x:Type models:CommandDefinition}">
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <!-- Icon -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Title + category -->
                    <ColumnDefinition Width="*" />
                    <!-- Shortcut badge -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Optional icon -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Icon}"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{DynamicResource SubtextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Trigger>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Title and category -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="{Binding Category}"
                               FontSize="11"
                               Foreground="{DynamicResource Overlay0Brush}"
                               Margin="0,1,0,0" />
                </StackPanel>

                <!-- Shortcut badge -->
                <Border Grid.Column="2"
                        Background="{DynamicResource Surface0Brush}"
                        CornerRadius="4"
                        Padding="8,3"
                        VerticalAlignment="Center"
                        Visibility="{Binding Shortcut, Converter={StaticResource StringToVis}}">
                    <TextBlock Text="{Binding Shortcut}"
                               FontSize="11"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontFamily="{StaticResource MonoFont}" />
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Semi-transparent backdrop -->
    <Grid Background="#60000000">
        <!-- Centered popup container -->
        <Border Background="{DynamicResource BaseBgBrush}"
                BorderBrush="{DynamicResource Surface1Brush}"
                BorderThickness="1"
                CornerRadius="12"
                Width="560"
                MaxHeight="380"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="20">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Search input -->
                    <RowDefinition Height="Auto" />
                    <!-- Results list -->
                    <RowDefinition Height="*" />
                    <!-- Footer hint -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── Search Box ────────────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="{DynamicResource MantelBgBrush}"
                        CornerRadius="12,12,0,0"
                        Padding="12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource Surface1Brush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Search icon -->
                        <Path Grid.Column="0"
                              Data="M8.5 3C5.46243 3 3 5.46243 3 8.5C3 11.5376 5.46243 14 8.5 14C10.0182 14 11.3861 13.3706 12.3701 12.3701L16.2929 16.2929C16.6834 16.6834 17.3166 16.6834 17.7071 16.2929C18.0976 15.9024 18.0976 15.2692 17.7071 14.8787L13.7843 10.9559C14.5678 9.99232 15 8.79647 15 7.5C15 5.01472 12.9853 3 10.5 3H8.5Z"
                              Fill="{DynamicResource SubtextBrush}"
                              Width="16" Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />

                        <!-- Search TextBox: auto-focuses when palette opens -->
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=50}"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderThickness="0"
                                 Padding="4,6"
                                 FontSize="14"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 VerticalAlignment="Center" />

                        <!-- Placeholder text (overlays TextBox, hidden when text present) -->
                        <TextBlock Grid.Column="1"
                                   Text="Buscar comando..."
                                   Foreground="{DynamicResource Overlay0Brush}"
                                   FontSize="14"
                                   Padding="4,6"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- ── Results List ──────────────────────────────────────── -->
                <ListBox Grid.Row="1"
                         x:Name="ResultsList"
                         ItemsSource="{Binding FilteredCommands}"
                         SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                         SelectedItem="{Binding SelectedCommand, Mode=OneWayToSource}"
                         ItemContainerStyle="{StaticResource CommandPaletteItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         KeyboardNavigation.DirectionalNavigation="Contained"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.InputBindings>
                        <KeyBinding Key="Up" Command="{Binding NavigateUpCommand}" />
                        <KeyBinding Key="Down" Command="{Binding NavigateDownCommand}" />
                        <KeyBinding Key="Enter" Command="{Binding ExecuteSelectedCommand}" />
                        <KeyBinding Key="Escape" Command="{Binding CloseCommand}" />
                    </ListBox.InputBindings>

                    <!-- Empty state: show message when no results -->
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource DarkListBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasResults}" Value="False">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBox">
                                                <Grid>
                                                    <TextBlock Text="No matching commands"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource Overlay0Brush}"
                                                               FontSize="13"
                                                               Margin="0,40,0,0" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                </ListBox>

                <!-- ── Footer ────────────────────────────────────────────── -->
                <Border Grid.Row="2"
                        Background="{DynamicResource MantelBgBrush}"
                        CornerRadius="0,0,12,12"
                        Padding="12,6"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource Surface1Brush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding FilteredCommands.Count, StringFormat='{}{0} commands'}"
                                   Foreground="{DynamicResource Overlay0Brush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />

                        <!-- Keyboard hints -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock Text="↑↓ Navigate"
                                       Foreground="{DynamicResource Overlay0Brush}"
                                       FontSize="11"
                                       Margin="0,0,12,0" />
                            <TextBlock Text="↵ Execute"
                                       Foreground="{DynamicResource Overlay0Brush}"
                                       FontSize="11"
                                       Margin="0,0,12,0" />
                            <TextBlock Text="Esc Close"
                                       Foreground="{DynamicResource Overlay0Brush}"
                                       FontSize="11" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
