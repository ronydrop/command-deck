<UserControl x:Class="DevWorkspaceHub.Views.BrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Key="C" Modifiers="Ctrl+Shift" Command="{Binding TogglePickerCommand}" />
        <KeyBinding Key="L" Modifiers="Ctrl" x:Name="FocusUrlBinding" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- Context side panel -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!-- ═══ BROWSER TOOLBAR ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Back -->
                <Button Grid.Column="0"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28"
                        Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding CanGoBack}"
                        ToolTip="Voltar"
                        Margin="0,0,2,0">
                    <Path Data="{StaticResource ChevronLeftIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>

                <!-- Forward -->
                <Button Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28"
                        Command="{Binding GoForwardCommand}"
                        IsEnabled="{Binding CanGoForward}"
                        ToolTip="Avançar"
                        Margin="0,0,2,0">
                    <Path Data="{StaticResource ChevronRightIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>

                <!-- Reload -->
                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28"
                        Command="{Binding ReloadCommand}"
                        ToolTip="Recarregar (F5)"
                        Margin="0,0,8,0">
                    <Path Data="{StaticResource RefreshIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>

                <!-- Connection indicator -->
                <Ellipse Grid.Column="3"
                         Width="8" Height="8"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#6c7086" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                    <Setter Property="Fill" Value="#a6e3a1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- Address bar -->
                <Border Grid.Column="4"
                        Background="{DynamicResource MantelBgBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,0"
                        Margin="0,2">
                    <TextBox Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="12.5"
                             VerticalAlignment="Center"
                             x:Name="AddressBar">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddressBarSubmitCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>

                <!-- Element Picker toggle -->
                <Button Grid.Column="5"
                        Width="28" Height="28"
                        Command="{Binding TogglePickerCommand}"
                        ToolTip="Selecionar Elemento (Ctrl+Shift+C)"
                        Margin="8,0,2,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPickerActive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                    <Setter Property="Opacity" Value="0.9" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="{StaticResource SearchIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>

                <!-- Detect server button -->
                <Button Grid.Column="6"
                        Style="{StaticResource IconButton}"
                        Width="28" Height="28"
                        Command="{Binding DetectServerCommand}"
                        ToolTip="Detectar servidor local"
                        Margin="2,0,0,0">
                    <Path Data="{StaticResource ScanIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>
            </Grid>
        </Border>

        <!-- ═══ WEBVIEW2 CONTENT ═══ -->
        <Grid Grid.Row="1" Grid.Column="0">
            <wv2:WebView2 x:Name="WebView"
                          Visibility="{Binding IsInitialized, Converter={StaticResource BoolToVis}}" />

            <!-- Disconnected overlay -->
            <Border Background="{DynamicResource BaseBgBrush}"
                    Visibility="{Binding IsInitialized, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🌐"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                    <TextBlock Text="Browser Embutido"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Inicie um servidor local no seu projeto para visualizá-lo aqui"
                               FontSize="13"
                               Foreground="{DynamicResource SubtextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                    <Button Style="{StaticResource GhostButton}"
                            Content="🔍 Detectar servidor"
                            Padding="16,8"
                            Command="{Binding DetectServerCommand}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Picker indicator moved to status bar to avoid WebView2 airspace issue -->
        </Grid>

        <!-- ═══ ELEMENT CONTEXT SIDE PANEL ═══ -->
        <Border Grid.Row="1" Grid.Column="1"
                Width="320"
                Background="{DynamicResource MantelBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsContextPanelOpen, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Panel header -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Elemento Selecionado"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="{Binding SelectedElementSummary}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AccentBlueBrush}"
                                       FontFamily="Consolas"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Width="24" Height="24"
                                Command="{Binding DismissContextCommand}"
                                ToolTip="Fechar">
                            <Path Data="{StaticResource CloseIcon}"
                                  Style="{StaticResource IconPathSmall}" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Panel content -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="12,8">
                    <StackPanel>
                        <!-- Selector -->
                        <TextBlock Text="SELETOR" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource Overlay0Brush}"
                                   Margin="0,0,0,4" />
                        <Border Background="{DynamicResource CrustBgBrush}"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedElementSelector}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource AccentGreenBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- HTML Preview -->
                        <TextBlock Text="HTML" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource Overlay0Brush}"
                                   Margin="0,0,0,4" />
                        <Border Background="{DynamicResource CrustBgBrush}"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,12"
                                MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedElementHtml}"
                                           FontFamily="Consolas" FontSize="10.5"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>

                        <!-- Info -->
                        <TextBlock Text="INFO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource Overlay0Brush}"
                                   Margin="0,0,0,4" />
                        <Border Background="{DynamicResource CrustBgBrush}"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontFamily="Consolas" FontSize="10.5"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="URL: " Foreground="{DynamicResource Overlay0Brush}" />
                                    <Run Text="{Binding Url, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Panel actions -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                    <StackPanel>
                        <!-- Send to agent buttons -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Padding="8,6"
                                    Margin="0,0,3,0"
                                    FontSize="11"
                                    Command="{Binding SendToAssistantCommand}"
                                    ToolTip="Enviar contexto para o Assistant AI">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Background" Value="#221a73e8" />
                                    </Style>
                                </Button.Style>
                                <TextBlock>
                                    <Run Text="🤖" /><Run Text=" Enviar p/ AI" />
                                </TextBlock>
                            </Button>
                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Padding="8,6"
                                    Margin="3,0,0,0"
                                    FontSize="11"
                                    Command="{Binding ShowAgentMenuCommand}"
                                    ToolTip="Escolher agent de destino">
                                <TextBlock>
                                    <Run Text="📟" /><Run Text=" Enviar p/ Terminal" />
                                </TextBlock>
                            </Button>
                        </Grid>
                        <!-- Copy buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource GhostButton}"
                                    Content="📋 Seletor"
                                    Padding="8,3"
                                    Margin="0,0,4,0"
                                    FontSize="10"
                                    Command="{Binding CopySelectorCommand}" />
                            <Button Style="{StaticResource GhostButton}"
                                    Content="📄 HTML"
                                    Padding="8,3"
                                    Margin="4,0,0,0"
                                    FontSize="10"
                                    Command="{Binding CopyHtmlCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Agent selection popup -->
                <Popup IsOpen="{Binding IsAgentMenuOpen}"
                       PlacementTarget="{Binding ElementName=AgentMenuAnchor}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="{DynamicResource MantelBgBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="4"
                            MinWidth="250"
                            MaxHeight="300">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.4" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Enviar contexto para:"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       Margin="8,4,8,6" />
                            <ItemsControl ItemsSource="{Binding AvailableAgents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource GhostButton}"
                                                HorizontalContentAlignment="Left"
                                                Padding="10,6"
                                                Margin="2"
                                                Command="{Binding DataContext.SendToAgentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding IsAvailable}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>
                <Border x:Name="AgentMenuAnchor" Height="0" />
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Loading badge (replaces airspace-broken overlay) -->
                <Border Grid.Column="0"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Background="#33f9e2af"
                        CornerRadius="3"
                        Padding="6,1"
                        Margin="0,0,8,0">
                    <TextBlock Text="⏳ LOADING"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentYellowBrush}"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Picker badge (includes hints from removed airspace overlay) -->
                <Border Grid.Column="0"
                        Visibility="{Binding IsPickerActive, Converter={StaticResource BoolToVis}}"
                        Background="#331a73e8"
                        CornerRadius="3"
                        Padding="6,1"
                        Margin="0,0,8,0">
                    <TextBlock Text="🔍 PICKER — Clique p/ selecionar | Esc cancela | ↑↓←→ navega"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBlueBrush}"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="2"
                           Text="{Binding PageTitle}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           MaxWidth="300"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
