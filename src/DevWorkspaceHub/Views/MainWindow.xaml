<Window x:Class="DevWorkspaceHub.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DevWorkspaceHub.ViewModels"
        xmlns:views="clr-namespace:DevWorkspaceHub.Views"
        xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
        mc:Ignorable="d"
        Title="Dev Workspace Hub"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindowStyle}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:ViewTypeToVisibilityConverter x:Key="ViewTypeToVis" />
        <conv:HexColorToBrushConverter x:Key="HexToBrush" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Ctrl+Shift" Command="{Binding NewTerminalCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl+Shift" Command="{Binding CloseTerminalCommand}"
                    CommandParameter="{Binding ActiveTerminal}" />
        <KeyBinding Key="Tab" Modifiers="Ctrl" Command="{Binding NextTerminalCommand}" />
        <KeyBinding Key="Tab" Modifiers="Ctrl+Shift" Command="{Binding PreviousTerminalCommand}" />
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding ToggleSidebarCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="Auto" />
            <!-- Main content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             SIDEBAR
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.Row="0"
                Width="280"
                Background="{StaticResource MantelBgBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,1,0"
                Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Project list -->
                    <RowDefinition Height="*" />
                    <!-- Nav buttons -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Margin="16,16,16,8">
                    <TextBlock Text="Dev Workspace Hub"
                               Style="{StaticResource SubheadingText}"
                               FontSize="16" />
                    <TextBlock Text="Rony Oliveira"
                               Style="{StaticResource CaptionText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Project List View -->
                <views:ProjectListView Grid.Row="1"
                                       DataContext="{Binding ProjectList}" />

                <!-- Bottom Nav -->
                <StackPanel Grid.Row="2"
                            Margin="8,4,8,8">
                    <Separator Style="{StaticResource DarkSeparator}" />
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{x:Static vm:ViewType.Dashboard}"
                            HorizontalContentAlignment="Left"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource DashboardIcon}"
                                  Style="{StaticResource IconPath}"
                                  Margin="0,0,8,0" />
                            <TextBlock Text="Painel" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{x:Static vm:ViewType.ProcessMonitor}"
                            HorizontalContentAlignment="Left"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource ProcessIcon}"
                                  Style="{StaticResource IconPath}"
                                  Margin="0,0,8,0" />
                            <TextBlock Text="Monitor de Processos" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalContentAlignment="Left"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource SettingsIcon}"
                                  Style="{StaticResource IconPath}"
                                  Margin="0,0,8,0" />
                            <TextBlock Text="Configurações" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.Row="0">
            <!-- Dashboard View -->
            <views:DashboardView
                DataContext="{Binding Dashboard}"
                Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window},
                             Converter={StaticResource ViewTypeToVis}, ConverterParameter=Dashboard}" />

            <!-- Terminal Canvas View -->
            <views:TerminalCanvasView
                Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window},
                             Converter={StaticResource ViewTypeToVis}, ConverterParameter=Terminal}" />

            <!-- Process Monitor View -->
            <views:ProcessMonitorView
                DataContext="{Binding ProcessMonitor}"
                Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window},
                             Converter={StaticResource ViewTypeToVis}, ConverterParameter=ProcessMonitor}" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             PROJECT EDIT DIALOG OVERLAY
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
              Visibility="{Binding IsProjectEditVisible, Converter={StaticResource BoolToVis}}">
            <!-- Backdrop -->
            <Border Background="#80000000" />
            <!-- Dialog -->
            <Border Background="{StaticResource BaseBgBrush}"
                    CornerRadius="12"
                    Width="500"
                    MaxHeight="650"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" />
                </Border.Effect>
                <views:ProjectEditView DataContext="{Binding ProjectEditViewModel}" />
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             SETTINGS DIALOG OVERLAY
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
              Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000" />
            <Border Background="{StaticResource BaseBgBrush}"
                    CornerRadius="12"
                    Width="500"
                    MaxHeight="650"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" />
                </Border.Effect>
                <views:SettingsView DataContext="{Binding SettingsViewModel}" />
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             STATUS BAR
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{StaticResource CrustBgBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,1,0,0"
                Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Toggle sidebar button -->
                <Button Grid.Column="0"
                        Style="{StaticResource IconButton}"
                        Width="24" Height="24"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip="Alternar Barra Lateral (Ctrl+B)">
                    <Path Data="{StaticResource SidebarIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>

                <!-- Status text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusBarText}"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center"
                           Margin="8,0" />

                <!-- Active processes -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0">
                    <Path Data="{StaticResource ProcessIcon}"
                          Style="{StaticResource IconPathSmall}"
                          Margin="0,0,4,0" />
                    <TextBlock Text="{Binding ActiveProcessCount, StringFormat='{}{0} processos'}"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Git branch -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0"
                            Visibility="{Binding GitBranchDisplay, Converter={StaticResource NullToVis}}">
                    <Path Data="{StaticResource GitBranchIcon}"
                          Style="{StaticResource IconPathSmall}"
                          Margin="0,0,4,0" />
                    <TextBlock Text="{Binding GitBranchDisplay}"
                               Style="{StaticResource CaptionText}"
                               FontFamily="{StaticResource MonoFont}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Shell type -->
                <TextBlock Grid.Column="4"
                           Text="{Binding ShellTypeDisplay}"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center"
                           Margin="8,0" />

                <!-- Terminal count -->
                <StackPanel Grid.Column="5" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0">
                    <Path Data="{StaticResource TerminalIcon}"
                          Style="{StaticResource IconPathSmall}"
                          Margin="0,0,4,0" />
                    <TextBlock Text="{Binding ActiveTerminalCount}"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
