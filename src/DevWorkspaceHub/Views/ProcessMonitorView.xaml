<UserControl x:Class="DevWorkspaceHub.Views.ProcessMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             Background="{StaticResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:ProcessStatusToColorConverter x:Key="ProcessStatusToColor" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto" />
            <!-- Stats -->
            <RowDefinition Height="Auto" />
            <!-- Filter -->
            <RowDefinition Height="Auto" />
            <!-- Process list -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             HEADER
             ═══════════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Monitor de Processos"
                           Style="{StaticResource HeadingText}"
                           FontSize="20" />
                <TextBlock Style="{StaticResource CaptionText}">
                    <Run Text="Última atualização: " />
                    <Run Text="{Binding LastRefreshed}" />
                </TextBlock>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding RefreshProcessesCommand}"
                        ToolTip="Refresh"
                        Margin="0,0,4,0">
                    <Path Data="{StaticResource RefreshIcon}"
                          Style="{StaticResource IconPathSmall}" />
                </Button>
                <Button Style="{StaticResource AccentButton}"
                        Command="{Binding StartMonitoringCommand}"
                        Content="Iniciar Monitoramento"
                        Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                        Padding="12,6" />
                <Button Style="{StaticResource DangerButton}"
                        Command="{Binding StopMonitoringCommand}"
                        Content="Parar Monitoramento"
                        Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVis}}"
                        Padding="12,6" />
            </StackPanel>
        </DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════
             SUMMARY STATS
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Total de Processos" Style="{StaticResource CaptionText}" />
                    <TextBlock Text="{Binding TotalProcesses}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Memória Total" Style="{StaticResource CaptionText}" />
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}">
                        <Run Text="{Binding TotalMemoryMb}" /><Run Text=" MB" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             FILTER
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <TextBox Style="{StaticResource DarkTextBox}"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Filtrar processos..."
                     Padding="30,8,10,8"
                     FontSize="12" />
            <Path Data="{StaticResource SearchIcon}"
                  Style="{StaticResource IconPathSmall}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Margin="10,0,0,0"
                  IsHitTestVisible="False" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             PROCESS TABLE
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource Surface0Brush}"
                CornerRadius="8"
                Padding="0"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Rows -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0"
                        Background="{StaticResource Surface1Brush}"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />  <!-- PID -->
                            <ColumnDefinition Width="120" /> <!-- Name -->
                            <ColumnDefinition Width="70" />  <!-- Port -->
                            <ColumnDefinition Width="80" />  <!-- CPU -->
                            <ColumnDefinition Width="80" />  <!-- Memory -->
                            <ColumnDefinition Width="80" />  <!-- Status -->
                            <ColumnDefinition Width="*" />   <!-- Uptime -->
                            <ColumnDefinition Width="60" />  <!-- Actions -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="PID"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Nome"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Porta"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="CPU"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="Memória"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="5" Text="Status"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="6" Text="Tempo Ativo"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="7" Text="Encerrar"
                                   Style="{StaticResource CaptionText}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Table Rows -->
                <ListBox Grid.Row="1"
                         Style="{StaticResource DarkListBox}"
                         ItemsSource="{Binding FilteredProcesses}"
                         SelectedItem="{Binding SelectedProcess}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                Padding="16,8"
                                                BorderBrush="{StaticResource Surface1Brush}"
                                                BorderThickness="0,0,0,1">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{StaticResource Surface1Brush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{StaticResource Surface1Brush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Pid}"
                                           Style="{StaticResource MonoText}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontWeight="Medium" FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Port, TargetNullValue='—'}"
                                           Style="{StaticResource MonoText}"
                                           Foreground="{StaticResource AccentBlueBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding FormattedCpu}"
                                           Style="{StaticResource MonoText}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{Binding FormattedMemory}"
                                           Style="{StaticResource MonoText}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="5" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6"
                                             Fill="{Binding Status, Converter={StaticResource ProcessStatusToColor}}"
                                             Margin="0,0,4,0"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Status}"
                                               Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Column="6" Text="{Binding Uptime}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="7"
                                        Style="{StaticResource IconButton}"
                                        Width="28" Height="28"
                                        HorizontalAlignment="Center"
                                        Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Encerrar Processo">
                                    <Path Data="{StaticResource KillIcon}"
                                          Style="{StaticResource IconPathSmall}"
                                          Stroke="{StaticResource AccentRedBrush}" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
