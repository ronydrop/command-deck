<UserControl x:Class="DevWorkspaceHub.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="500"
             Focusable="True"
             KeyboardNavigation.DirectionalNavigation="None"
             KeyboardNavigation.TabNavigation="None"
             Background="Transparent"
             Loaded="OnLoaded"
             SizeChanged="OnSizeChanged"
             MouseDown="OnMouseDown"
             GotFocus="OnGotFocus"
             LostFocus="OnLostFocus">

    <Grid>
        <!-- Layer 0: Wallpaper image (pre-blurred, frozen bitmap) -->
        <Image x:Name="WallpaperImage"
               Source="{Binding BackgroundImage}"
               Stretch="{Binding BackgroundStretch}"
               Opacity="{Binding BackgroundOpacity}"
               IsHitTestVisible="False">
            <Image.Style>
                <Style TargetType="Image">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBackground}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>

        <!-- Layer 1: Dark/Light overlay for text readability -->
        <Rectangle x:Name="WallpaperOverlay"
                   IsHitTestVisible="False"
                   Opacity="{Binding OverlayOpacity}">
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="Fill" Value="#000000" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBackground}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDarkOverlay}" Value="False">
                            <Setter Property="Fill" Value="#FFFFFF" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <!-- Layer 2: Terminal output area (read-only, no focus) -->
        <RichTextBox x:Name="OutputArea"
                     IsReadOnly="True"
                     IsReadOnlyCaretVisible="False"
                     Foreground="{DynamicResource TextBrush}"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="14"
                     BorderThickness="0"
                     Padding="8,4"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     IsUndoEnabled="False"
                     Focusable="False"
                     IsHitTestVisible="False"
                     Cursor="IBeam">
            <RichTextBox.Style>
                <Style TargetType="RichTextBox">
                    <Setter Property="Background" Value="{DynamicResource BaseBgBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBackground}" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </RichTextBox.Style>
            <RichTextBox.Resources>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <!-- Invisible TextBox: provides a real text-input target so the OS/IME
             generates TextComposition events for printable chars.
             PreviewKeyDown + PreviewTextInput are wired directly on this TextBox
             so Backspace, Delete, and arrow keys are intercepted before the
             TextBox (or WPF navigation) can consume them. -->
        <TextBox x:Name="HiddenInput"
                 Opacity="0"
                 Width="1" Height="1"
                 Focusable="True"
                 AcceptsReturn="False"
                 AcceptsTab="False"
                 IsUndoEnabled="False"
                 MaxLength="1"
                 AllowDrop="False"
                 AutoWordSelection="False"
                 Background="Transparent"
                 BorderThickness="0"
                 SpellCheck.IsEnabled="False"
                 KeyboardNavigation.IsTabStop="False"
                 KeyboardNavigation.DirectionalNavigation="None"
                 KeyboardNavigation.TabNavigation="None"
                 KeyboardNavigation.ControlTabNavigation="None"
                 PreviewKeyDown="OnPreviewKeyDown"
                 PreviewTextInput="OnPreviewTextInput" />

        <!-- Blinking cursor overlay -->
        <Canvas x:Name="CursorCanvas"
                IsHitTestVisible="False">
            <Border x:Name="CursorBlock"
                    Width="8" Height="16"
                    Background="{DynamicResource AccentBrush}"
                    Opacity="0.8"
                    Visibility="Collapsed"
                    Canvas.Left="0" Canvas.Top="0">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Opacity"
                                    From="0.8" To="0.0"
                                    Duration="0:0:0.5"
                                    AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
