<UserControl x:Class="DevWorkspaceHub.Controls.CanvasCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DevWorkspaceHub.ViewModels"
             xmlns:ctrl="clr-namespace:DevWorkspaceHub.Controls"
             xmlns:conv="clr-namespace:DevWorkspaceHub.Converters"
             mc:Ignorable="d"
             d:DesignWidth="620" d:DesignHeight="420"
             Focusable="False"
             Opacity="0">

    <!-- ── A. Entrance animation: slide+fade in on Loaded ──────────────────────
         RenderTransform starts at Y=-8 and animates to Y=0 alongside Opacity 0→1.
         FillBehavior=HoldEnd is intentional here: this is a one-time entrance
         animation so the final values (Opacity=1, Y=0) should be held permanently. -->
    <UserControl.RenderTransform>
        <TranslateTransform Y="-8" />
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade in: Opacity 0 → 1 in 200ms QuadraticEase Out -->
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.200">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Slide in: TranslateTransform.Y -8 → 0 in 200ms -->
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="-8" To="0"
                                     Duration="0:0:0.200">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>

        <!-- Shell type icon lookup -->
        <conv:CanvasItemTypeIconConverter x:Key="ItemTypeIconConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:AiSessionTypeToVisibilityConverter x:Key="AiToVis" />
        <conv:AiSessionTypeToBrushConverter x:Key="AiTypeBrush" />
        <conv:AiSessionTypeToLabelConverter x:Key="AiTypeLabel" />
        <conv:AiModelToLabelConverter x:Key="AiModelLabel" />
        <conv:AiModelToBrushConverter x:Key="AiModelBrush" />

        <!-- Template selector chooses content based on ViewModel type -->
        <ctrl:CanvasItemContentTemplateSelector x:Key="ContentSelector">
            <ctrl:CanvasItemContentTemplateSelector.TerminalTemplate>
                <DataTemplate DataType="{x:Type vm:TerminalCanvasItemViewModel}">
                    <ctrl:TerminalControl DataContext="{Binding Terminal}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.TerminalTemplate>
            <ctrl:CanvasItemContentTemplateSelector.GitWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:GitWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.GitWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.ProcessWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:ProcessWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.ProcessWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.ShortcutWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:ShortcutWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.ShortcutWidgetTemplate>
        </ctrl:CanvasItemContentTemplateSelector>

    </UserControl.Resources>

    <!-- ───────────────────────────────────────────────────────────────────
         OUTER GLOW LAYER — a second translucent Border behind the card
         that becomes visible on hover to create an accent glow effect.
         It sits in a Grid at the same position as the card.
         ─────────────────────────────────────────────────────────────────── -->
    <Grid>

        <!-- Glow border (rendered below card) -->
        <Border x:Name="GlowBorder"
                CornerRadius="10"
                BorderThickness="2"
                Background="Transparent"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.BorderBrush>
                <!-- AccentPurple at ~30 % opacity: #4D7C3AED -->
                <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.30" />
            </Border.BorderBrush>
            <Border.Effect>
                <BlurEffect Radius="6" />
            </Border.Effect>
        </Border>

        <!-- ── Card wrapper ──────────────────────────────────────────────── -->
        <!-- B. DragScale ScaleTransform: animated 1.0↔1.03 on drag start/end -->
        <Border x:Name="CardBorder"
                CornerRadius="8"
                BorderThickness="1.5"
                Background="{DynamicResource Surface0Brush}"
                UseLayoutRounding="True"
                RenderTransformOrigin="0.5,0.5">
            <!-- RenderTransform group: ScaleTransform named DragScale for code-behind animation -->
            <Border.RenderTransform>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFocused}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="BorderThickness" Value="2" />
                        </DataTrigger>
                        <!-- AI session: tinted left border accent -->
                        <DataTrigger Binding="{Binding AiSessionType, Converter={StaticResource AiToVis}}" Value="Visible">
                            <Setter Property="BorderBrush" Value="{Binding AiSessionType, Converter={StaticResource AiTypeBrush}}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <!-- Drop shadow — intensity controlled by x:Name for animation -->
            <Border.Effect>
                <DropShadowEffect x:Name="CardShadow"
                                  BlurRadius="12"
                                  ShadowDepth="4"
                                  Opacity="0.35"
                                  Color="#000000" />
            </Border.Effect>

            <!-- Hover triggers: intensify shadow + show glow border -->
            <Border.Triggers>
                <EventTrigger RoutedEvent="Mouse.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Shadow BlurRadius 12 → 20 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="BlurRadius"
                                To="20"
                                Duration="0:0:0.18" />
                            <!-- Shadow Opacity 0.35 → 0.50 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="Opacity"
                                To="0.50"
                                Duration="0:0:0.18" />
                            <!-- GlowBorder Opacity 0 → 1 -->
                            <DoubleAnimation
                                Storyboard.TargetName="GlowBorder"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Mouse.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Shadow BlurRadius 20 → 12 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="BlurRadius"
                                To="12"
                                Duration="0:0:0.22" />
                            <!-- Shadow Opacity 0.50 → 0.35 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="Opacity"
                                To="0.35"
                                Duration="0:0:0.22" />
                            <!-- GlowBorder Opacity 1 → 0 -->
                            <DoubleAnimation
                                Storyboard.TargetName="GlowBorder"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.22" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ─── Title bar ──────────────────────────────────────────────── -->
                <Grid Grid.Row="0"
                      x:Name="TitleBar"
                      Cursor="SizeAll"
                      MouseDown="OnTitleBarMouseDown"
                      MouseMove="OnTitleBarMouseMove"
                      MouseUp="OnTitleBarMouseUp">

                    <!-- Gradient background: MantelBg → Surface0 top-to-bottom -->
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{DynamicResource MantelBg}" Offset="0" />
                            <GradientStop Color="{DynamicResource Surface0}" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Clip top two corners to card radius -->
                    <Grid.Clip>
                        <RectangleGeometry Rect="0,0,2000,32" RadiusX="8" RadiusY="8" />
                    </Grid.Clip>

                    <!-- Very subtle separator line at bottom of title bar -->
                    <Rectangle VerticalAlignment="Bottom"
                               Height="1"
                               HorizontalAlignment="Stretch"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.5" />

                    <Grid.ContextMenu>
                        <ContextMenu x:Name="CardContextMenu"
                                     Style="{x:Null}">
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                                </Style>
                                <Style TargetType="Separator">
                                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                                    <Setter Property="Margin" Value="4,2" />
                                </Style>
                            </ContextMenu.Resources>
                            <ContextMenu.Style>
                                <Style TargetType="ContextMenu">
                                    <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Padding" Value="2" />
                                </Style>
                            </ContextMenu.Style>

                            <MenuItem Header="⚡ Fix Last Error"
                                      Click="OnAiFixError" />
                            <MenuItem Header="💡 Explain Output"
                                      Click="OnAiExplainOutput" />
                            <MenuItem Header="🔧 Suggest Command"
                                      Click="OnAiSuggestCommand" />
                            <Separator />
                            <MenuItem Header="📤 Send Context to AI"
                                      Click="OnAiSendContext" />
                            <Separator />
                            <MenuItem Header="🟣 Open with Sonnet"
                                      Click="OnAiOpenSonnet" />
                            <MenuItem Header="🔵 Open with Opus"
                                      Click="OnAiOpenOpus" />
                            <MenuItem Header="🟢 Open with Haiku"
                                      Click="OnAiOpenHaiku" />
                            <MenuItem Header="🟡 Open with Agent"
                                      Click="OnAiOpenAgent" />
                            <Separator />
                            <MenuItem Header="🔄 Run Again"
                                      Click="OnAiRunAgain" />
                            <MenuItem Header="⚡ Fix Again"
                                      Click="OnAiFixAgain" />
                            <MenuItem Header="💡 Explain More"
                                      Click="OnAiExplainMore" />
                            <MenuItem Header="🔵 Retry with Opus"
                                      Click="OnAiRetryWithOpus" />
                        </ContextMenu>
                    </Grid.ContextMenu>

                    <DockPanel Margin="10,0,6,0" VerticalAlignment="Center">

                        <!-- Item type icon -->
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding ItemType, Converter={StaticResource ItemTypeIconConverter}}"
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />

                        <!-- AI badge: session type pill -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="0,0,3,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding AiSessionType, Converter={StaticResource AiToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.2" />
                            </Border.Background>
                            <TextBlock Text="{Binding AiSessionType, Converter={StaticResource AiTypeLabel}}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{Binding AiSessionType, Converter={StaticResource AiTypeBrush}}"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- AI badge: model pill -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding AiSessionType, Converter={StaticResource AiToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" />
                            </Border.Background>
                            <TextBlock Text="{Binding AiModelUsed, Converter={StaticResource AiModelLabel}}"
                                       FontSize="9" FontWeight="SemiBold"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{Binding AiModelUsed, Converter={StaticResource AiModelBrush}}"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Close button -->
                        <Button DockPanel.Dock="Right"
                                x:Name="CloseButton"
                                Width="20" Height="20"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="OnCloseClicked"
                                ToolTip="Fechar"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="closeBg"
                                            CornerRadius="4"
                                            Background="Transparent"
                                            Width="20" Height="20">
                                        <Path Data="{StaticResource CloseIcon}"
                                              Stroke="{DynamicResource SubtextBrush}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="9" Height="9"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="closeBg" Property="Background"
                                                    Value="{DynamicResource AccentRedBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Status dot (terminals only) -->
                        <Ellipse DockPanel.Dock="Right"
                                 Width="7" Height="7"
                                 Margin="4,0,3,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Surface2Brush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Terminal.IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Title text -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="12"
                                   FontFamily="{StaticResource MonoFont}"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                    </DockPanel>
                </Grid>

                <!-- ─── Content area ───────────────────────────────────────────── -->
                <ContentControl Grid.Row="1"
                                Content="{Binding}"
                                ContentTemplateSelector="{StaticResource ContentSelector}"
                                Focusable="False"
                                ClipToBounds="True" />

                <!-- ─── Resize handle (bottom-right) — 3 diagonal lines ───────── -->
                <Thumb Grid.Row="1"
                       x:Name="ResizeThumb"
                       Width="18" Height="18"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Cursor="SizeNWSE"
                       Background="Transparent"
                       BorderThickness="0"
                       DragDelta="OnResizeDragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <!-- 3-line diagonal grip icon -->
                            <Canvas Width="18" Height="18">
                                <!-- Line 1 (shortest, top) -->
                                <Line X1="7"  Y1="17" X2="17" Y2="7"
                                      Stroke="{DynamicResource Surface2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="0.5" />
                                <!-- Line 2 (middle) -->
                                <Line X1="11" Y1="17" X2="17" Y2="11"
                                      Stroke="{DynamicResource Surface2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="0.75" />
                                <!-- Line 3 (longest, bottom) -->
                                <Line X1="15" Y1="17" X2="17" Y2="15"
                                      Stroke="{DynamicResource Surface2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="1.0" />
                            </Canvas>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

            </Grid>
        </Border>
    </Grid>
</UserControl>
