<UserControl x:Class="DevWorkspaceHub.Controls.GitWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="280"
             Background="{DynamicResource Surface0Brush}"
             Padding="12">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Branch + status row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text=" " FontSize="14" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="{Binding GitInfo.Branch, FallbackValue='–'}"
                           FontFamily="{StaticResource MonoFont}" FontSize="13"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding GitInfo.BranchDisplay, FallbackValue=''}"
                           FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>

            <Separator Background="{DynamicResource Surface1Brush}" />

            <!-- File stats -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding GitInfo.ModifiedFiles, FallbackValue='0'}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentYellowBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="modificados" FontSize="10"
                               Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding GitInfo.StagedFiles, FallbackValue='0'}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="staged" FontSize="10"
                               Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding GitInfo.UntrackedFiles, FallbackValue='0'}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="novos" FontSize="10"
                               Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Separator Background="{DynamicResource Surface1Brush}" />

            <!-- Last commit -->
            <StackPanel>
                <TextBlock Text="Último commit" FontSize="10"
                           Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,2" />
                <TextBlock Text="{Binding GitInfo.Message, FallbackValue='–'}"
                           FontSize="12" Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding GitInfo.RelativeTime, FallbackValue=''}"
                           FontSize="10" Foreground="{DynamicResource SubtextBrush}" Margin="0,2,0,0" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
