<UserControl x:Class="DevWorkspaceHub.Controls.ProcessWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="350"
             Background="{DynamicResource Surface0Brush}"
             Padding="12">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Processos ativos"
                   FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                   Margin="0,0,0,8" />

        <ListView Grid.Row="1"
                  ItemsSource="{Binding Processes}"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="28" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="{Binding Port, StringFormat=':{0}', FallbackValue=''}"
                                       FontSize="10" Foreground="{DynamicResource SubtextBrush}" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding FormattedCpu}"
                                   FontSize="11" Foreground="{DynamicResource AccentYellowBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />

                        <TextBlock Grid.Column="2"
                                   Text="{Binding FormattedMemory}"
                                   FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />

                        <Button Grid.Column="3"
                                Content="✕"
                                FontSize="10"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Foreground="{DynamicResource AccentRedBrush}"
                                Click="OnKillProcessClicked"
                                Tag="{Binding Pid}"
                                VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
