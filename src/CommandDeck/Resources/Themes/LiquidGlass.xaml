<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════
         LIQUID GLASS LIGHT — Premium glass light theme
         Inspired by: macOS Ventura, Arc Browser, Raycast, Linear
         Design philosophy:
           • Clear luminance hierarchy (bg → panel → card → modal)
           • Borders use DARK semi-transparency on light backgrounds (not white!)
           • Diagonal gradients simulate real light refraction on glass
           • Shadows are ambient and soft (not directional/harsh)
           • Cool blue-tinted neutrals (not warm gray) for premium feel
         ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════════════════════════════════════
         A. BASE COLORS — Cool neutral foundation with clear luminance steps
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Window background: cool light gray with slight blue tint — NOT pure gray -->
    <Color x:Key="BaseBg">#EDEDF6</Color>
    <!-- Secondary panels: clear step darker than base -->
    <Color x:Key="MantelBg">#E3E3EE</Color>
    <!-- Tertiary / canvas depth: visible step darker -->
    <Color x:Key="CrustBg">#D6D6E4</Color>
    <!-- Card/input surface: white — CLEARLY distinct from #EDEDF6 base -->
    <Color x:Key="Surface0">#F5F5FC</Color>
    <!-- Borders / dividers: mid-tone — visible on both white cards and gray base -->
    <Color x:Key="Surface1">#C8C8D6</Color>
    <!-- Active borders / strong separators -->
    <Color x:Key="Surface2">#A6A6B8</Color>
    <!-- Muted icons, disabled states -->
    <Color x:Key="Overlay0">#828294</Color>
    <!-- Primary text: near-black with blue tint (better than pure black) -->
    <Color x:Key="TextColor">#0D0D1A</Color>
    <!-- Secondary text: medium gray — strong enough contrast on white -->
    <Color x:Key="SubtextColor">#4C4C5C</Color>
    <Color x:Key="Subtext0Color">#2E2E3E</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         B. ACCENT COLORS — Apple-inspired, slightly deepened for white backgrounds
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Primary accent: Apple blue, slightly deeper than #007AFF for contrast on white -->
    <Color x:Key="AccentPurple">#0071E3</Color>
    <Color x:Key="AccentBlue">#4F4CC8</Color>
    <Color x:Key="AccentGreen">#1EB04A</Color>
    <Color x:Key="AccentYellow">#E08800</Color>
    <Color x:Key="AccentRed">#D8281E</Color>
    <Color x:Key="AccentPink">#D42452</Color>
    <Color x:Key="AccentCyan">#14B0D8</Color>
    <Color x:Key="AccentMauve">#943EC6</Color>

    <!-- Search highlights -->
    <Color x:Key="SearchHighlight">#66E08800</Color>
    <Color x:Key="SearchCurrentHighlight">#990071E3</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         C. GLASS DESIGN TOKENS
         Key insight: on light backgrounds, use DARK semi-transparent borders
         (not white — white border on white bg = invisible)
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Card gradient top: pure bright white — crisp glass surface -->
    <Color x:Key="GlassTop">#FFFFFF</Color>
    <!-- Card gradient bottom: very slightly blue-tinted white — creates depth -->
    <Color x:Key="GlassBottom">#F2F2FA</Color>
    <!-- Card gradient mid-point for richer diagonal gradient -->
    <Color x:Key="GlassMid">#FAFAFD</Color>
    <!-- Inner top highlight: bright white line at top edge (simulates glass rim) -->
    <Color x:Key="GlassHighlight">#BBFFFFFF</Color>
    <!-- CRITICAL FIX: dark semi-transparent border — visible on light backgrounds -->
    <Color x:Key="GlassBorder">#22000000</Color>
    <!-- Subtle inner border (second layer) -->
    <Color x:Key="GlassBorderSubtle">#12000000</Color>
    <!-- Card shadow: soft ambient shadow under floating surfaces -->
    <Color x:Key="ElevatedShadow">#1A000000</Color>
    <!-- Accent-tinted glass overlay for sidebar -->
    <Color x:Key="GlassTintBlue">#0C0071E3</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         D. STANDARD BRUSHES
         ═══════════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="BaseBgBrush"     Color="{StaticResource BaseBg}" />
    <SolidColorBrush x:Key="MantelBgBrush"   Color="{StaticResource MantelBg}" />
    <SolidColorBrush x:Key="CrustBgBrush"    Color="{StaticResource CrustBg}" />
    <SolidColorBrush x:Key="Surface0Brush"   Color="{StaticResource Surface0}" />
    <SolidColorBrush x:Key="Surface1Brush"   Color="{StaticResource Surface1}" />
    <SolidColorBrush x:Key="Surface2Brush"   Color="{StaticResource Surface2}" />
    <SolidColorBrush x:Key="Overlay0Brush"   Color="{StaticResource Overlay0}" />
    <SolidColorBrush x:Key="TextBrush"       Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubtextBrush"    Color="{StaticResource SubtextColor}" />
    <SolidColorBrush x:Key="AccentBrush"     Color="{StaticResource AccentPurple}" />
    <SolidColorBrush x:Key="AccentBlueBrush"   Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="AccentGreenBrush"  Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource AccentYellow}" />
    <SolidColorBrush x:Key="AccentRedBrush"    Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="AccentMauveBrush"  Color="{StaticResource AccentMauve}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuItemHoverBrush"   Color="#260071E3" />

    <!-- Search highlight brushes -->
    <SolidColorBrush x:Key="SearchHighlightBrush"        Color="{StaticResource SearchHighlight}" />
    <SolidColorBrush x:Key="SearchCurrentHighlightBrush" Color="{StaticResource SearchCurrentHighlight}" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         E. GLASS BRUSHES — premium glass surface system
         Rule: gradients go top-left (brightest) → bottom-right (slightly dimmer)
         This simulates light from upper-left as in macOS/iOS glass design
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- PRIMARY GLASS SURFACE (cards, panels)
         Diagonal gradient: pure white top-left → barely tinted bottom-right
         Creates glass depth without fake transparency -->
    <LinearGradientBrush x:Key="GlassBgBrush" StartPoint="0,0" EndPoint="0.25,1">
        <GradientStop Color="{StaticResource GlassTop}"    Offset="0" />
        <GradientStop Color="{StaticResource GlassMid}"    Offset="0.45" />
        <GradientStop Color="{StaticResource GlassBottom}" Offset="1" />
    </LinearGradientBrush>

    <!-- GLASS BORDER — dark semi-transparent: THE KEY FIX for light themes
         13% black creates a clean, visible border without harsh edges -->
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />

    <!-- GLASS HIGHLIGHT — bright top-edge reflection (simulates glass rim) -->
    <SolidColorBrush x:Key="GlassHighlightBrush" Color="{StaticResource GlassHighlight}" />

    <!-- SHADOW BRUSH -->
    <SolidColorBrush x:Key="ElevatedShadowBrush" Color="{StaticResource ElevatedShadow}" />

    <!-- SIDEBAR GLASS — clearly distinct from white cards, clearly lighter than bg -->
    <LinearGradientBrush x:Key="GlassSidebarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#EAEAF4" Offset="0" />    <!-- slightly lighter top -->
        <GradientStop Color="#E3E3EE" Offset="0.5" />  <!-- matches MantelBg -->
        <GradientStop Color="#DCDCEA" Offset="1" />    <!-- slightly darker bottom -->
    </LinearGradientBrush>

    <!-- CANVAS BACKGROUND — radial vignette creates depth in the canvas area -->
    <RadialGradientBrush x:Key="CanvasDepthBrush"
                         GradientOrigin="0.5,0.3"
                         Center="0.5,0.3"
                         RadiusX="0.7"
                         RadiusY="0.7">
        <GradientStop Color="#EAEAF2" Offset="0" />    <!-- lighter center (lit) -->
        <GradientStop Color="#E0E0EA" Offset="0.55" /> <!-- mid transition -->
        <GradientStop Color="{StaticResource CrustBg}" Offset="1" />
    </RadialGradientBrush>

    <!-- TOOLBAR GLASS — header bar, slightly more opaque than sidebar -->
    <LinearGradientBrush x:Key="GlassToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#EDEDF6" Offset="0" />    <!-- almost matches BaseBg -->
        <GradientStop Color="#E6E6F0" Offset="1" />    <!-- slightly deeper -->
    </LinearGradientBrush>

    <!-- CARD TITLE BAR — visible header area at top of card panels -->
    <LinearGradientBrush x:Key="GlassTitleBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FAFAFE" Offset="0" />    <!-- near-white top -->
        <GradientStop Color="#F2F2FA" Offset="1" />    <!-- slightly tinted bottom -->
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════════════════
         F. ELEVATION SHADOW — per-theme shadow tuned for light backgrounds
         Light mode: soft, barely-there shadow (macOS-style ambient shadow)
         Opacity=0.13 = very subtle but perceptible depth
         ═══════════════════════════════════════════════════════════════════════ -->

    <DropShadowEffect x:Key="CardShadow"
                      ShadowDepth="2"
                      BlurRadius="18"
                      Opacity="0.13"
                      Color="#000000"
                      Direction="270" />

    <!-- DOT GRID: base dark dots + accent glow (revealed via OpacityMask near cursor) -->
    <SolidColorBrush x:Key="DotGridDotBrush"  Color="#30000000" />
    <SolidColorBrush x:Key="DotGridLineBrush" Color="#0F000000" />
    <SolidColorBrush x:Key="DotGridGlowBrush" Color="{StaticResource AccentPurple}" Opacity="0.28" />

</ResourceDictionary>
