<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════
         MORPH DARK — Near-pure black with neon lime accents
         Inspired by Codeium / morph.so theme
         Accent base: #C5F467 (neon lime) — borders use this at low alpha
         ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════════════════════════════════════
         A. BASE COLORS — Near-pure black, neutral-cool
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- App shell: outermost background — dark charcoal with cool tint (~Codeium base) -->
    <Color x:Key="BaseBg">#131318</Color>
    <!-- Canvas / secondary panels: canvas background where terminals float -->
    <Color x:Key="MantelBg">#17171C</Color>
    <!-- Terminal background: deepest layer inside terminal cards -->
    <Color x:Key="CrustBg">#0F0F13</Color>
    <!-- Card/panel body: clearly above MantelBg -->
    <Color x:Key="Surface0">#1C1C22</Color>
    <!-- Muted panels / secondary raised surface -->
    <Color x:Key="Surface1">#21212A</Color>
    <!-- Elevated panels, modals, dropdowns, hover backgrounds -->
    <Color x:Key="Surface2">#272733</Color>
    <!-- Disabled text, inactive decorations -->
    <Color x:Key="Overlay0">#606068</Color>
    <!-- Primary text: cool off-white -->
    <Color x:Key="TextColor">#EDEDED</Color>
    <!-- Muted text: captions, metadata -->
    <Color x:Key="SubtextColor">#808088</Color>
    <!-- Secondary text: slightly brighter than SubtextColor -->
    <Color x:Key="Subtext0Color">#BBBBBD</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         B. ACCENT COLORS — Neon lime family + ANSI terminal palette
         Primary: #C5F467 — neon lime-green, the defining color of Morph
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Primary accent: neon lime -->
    <Color x:Key="AccentPurple">#C5F467</Color>
    <!-- Blue: terminal ANSI blue, link color -->
    <Color x:Key="AccentBlue">#5C9BD1</Color>
    <!-- Green: success, ANSI green -->
    <Color x:Key="AccentGreen">#7BCF5A</Color>
    <!-- Yellow/Warning: ANSI yellow, amber warning -->
    <Color x:Key="AccentYellow">#E8B84B</Color>
    <!-- Peach: warm orange accent -->
    <Color x:Key="AccentPeach">#FAB387</Color>
    <!-- Red/Danger: ANSI red, error, danger -->
    <Color x:Key="AccentRed">#F06868</Color>
    <!-- Pink: secondary danger / decorative -->
    <Color x:Key="AccentPink">#D988AA</Color>
    <!-- Cyan: ANSI cyan, teal -->
    <Color x:Key="AccentCyan">#4DBDBD</Color>
    <!-- Mauve: ANSI magenta, purple decorations -->
    <Color x:Key="AccentMauve">#B87FD0</Color>

    <!-- Search highlights: amber for results, lime for current match -->
    <Color x:Key="SearchHighlight">#66E8B84B</Color>
    <Color x:Key="SearchCurrentHighlight">#99C5F467</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         C. GLASS DESIGN TOKENS — Flat near-black, no blue glass
         All border tokens carry the neon lime at ultra-low alpha
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Card gradient stops: near-flat, matches Surface0/MantelBg range -->
    <Color x:Key="GlassTop">#21212A</Color>
    <Color x:Key="GlassMid">#1C1C22</Color>
    <Color x:Key="GlassBottom">#17171C</Color>
    <!-- Inner top edge highlight: lime tint instead of white (Morph signature) -->
    <Color x:Key="GlassHighlight">#0FC5F467</Color>
    <!-- Card/panel border: lime 10% — the universal border tone -->
    <Color x:Key="GlassBorder">#18C5F467</Color>
    <!-- Subtle inner borders: lime 6% -->
    <Color x:Key="GlassBorderSubtle">#0FC5F467</Color>
    <!-- Card shadow: strong black shadow -->
    <Color x:Key="ElevatedShadow">#7A000000</Color>
    <!-- Sidebar tint: lime 7% — warm tint on sidebar background -->
    <Color x:Key="GlassTintBlue">#12C5F467</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════
         D. STANDARD BRUSHES
         ═══════════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="BaseBgBrush"       Color="{StaticResource BaseBg}" />
    <SolidColorBrush x:Key="MantelBgBrush"     Color="{StaticResource MantelBg}" />
    <SolidColorBrush x:Key="CrustBgBrush"      Color="{StaticResource CrustBg}" />
    <SolidColorBrush x:Key="Surface0Brush"     Color="{StaticResource Surface0}" />
    <SolidColorBrush x:Key="Surface1Brush"     Color="{StaticResource Surface1}" />
    <SolidColorBrush x:Key="Surface2Brush"     Color="{StaticResource Surface2}" />
    <SolidColorBrush x:Key="Overlay0Brush"     Color="{StaticResource Overlay0}" />
    <SolidColorBrush x:Key="TextBrush"         Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubtextBrush"      Color="{StaticResource SubtextColor}" />
    <SolidColorBrush x:Key="AccentBrush"       Color="{StaticResource AccentPurple}" />
    <SolidColorBrush x:Key="AccentBlueBrush"   Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="AccentGreenBrush"  Color="{StaticResource AccentGreen}" />
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource AccentYellow}" />
    <SolidColorBrush x:Key="AccentPeachBrush"  Color="{StaticResource AccentPeach}" />
    <SolidColorBrush x:Key="AccentRedBrush"    Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="AccentMauveBrush"  Color="{StaticResource AccentMauve}" />

    <!-- Lime is bright — accent buttons need dark text for contrast -->
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#111113" />
    <SolidColorBrush x:Key="MenuItemHoverBrush"    Color="#40C5F467" />

    <SolidColorBrush x:Key="SearchHighlightBrush"        Color="{StaticResource SearchHighlight}" />
    <SolidColorBrush x:Key="SearchCurrentHighlightBrush" Color="{StaticResource SearchCurrentHighlight}" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         E. GLASS BRUSHES — Morph-style flat near-black surface system
         Near-flat gradients simulate subtle depth without glass-light effect
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- PRIMARY SURFACE (cards, panels): flat — no gradient, like codesurf surface.panel -->
    <SolidColorBrush x:Key="GlassBgBrush" Color="{StaticResource Surface0}" />

    <!-- GLASS BORDER: lime-tinted, ultra-subtle -->
    <SolidColorBrush x:Key="GlassBorderBrush"   Color="{StaticResource GlassBorder}" />

    <!-- GLASS HIGHLIGHT: transparent — Morph has no frosted inner edge -->
    <SolidColorBrush x:Key="GlassHighlightBrush" Color="#00000000" />

    <!-- SHADOW BRUSH -->
    <SolidColorBrush x:Key="ElevatedShadowBrush" Color="{StaticResource ElevatedShadow}" />

    <!-- SIDEBAR: flat, slightly darker than MantelBg -->
    <SolidColorBrush x:Key="GlassSidebarBrush" Color="#101014" />

    <!-- CANVAS BACKGROUND: flat MantelBg — depth from dot grid + hover glow only -->
    <SolidColorBrush x:Key="CanvasDepthBrush" Color="{StaticResource MantelBg}" />

    <!-- TOOLBAR: flat, slightly elevated from MantelBg -->
    <SolidColorBrush x:Key="GlassToolbarBrush" Color="#181820" />

    <!-- CARD TITLE BAR: flat, same tone as toolbar -->
    <SolidColorBrush x:Key="GlassTitleBarBrush" Color="#181820" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         F. ELEVATION SHADOW — tuned for near-black backgrounds
         Strong shadow (0.48) to float cards above the canvas
         ═══════════════════════════════════════════════════════════════════════ -->

    <DropShadowEffect x:Key="CardShadow"
                      ShadowDepth="10"
                      BlurRadius="36"
                      Opacity="0.48"
                      Color="#000000"
                      Direction="270" />

    <!-- ═══════════════════════════════════════════════════════════════════════
         G. DOT GRID — two layers, codesurf-style spotlight reveal
         Base: subtle gray dots (always visible).
         Glow: lime dots revealed via OpacityMask near the cursor.
         Matches codesurf theme.ts: gridColorSmall '#2a2e35' + gridGlowSmall
         'rgba(200,214,78,0.22)'.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Base dots: subtle gray — always visible at all zoom levels -->
    <SolidColorBrush x:Key="DotGridDotBrush"  Color="#2A2E35" />
    <!-- Base hairlines: fainter gray -->
    <SolidColorBrush x:Key="DotGridLineBrush" Color="#1A2A2E35" />
    <!-- Glow dots: neon lime, revealed only inside the cursor spotlight -->
    <SolidColorBrush x:Key="DotGridGlowBrush" Color="{StaticResource AccentPurple}" Opacity="0.38" />

</ResourceDictionary>
