    <!-- ═══════════════════════════════════════════════════════════════════════
         ICON STYLE (for Path elements using icons)
         ═══════════════════════════════════════════════════════════════════════ -->

    <Style x:Key="IconPath" TargetType="Path">
        <Setter Property="Stroke" Value="{StaticResource SubtextBrush}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style x:Key="IconPathSmall" TargetType="Path" BasedOn="{StaticResource IconPath}">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
    </Style>

    <Style x:Key="IconPathLarge" TargetType="Path" BasedOn="{StaticResource IconPath}">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
    </Style>

</ResourceDictionary>
