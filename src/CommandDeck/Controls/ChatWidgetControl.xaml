<UserControl x:Class="CommandDeck.Controls.ChatWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="540"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <ctrl:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header with title + provider/model -->
            <RowDefinition Height="Auto" />
            <!-- Messages list -->
            <RowDefinition Height="*" />
            <!-- Shimmer loading bar -->
            <RowDefinition Height="3" />
            <!-- Status text -->
            <RowDefinition Height="Auto" />
            <!-- Input area -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Header ───────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="10,6,10,6" BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
            </Border.BorderBrush>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title row -->
                <DockPanel Grid.Row="0" VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="20" Height="20" CornerRadius="5" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.18" />
                            </Border.Background>
                            <TextBlock Text="💬" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding ChatTitle, FallbackValue='Chat AI'}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Provider availability indicator -->
                    <Ellipse DockPanel.Dock="Right"
                             Width="7" Height="7" Margin="4,0,0,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#A6E3A1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProviderAvailable}" Value="False">
                                        <Setter Property="Fill" Value="#F38BA8" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Cancel button (visible when loading) -->
                    <Button DockPanel.Dock="Right"
                            Width="22" Height="22" Margin="4,0,0,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                            Command="{Binding CancelRequestCommand}"
                            ToolTip="Cancelar">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="4" Background="Transparent" Width="22" Height="22">
                                    <TextBlock Text="⏹" FontSize="9"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background">
                                            <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" /></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Clear history button -->
                    <Button DockPanel.Dock="Right"
                            Width="22" Height="22"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ClearHistoryCommand}"
                            ToolTip="Limpar conversa"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="4" Background="Transparent" Width="22" Height="22">
                                    <TextBlock Text="🗑" FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background">
                                            <Setter.Value><SolidColorBrush Color="{DynamicResource AccentRed}" Opacity="0.2" /></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>

                <!-- Provider + Model selectors row -->
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Provider selector -->
                    <ComboBox Grid.Column="0"
                              Height="24" FontSize="10"
                              SelectedItem="{Binding SelectedProviderLabel, Mode=OneWay}"
                              SelectionChanged="OnProviderSelected"
                              ToolTip="Selecionar provider de IA">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}" />
                        </ComboBox.Style>
                        <ComboBoxItem Content="Claude" />
                        <ComboBoxItem Content="OpenAI" />
                        <ComboBoxItem Content="OpenRouter" />
                        <ComboBoxItem Content="Local (Ollama)" />
                    </ComboBox>

                    <!-- Model selector -->
                    <ComboBox Grid.Column="2"
                              Height="24" FontSize="10"
                              ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                              ToolTip="Selecionar modelo">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}" />
                        </ComboBox.Style>
                    </ComboBox>
                </Grid>

                <!-- Agent Mode selector row -->
                <Grid Grid.Row="2" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              x:Name="AgentModeCombo"
                              Height="24" FontSize="10"
                              ItemsSource="{Binding AgentModes}"
                              SelectedItem="{Binding ActiveAgentMode, Mode=TwoWay}"
                              SelectionChanged="OnAgentModeChanged"
                              ToolTip="Selecionar modo do agente">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}"/>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="10" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Column="1" Text="{Binding ActiveModeLabel}"
                               FontSize="9" Foreground="{DynamicResource SubtextBrush}"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ─── Messages list ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="10,8">
            <ItemsControl x:Name="MessagesList"
                          ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <!-- Streaming dots -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="10,8"
                                        Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                                <Ellipse x:Name="Dot1" Width="6" Height="6" Margin="2,0"
                                         Fill="{DynamicResource SubtextBrush}" Opacity="0.6" />
                                <Ellipse x:Name="Dot2" Width="6" Height="6" Margin="2,0"
                                         Fill="{DynamicResource SubtextBrush}" Opacity="0.4" />
                                <Ellipse x:Name="Dot3" Width="6" Height="6" Margin="2,0"
                                         Fill="{DynamicResource SubtextBrush}" Opacity="0.2" />
                                <StackPanel.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Dot1"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0.2" To="1" Duration="0:0:0.5"
                                                                 AutoReverse="True" />
                                                <DoubleAnimation Storyboard.TargetName="Dot2"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0.2" To="1" Duration="0:0:0.5"
                                                                 BeginTime="0:0:0.17"
                                                                 AutoReverse="True" />
                                                <DoubleAnimation Storyboard.TargetName="Dot3"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0.2" To="1" Duration="0:0:0.5"
                                                                 BeginTime="0:0:0.34"
                                                                 AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </StackPanel.Triggers>
                            </StackPanel>

                            <!-- Message bubble (not streaming) -->
                            <Grid MaxWidth="320"
                                  Visibility="{Binding IsStreaming, Converter={StaticResource InvBoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="10,7">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="2,10,10,10" />
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.7" />
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="CornerRadius" Value="10,10,2,10" />
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.22" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="{DynamicResource AccentRed}" Opacity="0.15" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Content}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <!-- Copy button (only for assistant messages) -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal"
                                            Margin="4,2,0,4"
                                            Visibility="{Binding IsUser, Converter={StaticResource InvBoolToVis}}">
                                    <Button Width="20" Height="16"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Click="OnCopyMessage"
                                            ToolTip="Copiar mensagem">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock Text="📋" FontSize="9"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Opacity="0.5"
                                                           VerticalAlignment="Center" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ─── Shimmer loading bar ─────────────────────────────────────── -->
        <Grid Grid.Row="2" ClipToBounds="True"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="{DynamicResource Surface1Brush}" />
            <Rectangle x:Name="ShimmerHighlight" Width="200" HorizontalAlignment="Left">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0" />
                        <GradientStop Color="{DynamicResource AccentPurple}" Offset="0.5" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <TranslateTransform X="-200" />
                </Rectangle.RenderTransform>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource ShimmerAnimation}" />
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>
        </Grid>

        <!-- ─── Status bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Padding="10,3,10,3"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       Foreground="{DynamicResource SubtextBrush}"
                       Opacity="0.7"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- ─── Input area ───────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Padding="10,8"
                BorderThickness="0,1,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.4" />
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Template picker button -->
                <Button Grid.Column="0"
                        x:Name="TemplateBtnInput"
                        Width="30" Height="30"
                        Click="OnTemplatePickerClick"
                        ToolTip="Prompt Templates (Ctrl+T)"
                        Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="TplBg" CornerRadius="6" Background="Transparent"
                                    Width="30" Height="30">
                                <TextBlock Text="📝" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TplBg" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBox Grid.Column="2"
                         x:Name="ChatInput"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Pergunte algo..."
                         AcceptsReturn="False"
                         Padding="10,6"
                         MinHeight="34"
                         MaxHeight="90"
                         FontSize="12"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Center"
                         IsEnabled="{Binding IsLoading, Converter={StaticResource InvBoolToVis},
                             ConverterParameter=BoolToEnabled}"
                         KeyDown="OnChatInputKeyDown" />

                <Button Grid.Column="4"
                        Width="34" Height="34"
                        Click="OnSendClicked"
                        ToolTip="Enviar (Ctrl+Enter)"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvBoolToVis},
                            ConverterParameter=BoolToEnabled}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SendBg" CornerRadius="8" Width="34" Height="34">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.7" />
                                </Border.Background>
                                <TextBlock Text="➤" FontSize="13"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SendBg" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="SendBg" Property="Opacity" Value="0.35" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ─── Template Picker Popup ───────────────────────────────────────── -->
        <Popup x:Name="TemplatePickerPopup"
               PlacementTarget="{Binding ElementName=TemplateBtnInput}"
               Placement="Top"
               VerticalOffset="-6"
               StaysOpen="False"
               AllowsTransparency="True"
               MaxWidth="380">
            <Border CornerRadius="10" Padding="12,10"
                    BorderThickness="1" MaxHeight="400">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.98"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.6"/>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Prompt Templates"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                        <ItemsControl x:Name="TemplateList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="7" Padding="10,8"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnTemplateItemClick">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/></Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value><SolidColorBrush Color="{DynamicResource Blue}" Opacity="0.15"/></Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                       FontSize="16" Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="10"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="0,2,0,0"/>
                                                <TextBlock FontSize="9" Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="0,2,0,0">
                                                    <Run Text="{Binding Category}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Fields.Count, Mode=OneWay}"/>
                                                    <Run Text=" campos"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</UserControl>
