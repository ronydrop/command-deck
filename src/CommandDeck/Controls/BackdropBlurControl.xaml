<UserControl x:Class="CommandDeck.Controls.BackdropBlurControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="300"
             IsHitTestVisible="False">
    <Grid>
        <!-- Blurred snapshot of the parent visual.
             NOTE: This captures a static snapshot at initialization time.
             Only suitable for overlays that appear over content that does NOT
             change frequently (e.g. Command Palette, modal dialogs).
             The Fill is set in code-behind via VisualBrush. -->
        <Rectangle x:Name="BackdropRect">
            <Rectangle.Effect>
                <BlurEffect x:Name="BlurFx" Radius="10" />
            </Rectangle.Effect>
        </Rectangle>

        <!-- Semi-transparent tint overlay for depth -->
        <Rectangle x:Name="TintRect" Opacity="0.6">
            <Rectangle.Fill>
                <SolidColorBrush x:Name="TintBrush" Color="#131318" />
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>
