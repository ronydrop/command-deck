<UserControl x:Class="CommandDeck.Controls.BrowserWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="700" d:DesignHeight="480">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <ctrl:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="5" Background="Transparent"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Accent strip -->
            <RowDefinition Height="3"/>
            <!-- Toolbar -->
            <RowDefinition Height="36"/>
            <!-- WebView2 -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <!-- Accent strip -->
        <Border Grid.Row="0" Background="#89b4fa" CornerRadius="0"/>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="1">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.92"/>
            </Border.Background>
            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back -->
                <Button Grid.Column="0" x:Name="BtnBack"
                        Width="28" Height="28"
                        IsEnabled="{Binding CanGoBack}"
                        Click="OnBackClick"
                        ToolTip="Voltar"
                        Style="{StaticResource NavBtn}">
                    <TextBlock Text="←" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                </Button>

                <!-- Forward -->
                <Button Grid.Column="1" x:Name="BtnForward"
                        Width="28" Height="28"
                        IsEnabled="{Binding CanGoForward}"
                        Click="OnForwardClick"
                        ToolTip="Avançar"
                        Style="{StaticResource NavBtn}">
                    <TextBlock Text="→" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                </Button>

                <!-- Reload -->
                <Button Grid.Column="2" x:Name="BtnReload"
                        Width="28" Height="28"
                        Click="OnReloadClick"
                        ToolTip="Recarregar (F5)"
                        Style="{StaticResource NavBtn}">
                    <TextBlock x:Name="ReloadIcon" Text="↻" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                </Button>

                <!-- URL Bar -->
                <Border Grid.Column="3" CornerRadius="6" Margin="6,5"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.4"/>
                    </Border.BorderBrush>
                    <TextBox x:Name="AddressBar"
                             Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextBrush}"
                             CaretBrush="{DynamicResource TextBrush}"
                             FontSize="11"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             KeyDown="OnAddressBarKeyDown"
                             GotFocus="OnAddressBarFocus"/>
                </Border>

                <!-- Desktop/Mobile toggle -->
                <ToggleButton Grid.Column="4"
                              Width="28" Height="28"
                              IsChecked="{Binding IsDesktopMode}"
                              Click="OnDesktopModeClick"
                              Margin="2,0">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="ToolTip" Value="Modo Desktop — clique para Mobile"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bg" CornerRadius="5" Background="Transparent"
                                                Width="28" Height="28">
                                            <TextBlock x:Name="Icon" Text="🖥" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="Icon" Property="Text" Value="📱"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background">
                                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/></Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="ToolTip" Value="Modo Mobile — clique para Desktop"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <!-- Home -->
                <Button Grid.Column="5" x:Name="BtnHome"
                        Width="28" Height="28"
                        Click="OnHomeClick"
                        ToolTip="Página inicial"
                        Style="{StaticResource NavBtn}">
                    <TextBlock Text="⌂" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── WebView2 ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <!-- Loading progress bar -->
            <Border x:Name="LoadingBar" Height="2" VerticalAlignment="Top"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#89b4fa" Offset="0"/>
                        <GradientStop Color="#cba6f7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Not-ready placeholder -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsBrowserReady, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="🌐" FontSize="32" HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="Inicializando browser..." FontSize="12"
                           Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- WebView2 -->
            <wv2:WebView2 x:Name="WebView"
                          Visibility="{Binding IsBrowserReady, Converter={StaticResource BoolToVisibility}}"
                          NavigationStarting="OnNavigationStarting"
                          NavigationCompleted="OnNavigationCompleted"
                          CoreWebView2InitializationCompleted="OnCoreWebView2Initialized"/>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.8"/>
            </Border.Background>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       Foreground="{DynamicResource SubtextBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

    </Grid>
</UserControl>
