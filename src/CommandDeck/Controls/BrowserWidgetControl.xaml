<UserControl x:Class="CommandDeck.Controls.BrowserWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="700" d:DesignHeight="480">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <ctrl:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <!-- Nav button (Back / Reload) -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="5" Background="Transparent"
                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Traffic-light dot button -->
        <Style x:Key="DotBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <!-- Header with traffic lights + toolbar -->
            <RowDefinition Height="40"/>
            <!-- WebView2 content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" x:Name="HeaderBorder"
                BorderThickness="0,0,0,1"
                Cursor="SizeAll"
                MouseLeftButtonDown="OnHeaderMouseDown"
                MouseMove="OnHeaderMouseMove"
                MouseLeftButtonUp="OnHeaderMouseUp">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.96"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.4"/>
            </Border.BorderBrush>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Traffic lights -->
                    <ColumnDefinition Width="76"/>
                    <!-- Nav buttons -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- URL pill -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Traffic lights -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <!-- Red: close -->
                    <Button Click="OnCloseDotClick" Width="18" Height="18"
                            Style="{StaticResource DotBtn}" ToolTip="Fechar">
                        <Ellipse Width="12" Height="12" Fill="#FF5F57"/>
                    </Button>
                    <!-- Yellow: minimize -->
                    <Button Click="OnMinimizeDotClick" Width="18" Height="18"
                            Style="{StaticResource DotBtn}" ToolTip="Minimizar" Margin="5,0,0,0">
                        <Ellipse Width="12" Height="12" Fill="#FEBC2E"/>
                    </Button>
                    <!-- Green: focus/zoom -->
                    <Button Click="OnMaximizeDotClick" Width="18" Height="18"
                            Style="{StaticResource DotBtn}" ToolTip="Foco" Margin="5,0,0,0">
                        <Ellipse Width="12" Height="12" Fill="#28C840"/>
                    </Button>
                </StackPanel>

                <!-- Nav buttons: Back + Reload -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="2,0">
                    <Button x:Name="BtnBack"
                            Width="28" Height="28"
                            IsEnabled="{Binding CanGoBack}"
                            Click="OnBackClick"
                            ToolTip="Voltar"
                            Style="{StaticResource NavBtn}">
                        <TextBlock Text="←" FontSize="14" Foreground="{DynamicResource TextBrush}"/>
                    </Button>
                    <Button x:Name="BtnReload"
                            Width="28" Height="28"
                            Click="OnReloadClick"
                            ToolTip="Recarregar (F5)"
                            Style="{StaticResource NavBtn}">
                        <TextBlock x:Name="ReloadIcon" Text="↻" FontSize="14"
                                   Foreground="{DynamicResource TextBrush}"/>
                    </Button>
                </StackPanel>

                <!-- URL pill -->
                <Border Grid.Column="2" CornerRadius="13" Height="26"
                        Margin="4,0,10,0" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.85"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.6"/>
                    </Border.BorderBrush>
                    <TextBox x:Name="AddressBar"
                             Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextBrush}"
                             CaretBrush="{DynamicResource TextBrush}"
                             FontSize="11"
                             VerticalContentAlignment="Center"
                             Padding="12,0"
                             KeyDown="OnAddressBarKeyDown"
                             GotFocus="OnAddressBarFocus"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── WebView2 ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <!-- Loading progress bar (2px top) -->
            <Border x:Name="LoadingBar" Height="2" VerticalAlignment="Top"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource AccentBlue}" Offset="0"/>
                        <GradientStop Color="{DynamicResource AccentPurple}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Not-ready placeholder -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsBrowserReady, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="🌐" FontSize="32" HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="Inicializando browser..." FontSize="12"
                           Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- WebView2 (Composition variant: participates in WPF visual tree,
                 respects ClipToBounds, RenderTransform and zoom transforms) -->
            <wv2:WebView2 x:Name="WebView"
                          Visibility="{Binding IsBrowserReady, Converter={StaticResource BoolToVisibility}}"
                          NavigationStarting="OnNavigationStarting"
                          NavigationCompleted="OnNavigationCompleted"
                          CoreWebView2InitializationCompleted="OnCoreWebView2Initialized"/>
        </Grid>
    </Grid>
</UserControl>
