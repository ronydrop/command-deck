<UserControl x:Class="CommandDeck.Controls.TokenCounterWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:WidgetCanvasItemViewModel}"
             d:DesignWidth="340" d:DesignHeight="320"
             Background="Transparent">

    <Grid Margin="14,10,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="Auto" />   <!-- stats section label -->
            <RowDefinition Height="Auto" />   <!-- stat rows -->
            <RowDefinition Height="8" />      <!-- spacer -->
            <RowDefinition Height="Auto" />   <!-- estimator section label -->
            <RowDefinition Height="Auto" />   <!-- estimator input -->
            <RowDefinition Height="Auto" />   <!-- estimator result -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⬡" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="Token Counter" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Current model badge -->
            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                    Background="{DynamicResource Surface1Brush}" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentModelDisplay}" FontSize="10"
                           Foreground="{DynamicResource SubtextBrush}" />
            </Border>
        </Grid>

        <!-- ── Session stats label ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="1" Text="SESSÃO ATUAL"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtextBrush}"
                   Margin="0,0,0,6" />

        <!-- ── Stats grid ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Input tokens -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tokens de entrada"
                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DisplayInputTokens}"
                       FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"
                       Foreground="{DynamicResource AccentBrush}" />

            <!-- Output tokens -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tokens de saída"
                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DisplayOutputTokens}"
                       FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"
                       Foreground="{DynamicResource AccentGreenBrush}" />

            <!-- Total tokens -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Total de tokens"
                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DisplayTotalTokens}"
                       FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"
                       Foreground="{DynamicResource TextBrush}" />

            <!-- Separator line -->
            <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,4" />

            <!-- Cost row -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Custo estimado"
                       FontSize="11" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" />
            <StackPanel Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock Text="{Binding DisplayCostUsd}"
                           FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource AccentYellowBrush}" HorizontalAlignment="Right" />
                <TextBlock Text="{Binding DisplayCostBrl}"
                           FontSize="10" Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Right" Margin="0,1,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Estimator section label ─────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Text="ESTIMADOR MANUAL"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtextBrush}"
                   Margin="0,0,0,6" />

        <!-- ── Estimator input ─────────────────────────────────────────────── -->
        <Border Grid.Row="5" CornerRadius="4" BorderThickness="1"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                Background="{DynamicResource Surface1Brush}"
                Margin="0,0,0,6">
            <TextBox x:Name="EstimatorTextBox"
                     Text="{Binding EstimatorInputText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MaxHeight="64" MinHeight="32"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource TextBrush}"
                     FontSize="11" Padding="8,6"
                     ToolTip="Cole ou digite texto para estimar tokens"
                     VerticalContentAlignment="Top" />
        </Border>

        <!-- ── Estimator result ────────────────────────────────────────────── -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Estimativa:"
                       FontSize="11" Foreground="{DynamicResource SubtextBrush}"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="{Binding EstimatedTokenCount}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text=" tokens" FontSize="11"
                           Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Column="2" Text="{Binding EstimatedCostDisplay}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentYellowBrush}" VerticalAlignment="Center" />
        </Grid>

    </Grid>
</UserControl>
