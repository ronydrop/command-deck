<UserControl x:Class="CommandDeck.Controls.PomodoroWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:WidgetCanvasItemViewModel}"
             d:DesignWidth="280" d:DesignHeight="340"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="14,10,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header -->
            <RowDefinition Height="Auto" />  <!-- arc timer -->
            <RowDefinition Height="Auto" />  <!-- cycle dots -->
            <RowDefinition Height="8" />     <!-- spacer -->
            <RowDefinition Height="Auto" />  <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🍅" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="Pomodoro" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Phase label badge -->
            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                    Background="{DynamicResource Surface1Brush}" VerticalAlignment="Center">
                <TextBlock Text="{Binding PomodoroPhaseLabel}" FontSize="10"
                           Foreground="{DynamicResource SubtextBrush}" />
            </Border>
        </Grid>

        <!-- ── Arc timer (120×120 Viewbox) ────────────────────────────────── -->
        <Grid Grid.Row="1" Width="140" Height="140"
              HorizontalAlignment="Center" Margin="0,0,0,12">

            <!-- Background track circle -->
            <Ellipse Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Stroke="{DynamicResource Surface1Brush}" StrokeThickness="8"
                     Fill="Transparent" />

            <!-- Progress arc — geometry updated in code-behind -->
            <Path x:Name="ArcPath"
                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="8"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Fill="Transparent"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path.Data>
                    <PathGeometry x:Name="ArcGeometry">
                        <PathFigure x:Name="ArcFigure" IsClosed="False">
                            <ArcSegment x:Name="ArcSegment"
                                        Size="60,60"
                                        IsLargeArc="False"
                                        SweepDirection="Clockwise" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- Center time display -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TimeLabel" Text="{Binding PomodoroTimeDisplay}"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding PomodoroPhaseLabel}"
                           FontSize="10" Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Center" Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Cycle dots ──────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,4">
            <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3" />
            <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3" />
            <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3" />
            <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3" />
        </StackPanel>

        <!-- ── Controls ────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <!-- Reset button -->
            <Button Command="{Binding PomodoroResetCommand}"
                    ToolTip="Reiniciar"
                    Style="{DynamicResource GhostButton}"
                    Padding="10,6" FontSize="14" Margin="0,0,6,0">
                <TextBlock Text="↺" />
            </Button>

            <!-- Play / Pause button -->
            <Button Command="{Binding PomodoroStartPauseCommand}"
                    ToolTip="Iniciar / Pausar"
                    Style="{DynamicResource AccentButton}"
                    Padding="18,6" MinWidth="80" Margin="0,0,6,0">
                <TextBlock FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="▶ Iniciar" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PomodoroIsRunning}" Value="True">
                                    <Setter Property="Text" Value="⏸ Pausar" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- Skip button -->
            <Button Command="{Binding PomodoroSkipCommand}"
                    ToolTip="Pular fase"
                    Style="{DynamicResource GhostButton}"
                    Padding="10,6" FontSize="14">
                <TextBlock Text="⏭" />
            </Button>
        </StackPanel>

    </Grid>
</UserControl>
