<UserControl x:Class="CommandDeck.Controls.WorktreeSelectorPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type vm:WorktreeSelectorViewModel}}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource Surface0Brush}"
            BorderBrush="{DynamicResource Surface1Brush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0,4"
            MinWidth="280"
            MaxWidth="380"
            MaxHeight="400">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Worktrees"
                       Style="{StaticResource CaptionText}"
                       FontWeight="SemiBold"
                       Margin="12,6,12,4" />

            <Rectangle Fill="{DynamicResource Surface1Brush}" Height="1" Margin="0,2,0,2" />

            <!-- Worktree list -->
            <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Worktrees}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Worktree info button -->
                                <Button Grid.Column="0"
                                        Style="{StaticResource GhostButton}"
                                        Padding="8,6"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding DataContext.SelectWorktreeCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource FolderIcon}"
                                                  Stroke="{DynamicResource SubtextBrush}"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  Stretch="Uniform"
                                                  Width="12" Height="12"
                                                  Margin="0,0,6,0"
                                                  VerticalAlignment="Center" />
                                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <Binding Path="Path" />
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <!-- "principal" badge -->
                                            <Border Background="{DynamicResource AccentBlueBrush}"
                                                    CornerRadius="4"
                                                    Padding="4,1"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMain}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="principal"
                                                           FontSize="9"
                                                           Foreground="{DynamicResource BaseBgBrush}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <!-- Branch name -->
                                        <TextBlock Text="{Binding Branch}"
                                                   Style="{StaticResource CaptionText}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource AccentMauveBrush}"
                                                   FontSize="11"
                                                   Margin="18,1,0,0" />
                                    </StackPanel>
                                </Button>

                                <!-- Remove button (only for non-main worktrees) -->
                                <Button Grid.Column="1"
                                        Width="24" Height="24"
                                        ToolTip="Remover worktree"
                                        Command="{Binding DataContext.RemoveWorktreeCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMain}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource CloseIcon}"
                                          Stroke="{DynamicResource AccentRedBrush}"
                                          StrokeThickness="1.5"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="10" Height="10" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Rectangle Fill="{DynamicResource Surface1Brush}" Height="1" Margin="0,2,0,2" />

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource AccentRedBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="12,4,12,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}" />

            <!-- Create form -->
            <StackPanel Margin="8,4,8,4"
                        Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                <TextBox Text="{Binding NewWorktreePath, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Caminho do worktree"
                         Margin="0,0,0,6" />
                <TextBox Text="{Binding NewWorktreeBranch, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Nome da branch"
                         Margin="0,0,0,6" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Criar"
                            Style="{StaticResource AccentButton}"
                            FontSize="12"
                            Padding="12,4"
                            Command="{Binding CreateWorktreeCommand}"
                            Margin="0,0,6,0" />
                    <Button Content="Cancelar"
                            Style="{StaticResource GhostButton}"
                            FontSize="12"
                            Padding="12,4"
                            Command="{Binding CancelCreateCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- "Novo Worktree" button -->
            <Button Style="{StaticResource GhostButton}"
                    Padding="12,6"
                    HorizontalContentAlignment="Left"
                    Command="{Binding ShowCreateFormCommand}"
                    Margin="4,0,4,4"
                    Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource PlusIcon}"
                          Stroke="{DynamicResource AccentBrush}"
                          StrokeThickness="1.5"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="12" Height="12"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center" />
                    <TextBlock Text="Novo Worktree"
                               FontSize="12"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
