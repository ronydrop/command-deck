<UserControl x:Class="CommandDeck.Controls.ActivityFeedWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="300" d:DesignHeight="480">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <ctrl:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>    <!-- Accent strip -->
            <RowDefinition Height="36"/>   <!-- Toolbar -->
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>    <!-- Feed list -->
            <RowDefinition Height="22"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Accent strip -->
        <Border Grid.Row="0" Background="#94e2d5" CornerRadius="0"/>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="1">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.85"/>
            </Border.Background>
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" Text="Activity Feed"
                           FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"/>
                <!-- Pause/Resume -->
                <Button Grid.Column="2" Width="26" Height="26" Cursor="Hand"
                        Command="{Binding TogglePauseCommand}"
                        Background="Transparent" BorderThickness="0"
                        ToolTip="Pausar / Retomar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content"><Setter.Value><TextBlock Text="⏸" FontSize="11"/></Setter.Value></Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                    <Setter Property="Content"><Setter.Value><TextBlock Text="▶" FontSize="11"/></Setter.Value></Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Clear -->
                <Button Grid.Column="3" Width="26" Height="26" Cursor="Hand"
                        Command="{Binding ClearFeedCommand}"
                        Background="Transparent" BorderThickness="0"
                        ToolTip="Limpar feed">
                    <TextBlock Text="🗑" FontSize="11"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Filters ────────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="8,4,8,4">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.6"/>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="5" Padding="6,0" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.4"/>
                    </Border.BorderBrush>
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextBrush}"
                             CaretBrush="{DynamicResource TextBrush}"
                             FontSize="11" Height="26" VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <TextBlock x:Name="ph" Text="Filtrar..."
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Visibility="Collapsed" IsHitTestVisible="False"/>
                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding TypeFilters}"
                          SelectedItem="{Binding SelectedTypeFilter}"
                          Height="26" FontSize="10"
                          Style="{StaticResource DarkComboBox}"/>
            </Grid>
        </Border>

        <!-- ── Feed list ──────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="3"
                      x:Name="FeedScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8,4">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,4" CornerRadius="6" Padding="8,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background">
                                        <Setter.Value><SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.7"/></Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon badge -->
                                <Border Grid.Column="0" Width="26" Height="26"
                                        CornerRadius="6" Margin="0,0,8,0" VerticalAlignment="Top">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.6"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding Icon}" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- Content -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Detail, Converter={StaticResource StringToVis}}"/>
                                </StackPanel>
                                <!-- Relative time -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding RelativeTime}"
                                           FontSize="9"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           VerticalAlignment="Top"
                                           Margin="6,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="4">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.8"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock FontSize="10" Foreground="{DynamicResource SubtextBrush}">
                    <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                    <Run Text=" eventos"/>
                </TextBlock>
                <TextBlock Text=" · Pausado" FontSize="10" Foreground="#f38ba8"
                           Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}"
                           Margin="2,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
