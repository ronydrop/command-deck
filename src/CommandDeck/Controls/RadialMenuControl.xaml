                        Padding="8,4"
                        HorizontalContentAlignment="Left" />
                <Button Content="GPT"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding SelectAgentCommand}"
                        CommandParameter="openai"
                        Foreground="#A6E3A1"
                        FontSize="12"
                        Padding="8,4"
                        HorizontalContentAlignment="Left" />
                <Button Content="Ollama"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding SelectAgentCommand}"
                        CommandParameter="local"
                        Foreground="#FAB387"
                        FontSize="12"
                        Padding="8,4"
                        HorizontalContentAlignment="Left" />
            </StackPanel>
        </Border>
