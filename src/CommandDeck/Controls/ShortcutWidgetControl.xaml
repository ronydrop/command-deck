<UserControl x:Class="CommandDeck.Controls.ShortcutWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="300" d:DesignHeight="200"
             Background="{DynamicResource Surface0Brush}"
             Padding="12">

    <StackPanel>
        <TextBlock Text="Atalhos" FontSize="11"
                   Foreground="{DynamicResource SubtextBrush}"
                   Margin="0,0,0,8" />

        <ItemsControl ItemsSource="{Binding Shortcuts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding}"
                            HorizontalContentAlignment="Left"
                            Margin="0,2"
                            Padding="10,6"
                            Cursor="Hand"
                            Click="OnShortcutClicked"
                            Tag="{Binding}"
                            Style="{StaticResource GhostButton}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
