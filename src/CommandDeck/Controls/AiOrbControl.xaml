<UserControl x:Class="CommandDeck.Controls.AiOrbControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:controls="clr-namespace:CommandDeck.Controls"
             Width="56" Height="56"
             Focusable="False"
             d:DataContext="{d:DesignInstance vm:AiOrbViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />

        <!-- Orb pulse animation storyboard -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.25"
                             Duration="0:0:0.7" />
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.25"
                             Duration="0:0:0.7" />
        </Storyboard>

        <!-- Processing spin animation -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ProcessingRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360"
                             Duration="0:0:1.2" />
        </Storyboard>

        <!-- Hover animation storyboard -->
        <Storyboard x:Key="HoverOnAnimation">
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1.08" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1.08" Duration="0:0:0.15" />
        </Storyboard>
        <Storyboard x:Key="HoverOffAnimation">
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1.0" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1.0" Duration="0:0:0.15" />
        </Storyboard>
    </UserControl.Resources>

    <!--
        Wrapper sem BitmapCache — apenas distribui as duas camadas.
        ClipToBounds="False" permite que bolhas e popup ultrapassem os 56px do orb.
    -->
    <!-- Background="Transparent" garante hit-testing na área completa do UserControl
         mesmo onde não há elementos filhos visíveis, permitindo drag em qualquer ponto do orb. -->
    <Grid x:Name="LayoutRoot" ClipToBounds="False" Background="Transparent">

        <!-- ═══ Camada 1: visual do orb ══════════════════════════════════════
             BitmapCache removido: cortava o blur do DropShadowEffect nos
             limites dos 56px e causava blur em monitores com DPI > 100%. -->
        <Grid x:Name="OrbRoot" Width="56" Height="56">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="OrbScale" ScaleX="1" ScaleY="1" CenterX="28" CenterY="28" />
            </Grid.RenderTransform>

            <!-- Glow aura — halo suave ao redor do orb (fill quase transparente para DropShadow funcionar) -->
            <Ellipse x:Name="GlowAura"
                     Width="48" Height="48"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <SolidColorBrush x:Name="GlowBrush" Color="#CBA6F7" Opacity="0.08" />
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect x:Name="GlowAuraEffect"
                                      Color="#CBA6F7"
                                      BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.8" />
                </Ellipse.Effect>
            </Ellipse>

            <!-- Orb background circle (glassmorphism) -->
            <Ellipse Width="48" Height="48"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                        <GradientStop Color="#E61E1E2E" Offset="0" />
                        <GradientStop Color="#CC181825" Offset="1" />
                    </LinearGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect x:Name="OrbGlow"
                                      Color="#CBA6F7"
                                      BlurRadius="16"
                                      ShadowDepth="0"
                                      Opacity="0.6" />
                </Ellipse.Effect>
            </Ellipse>

            <!-- Border highlight (top arc shine) -->
            <Ellipse Width="48" Height="48"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stroke="#33FFFFFF"
                     StrokeThickness="1"
                     Fill="Transparent" />

            <!-- Processing ring (spinning arc when State=Processing) -->
            <Ellipse x:Name="ProcessingRing"
                     Width="52" Height="52"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stroke="#CBA6F7"
                     StrokeThickness="2"
                     Fill="Transparent"
                     StrokeDashArray="3 5"
                     StrokeDashCap="Round"
                     Visibility="Collapsed">
                <Ellipse.RenderTransform>
                    <RotateTransform CenterX="26" CenterY="26" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Recording ring (red pulse) -->
            <Ellipse x:Name="RecordingRing"
                     Width="52" Height="52"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stroke="#F38BA8"
                     StrokeThickness="2"
                     Fill="Transparent"
                     Visibility="Collapsed" />

            <!-- Clickable button layer — Focusable=False para não roubar foco do terminal.
                 O Command foi removido: click vs drag é controlado inteiramente no code-behind
                 para evitar conflito entre Button.Click e o sistema de drag. -->
            <Button x:Name="OrbButton"
                    Width="48" Height="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Focusable="False"
                    IsTabStop="False"
                    Panel.ZIndex="10"
                    ToolTipService.InitialShowDelay="600"
                    ToolTipService.ShowDuration="4000">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource OrbTooltipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="AI Dev Assistant" VerticalAlignment="Center"/>
                            <TextBlock Text="  Ctrl+Alt+A" Foreground="#88A6ADC8" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToolTip>
                </Button.ToolTip>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="PressGrid"
                              Background="Transparent"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.9" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="PressGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.9" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="PressGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="PressGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

                <!-- Icon: Sparkles (idle/active), Mic (recording), Spinner dots (processing) -->
                <Grid Width="26" Height="26">
                    <!-- Sparkles icon (idle/active) — ícone Lucide "sparkles" para AI assistant -->
                    <Path x:Name="RobotIcon"
                          Data="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.937A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"
                          Stroke="White"
                          StrokeThickness="1.2"
                          StrokeLineJoin="Round"
                          Fill="White"
                          Stretch="Uniform"
                          Opacity="0.95" />

                    <!-- Mic icon (recording) — Lucide "mic" com stroke para visual mais limpo -->
                    <Path x:Name="MicIcon"
                          Data="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z M19 10v2a7 7 0 0 1-14 0v-2 M12 19v3"
                          Stroke="#F38BA8"
                          StrokeThickness="1.6"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Opacity="0.95"
                          Visibility="Collapsed" />

                    <!-- Processing dots -->
                    <StackPanel x:Name="ProcessingDots"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <Ellipse Width="5" Height="5" Fill="White" Margin="1,0" Opacity="0.9" />
                        <Ellipse Width="5" Height="5" Fill="White" Margin="1,0" Opacity="0.6" />
                        <Ellipse Width="5" Height="5" Fill="White" Margin="1,0" Opacity="0.3" />
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>

        <!-- ═══ Camada 2: elementos dinâmicos (SEM BitmapCache) ═══
             Estes elementos mudam frequentemente (texto de transcrição, status, popup)
             e ficam FORA do BitmapCache para não invalidá-lo a cada update.
             IsHitTestVisible="False" garante que a área transparente não bloqueia cliques no orb. -->

        <!-- Transcription bubble (shown during recording) -->
        <Border x:Name="TranscriptionBubble"
                Background="#E61E1E2E"
                BorderBrush="#33CBA6F7"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,4"
                MaxWidth="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="60,0,0,0"
                IsHitTestVisible="False"
                Visibility="{Binding TranscriptionText, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding TranscriptionText}"
                       Foreground="#CDD6F4"
                       FontSize="11"
                       TextWrapping="Wrap"
                       MaxHeight="60" />
        </Border>

        <!-- Status message bubble -->
        <Border x:Name="StatusBubble"
                Background="#E61E1E2E"
                BorderBrush="#33A6E3A1"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,4"
                MaxWidth="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="60,0,0,0"
                IsHitTestVisible="False"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#A6E3A1"
                       FontSize="11" />
        </Border>

        <!-- Suggestion badge — green dot top-right, visible when HasSuggestion=true -->
        <Ellipse x:Name="SuggestionBadge"
                 Width="10" Height="10"
                 Fill="#A6E3A1"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,4,4,0"
                 IsHitTestVisible="False"
                 Visibility="{Binding HasSuggestion, Converter={StaticResource BoolToVis}}">
            <Ellipse.Effect>
                <DropShadowEffect Color="#A6E3A1"
                                  BlurRadius="6"
                                  ShadowDepth="0"
                                  Opacity="0.9" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- Radial menu popup — fora do BitmapCache para não disparar re-cache ao abrir/fechar -->
        <Popup x:Name="RadialPopup"
               IsOpen="{Binding IsRadialMenuOpen}"
               AllowsTransparency="True"
               PopupAnimation="None"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=LayoutRoot}"
               StaysOpen="False">
            <controls:RadialMenuControl DataContext="{Binding}" />
        </Popup>

        <!-- ── Quick Chat inline input ─────────────────────────────────────── -->
        <Border x:Name="QuickChatPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="62,6,0,0"
                MinWidth="220" MaxWidth="320"
                CornerRadius="10"
                Padding="0"
                BorderThickness="1"
                Visibility="{Binding IsQuickChatOpen, Converter={StaticResource BoolToVis}}">
            <Border.Background>
                <SolidColorBrush Color="#E01E1E2E" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#44CBA6F7" />
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.4" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         x:Name="QuickChatTextBox"
                         Text="{Binding QuickChatInput, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#CDD6F4"
                         CaretBrush="#CBA6F7"
                         FontSize="12"
                         Padding="10,8"
                         MinHeight="36"
                         MaxHeight="100"
                         AcceptsReturn="False"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <TextBlock x:Name="ph" Text="Pergunte algo ao AI..."
                                                       Padding="10,8" FontSize="12"
                                                       Foreground="#6C7086"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"
                                                       IsHitTestVisible="False"/>
                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Column="1"
                        Command="{Binding SendQuickChatCommand}"
                        Width="34" Margin="0,4,4,4"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="7" Background="Transparent" Padding="5">
                                <TextBlock Text="↑" FontSize="14" Foreground="#CBA6F7"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#44CBA6F7"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Active terminal count badge (top-left of orb) -->
        <Border x:Name="TerminalCountBadge"
                Width="16" Height="16"
                CornerRadius="8"
                Background="#A6E3A1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="0,2,0,0"
                IsHitTestVisible="False"
                Visibility="{Binding ActiveTerminalCount, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding ActiveTerminalCount}"
                       FontSize="8" FontWeight="Bold"
                       Foreground="#1E1E2E"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>
