<UserControl x:Class="CommandDeck.Controls.AiOrbControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:controls="clr-namespace:CommandDeck.Controls"
             Width="56" Height="56"
             Focusable="False"
             d:DataContext="{d:DesignInstance vm:AiOrbViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:HexColorToBrushConverter x:Key="HexToBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />

        <!-- Orb pulse animation storyboard -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.25"
                             Duration="0:0:0.7" />
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.25"
                             Duration="0:0:0.7" />
        </Storyboard>

        <!-- Processing spin animation -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ProcessingRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360"
                             Duration="0:0:1.2" />
        </Storyboard>
    </UserControl.Resources>

    <!--
        Wrapper sem BitmapCache — apenas distribui as duas camadas.
        ClipToBounds="False" permite que bolhas e popup ultrapassem os 56px do orb.
    -->
    <Grid ClipToBounds="False">

        <!-- ═══ Camada 1: visual do orb ══════════════════════════════════════
             BitmapCache removido: cortava o blur do DropShadowEffect nos
             limites dos 56px e causava blur em monitores com DPI > 100%. -->
        <Grid x:Name="OrbRoot" Width="56" Height="56">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="OrbScale" ScaleX="1" ScaleY="1" CenterX="28" CenterY="28" />
            </Grid.RenderTransform>

            <!-- Glow aura — maior que o orb para criar halo visível ao redor -->
            <Ellipse x:Name="GlowAura"
                     Width="64" Height="64"
                     Opacity="0.85">
                <Ellipse.Fill>
                    <SolidColorBrush x:Name="GlowBrush" Color="#CBA6F7" />
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect x:Name="GlowAuraEffect"
                                      Color="#CBA6F7"
                                      BlurRadius="32"
                                      ShadowDepth="0"
                                      Opacity="1.0" />
                </Ellipse.Effect>
            </Ellipse>

            <!-- Orb background circle (glassmorphism) -->
            <Ellipse Width="48" Height="48"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                        <GradientStop Color="#E61E1E2E" Offset="0" />
                        <GradientStop Color="#CC181825" Offset="1" />
                    </LinearGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect x:Name="OrbGlow"
                                      Color="#CBA6F7"
                                      BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.9" />
                </Ellipse.Effect>
            </Ellipse>

            <!-- Border highlight (top arc shine) -->
            <Ellipse Width="48" Height="48"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stroke="#33FFFFFF"
                     StrokeThickness="1"
                     Fill="Transparent" />

            <!-- Processing ring (spinning arc when State=Processing) -->
            <Ellipse x:Name="ProcessingRing"
                     Width="52" Height="52"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stroke="#CBA6F7"
                     StrokeThickness="2"
                     Fill="Transparent"
                     StrokeDashArray="3 5"
                     StrokeDashCap="Round"
                     Visibility="Collapsed">
                <Ellipse.RenderTransform>
                    <RotateTransform CenterX="26" CenterY="26" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Recording ring (red pulse) -->
            <Ellipse x:Name="RecordingRing"
                     Width="52" Height="52"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stroke="#F38BA8"
                     StrokeThickness="2"
                     Fill="Transparent"
                     Visibility="Collapsed" />

            <!-- Clickable button layer — Focusable=False para não roubar foco do terminal -->
            <Button x:Name="OrbButton"
                    Width="48" Height="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Focusable="False"
                    IsTabStop="False"
                    Command="{Binding ToggleRadialMenuCommand}"
                    ToolTip="AI Dev Assistant (Ctrl+Alt+A)"
                    Panel.ZIndex="10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Button.Template>

                <!-- Icon: Robot (idle/active), Mic (recording), Spinner dots (processing) -->
                <Grid Width="28" Height="28">
                    <!-- Robot icon (idle/active) — stroke adicionado para melhor legibilidade em qualquer DPI -->
                    <Path x:Name="RobotIcon"
                          Data="M12 2C13.1 2 14 2.9 14 4C14 4.74 13.6 5.39 13 5.73V7H15C16.1 7 17 7.9 17 9V18C17 19.1 16.1 20 15 20H9C7.9 20 7 19.1 7 18V9C7 7.9 7.9 7 9 7H11V5.73C10.4 5.39 10 4.74 10 4C10 2.9 10.9 2 12 2M9 9V18H15V9H9M10 10H11V12H10V10M13 10H14V12H13V10M10 14H14V16H10V14Z"
                          Fill="White"
                          Stroke="White"
                          StrokeThickness="0.3"
                          Stretch="Uniform"
                          Opacity="1.0" />

                    <!-- Mic icon (recording) -->
                    <Path x:Name="MicIcon"
                          Data="M12 2C10.3 2 9 3.3 9 5V11C9 12.7 10.3 14 12 14S15 12.7 15 11V5C15 3.3 13.7 2 12 2M17.3 11C17.3 14 14.76 16.1 12 16.1C9.24 16.1 6.7 14 6.7 11H5C5 14.41 7.72 17.23 11 17.72V21H13V17.72C16.28 17.23 19 14.41 19 11H17.3Z"
                          Fill="#F38BA8"
                          Stretch="Uniform"
                          Opacity="0.95"
                          Visibility="Collapsed" />

                    <!-- Processing dots -->
                    <StackPanel x:Name="ProcessingDots"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <Ellipse Width="5" Height="5" Fill="White" Margin="1,0" Opacity="0.9" />
                        <Ellipse Width="5" Height="5" Fill="White" Margin="1,0" Opacity="0.6" />
                        <Ellipse Width="5" Height="5" Fill="White" Margin="1,0" Opacity="0.3" />
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>

        <!-- ═══ Camada 2: elementos dinâmicos (SEM BitmapCache) ═══
             Estes elementos mudam frequentemente (texto de transcrição, status, popup)
             e ficam FORA do BitmapCache para não invalidá-lo a cada update.
             IsHitTestVisible="False" garante que a área transparente não bloqueia cliques no orb. -->

        <!-- Transcription bubble (shown during recording) -->
        <Border x:Name="TranscriptionBubble"
                Background="#E61E1E2E"
                BorderBrush="#33CBA6F7"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,4"
                MaxWidth="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="60,0,0,0"
                Visibility="{Binding TranscriptionText, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding TranscriptionText}"
                       Foreground="#CDD6F4"
                       FontSize="11"
                       TextWrapping="Wrap"
                       MaxHeight="60" />
        </Border>

        <!-- Status message bubble -->
        <Border x:Name="StatusBubble"
                Background="#E61E1E2E"
                BorderBrush="#33A6E3A1"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,4"
                MaxWidth="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="60,0,0,0"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#A6E3A1"
                       FontSize="11" />
        </Border>

        <!-- Radial menu popup — fora do BitmapCache para não disparar re-cache ao abrir/fechar -->
        <Popup x:Name="RadialPopup"
               IsOpen="{Binding IsRadialMenuOpen}"
               AllowsTransparency="True"
               PopupAnimation="None"
               Placement="Center"
               PlacementTarget="{Binding ElementName=OrbButton}"
               StaysOpen="False">
            <controls:RadialMenuControl DataContext="{Binding}" />
        </Popup>

    </Grid>
</UserControl>
