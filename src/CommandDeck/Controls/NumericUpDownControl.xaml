<UserControl x:Class="CommandDeck.Controls.NumericUpDownControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <UserControl.Resources>
        <Style x:Key="SpinnerButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface1Brush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface2Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            Background="{DynamicResource Surface0Brush}"
            BorderBrush="{DynamicResource Surface1Brush}"
            BorderThickness="1"
            CornerRadius="6"
            MinHeight="36"
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="26"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="ValueBox"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource TextBrush}"
                     CaretBrush="{DynamicResource TextBrush}"
                     Padding="10,0,4,0"
                     FontSize="13"
                     VerticalContentAlignment="Center"
                     SelectionBrush="{DynamicResource AccentBrush}"
                     PreviewTextInput="ValueBox_PreviewTextInput"
                     DataObject.Pasting="ValueBox_Pasting"
                     LostFocus="ValueBox_LostFocus"/>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource Surface1Brush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <RepeatButton Grid.Row="0"
                                  Style="{StaticResource SpinnerButton}"
                                  Delay="400" Interval="80"
                                  Click="UpButton_Click">
                        <TextBlock Text="▲" FontSize="7"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </RepeatButton>

                    <Border Grid.Row="1"
                            Background="{DynamicResource Surface1Brush}"
                            Opacity="0.5"/>

                    <RepeatButton Grid.Row="2"
                                  Style="{StaticResource SpinnerButton}"
                                  Delay="400" Interval="80"
                                  Click="DownButton_Click">
                        <TextBlock Text="▼" FontSize="7"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </RepeatButton>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
