<UserControl x:Class="CommandDeck.Controls.CanvasCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             mc:Ignorable="d"
             d:DesignWidth="620" d:DesignHeight="420"
             Focusable="False"
             Opacity="0">

    <!-- ── A. Entrance animation: slide+fade in on Loaded ──────────────────────
         RenderTransform starts at Y=-8 and animates to Y=0 alongside Opacity 0→1.
         FillBehavior=HoldEnd is intentional here: this is a one-time entrance
         animation so the final values (Opacity=1, Y=0) should be held permanently. -->
    <UserControl.RenderTransform>
        <TranslateTransform Y="-8" />
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade in: Opacity 0 → 1 in 200ms QuadraticEase Out -->
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.200">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Slide in: TranslateTransform.Y -8 → 0 in 200ms -->
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="-8" To="0"
                                     Duration="0:0:0.200">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>

        <!-- Shell type icon lookup -->
        <conv:CanvasItemTypeIconConverter x:Key="ItemTypeIconConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:AiSessionTypeToVisibilityConverter x:Key="AiToVis" />
        <conv:AiSessionTypeToBrushConverter x:Key="AiTypeBrush" />
        <conv:AiSessionTypeToLabelConverter x:Key="AiTypeLabel" />
        <conv:AiModelToLabelConverter x:Key="AiModelLabel" />
        <conv:AiModelToBrushConverter x:Key="AiModelBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:NotificationTypeToBrushConverter x:Key="PaneStateBrush" />
        <conv:AiAgentStateToIconConverter x:Key="AiStateIcon" />
        <conv:AiAgentStateToLabelConverter x:Key="AiStateLabel" />
        <conv:AiAgentStateToBrushConverter x:Key="AiStateBrush" />
        <conv:AiAgentStateToVisibilityConverter x:Key="AiStateToVis" />

        <!-- Template selector chooses content based on ViewModel type -->
        <ctrl:CanvasItemContentTemplateSelector x:Key="ContentSelector">
            <ctrl:CanvasItemContentTemplateSelector.TerminalTemplate>
                <DataTemplate DataType="{x:Type vm:TerminalCanvasItemViewModel}">
                    <ctrl:TerminalControl DataContext="{Binding Terminal}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.TerminalTemplate>
            <ctrl:CanvasItemContentTemplateSelector.GitWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:GitWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.GitWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.ProcessWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:ProcessWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.ProcessWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.ShortcutWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:ShortcutWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.ShortcutWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.NoteWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:NoteWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.NoteWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.ImageWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:ImageWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.ImageWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.KanbanWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:KanbanBoardControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.KanbanWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.ChatWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:ChatWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.ChatWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.SystemMonitorWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:SystemMonitorWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.SystemMonitorWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.TokenCounterWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:TokenCounterWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.TokenCounterWidgetTemplate>
            <ctrl:CanvasItemContentTemplateSelector.PomodoroWidgetTemplate>
                <DataTemplate DataType="{x:Type vm:WidgetCanvasItemViewModel}">
                    <ctrl:PomodoroWidgetControl DataContext="{Binding}" />
                </DataTemplate>
            </ctrl:CanvasItemContentTemplateSelector.PomodoroWidgetTemplate>
        </ctrl:CanvasItemContentTemplateSelector>

    </UserControl.Resources>

    <!-- ───────────────────────────────────────────────────────────────────
         OUTER GLOW LAYER — a second translucent Border behind the card
         that becomes visible on hover to create an accent glow effect.
         It sits in a Grid at the same position as the card.
         ─────────────────────────────────────────────────────────────────── -->
    <Grid ClipToBounds="False">

        <!-- Glow border (rendered below card) — stronger accent glow on hover.
             CornerRadius matches CardBorder exactly to avoid corner bleed.
             In tiled mode corners are square so the glow doesn't bleed into adjacent cards. -->
        <Border x:Name="GlowBorder"
                BorderThickness="1.5"
                Background="Transparent"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8" />
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.45" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                            <Setter Property="CornerRadius" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <BlurEffect Radius="6" />
            </Border.Effect>
        </Border>

        <!-- Selection glow — purple drop-shadow visible only when IsSelected=True.
             Fades in over 200 ms on selection and out over 150 ms on deselection. -->
        <Border x:Name="SelectionGlowBorder"
                BorderThickness="0"
                Background="Transparent"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                            <Setter Property="CornerRadius" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.200">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.150" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource AccentPurple}"
                                  ShadowDepth="0" BlurRadius="18" Opacity="0.6" />
            </Border.Effect>
        </Border>

        <!-- ── Card wrapper ──────────────────────────────────────────────── -->
        <Border x:Name="CardBorder"
                BorderThickness="1"
                Background="{DynamicResource GlassBgBrush}"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                    <Setter Property="CornerRadius" Value="8" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="BorderThickness" Value="1.5" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFocused}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="BorderThickness" Value="1.5" />
                        </DataTrigger>
                        <!-- AI session: tinted left border accent -->
                        <DataTrigger Binding="{Binding AiSessionType, Converter={StaticResource AiToVis}}" Value="Visible">
                            <Setter Property="BorderBrush" Value="{Binding AiSessionType, Converter={StaticResource AiTypeBrush}}" />
                        </DataTrigger>
                        <!-- Tiled mode: square corners to align cleanly with adjacent cards -->
                        <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                            <Setter Property="CornerRadius" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <!-- Drop shadow — glass elevated shadow with visible depth -->
            <Border.Effect>
                <DropShadowEffect x:Name="CardShadow"
                                  BlurRadius="12"
                                  ShadowDepth="3"
                                  Opacity="0.18"
                                  Color="#000000" />
            </Border.Effect>

            <!-- Hover triggers: intensify shadow + show glow border -->
            <Border.Triggers>
                <EventTrigger RoutedEvent="Mouse.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Shadow BlurRadius 12 → 20 (lift effect) -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="BlurRadius"
                                To="20"
                                Duration="0:0:0.18" />
                            <!-- Shadow Opacity 0.20 → 0.30 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="Opacity"
                                To="0.30"
                                Duration="0:0:0.18" />
                            <!-- Shadow ShadowDepth 3 → 6 (card lifts up) -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="ShadowDepth"
                                To="6"
                                Duration="0:0:0.18" />
                            <!-- GlowBorder Opacity 0 → 1 -->
                            <DoubleAnimation
                                Storyboard.TargetName="GlowBorder"
                                Storyboard.TargetProperty="Opacity"
                                To="1"
                                Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Mouse.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Shadow BlurRadius 20 → 12 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="BlurRadius"
                                To="12"
                                Duration="0:0:0.22" />
                            <!-- Shadow Opacity 0.30 → 0.18 -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="Opacity"
                                To="0.18"
                                Duration="0:0:0.22" />
                            <!-- Shadow ShadowDepth 6 → 3 (card settles down) -->
                            <DoubleAnimation
                                Storyboard.TargetName="CardShadow"
                                Storyboard.TargetProperty="ShadowDepth"
                                To="3"
                                Duration="0:0:0.22" />
                            <!-- GlowBorder Opacity 1 → 0 -->
                            <DoubleAnimation
                                Storyboard.TargetName="GlowBorder"
                                Storyboard.TargetProperty="Opacity"
                                To="0"
                                Duration="0:0:0.22" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <!-- Inner glass highlight — 2px top + 1px sides for frosted glass edge -->
            <Border BorderThickness="1,2,1,0"
                    BorderBrush="{DynamicResource GlassHighlightBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="7" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                                <Setter Property="CornerRadius" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

            <Grid x:Name="ContentGrid"
                  SizeChanged="OnContentGridSizeChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ─── Title bar ──────────────────────────────────────────────── -->
                <Grid Grid.Row="0"
                      x:Name="TitleBar"
                      Background="{DynamicResource GlassTitleBarBrush}"
                      Cursor="SizeAll"
                      MouseDown="OnTitleBarMouseDown"
                      MouseMove="OnTitleBarMouseMove"
                      MouseUp="OnTitleBarMouseUp">

                    <!-- Clip top two corners to card radius -->
                    <Grid.Clip>
                        <RectangleGeometry Rect="0,0,2000,32" RadiusX="8" RadiusY="8" />
                    </Grid.Clip>

                    <Grid.ContextMenu>
                        <ContextMenu x:Name="CardContextMenu">

                            <MenuItem Header="⚡ Corrigir Último Erro"
                                      Click="OnAiFixError" />
                            <MenuItem Header="💡 Explicar Saída"
                                      Click="OnAiExplainOutput" />
                            <MenuItem Header="🔧 Sugerir Comando"
                                      Click="OnAiSuggestCommand" />
                            <Separator />
                            <MenuItem Header="📤 Enviar Contexto à IA"
                                      Click="OnAiSendContext" />
                            <Separator />
                            <MenuItem Header="🔄 Executar Novamente"
                                      Click="OnAiRunAgain" />
                            <MenuItem Header="⚡ Corrigir Novamente"
                                      Click="OnAiFixAgain" />
                            <MenuItem Header="💡 Explicar Mais"
                                      Click="OnAiExplainMore" />
                        </ContextMenu>
                    </Grid.ContextMenu>

                    <!-- Very subtle separator line at bottom of title bar -->
                    <Rectangle VerticalAlignment="Bottom"
                               Height="1"
                               HorizontalAlignment="Stretch"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.5" />

                    <DockPanel Margin="10,0,6,0" VerticalAlignment="Center">

                        <!-- Status dot (left, before title) -->
                        <Ellipse DockPanel.Dock="Left"
                                 Width="9" Height="9"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Surface2Brush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Terminal.IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Pane state icon (⚡🔔✅) — mirrors Zellij claude-pane-notify -->
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding PaneStateIcon}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   Visibility="{Binding PaneStateIcon, Converter={StaticResource StringToVis}}"
                                   ToolTip="{Binding PaneState}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <!-- Pulse animation when Running -->
                                        <DataTrigger Binding="{Binding PaneState}" Value="Running">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.4"
                                                                         Duration="0:0:0.8"
                                                                         AutoReverse="True">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- AI badge: session type pill -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="0,0,3,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding AiSessionType, Converter={StaticResource AiToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.2" />
                            </Border.Background>
                            <TextBlock Text="{Binding AiSessionType, Converter={StaticResource AiTypeLabel}}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{Binding AiSessionType, Converter={StaticResource AiTypeBrush}}"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- AI badge: model pill -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding AiSessionType, Converter={StaticResource AiToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" />
                            </Border.Background>
                            <TextBlock Text="{Binding AiModelUsed, Converter={StaticResource AiModelLabel}}"
                                       FontSize="9" FontWeight="SemiBold"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="{Binding AiModelUsed, Converter={StaticResource AiModelBrush}}"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- AI agent state indicator (only for AI sessions) -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="4"
                                Padding="4,1"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding AiAgentState, Converter={StaticResource AiStateToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.4" />
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding AiAgentStateIcon}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="0,0,3,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <!-- Pulse for Thinking -->
                                                <DataTrigger Binding="{Binding AiAgentState}" Value="Thinking">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="AiThinkPulse">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.3"
                                                                                 Duration="0:0:1"
                                                                                 AutoReverse="True">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <SineEase EasingMode="EaseInOut" />
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="AiThinkPulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                                <!-- Pulse for Executing -->
                                                <DataTrigger Binding="{Binding AiAgentState}" Value="Executing">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="AiExecPulse">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.3"
                                                                                 Duration="0:0:0.6"
                                                                                 AutoReverse="True" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="AiExecPulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                                <!-- Fast pulse for WaitingUser -->
                                                <DataTrigger Binding="{Binding AiAgentState}" Value="WaitingUser">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="AiWaitPulse">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.2"
                                                                                 Duration="0:0:0.4"
                                                                                 AutoReverse="True" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="AiWaitPulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding AiAgentStateLabel}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{Binding AiAgentState, Converter={StaticResource AiStateBrush}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Close button -->
                        <Button DockPanel.Dock="Right"
                                x:Name="CloseButton"
                                Width="20" Height="20"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="OnCloseClicked"
                                ToolTip="Fechar"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="closeBg"
                                            CornerRadius="4"
                                            Background="Transparent"
                                            Width="20" Height="20">
                                        <Path Data="{StaticResource CloseIcon}"
                                              Stroke="{DynamicResource SubtextBrush}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="9" Height="9"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="closeBg" Property="Background"
                                                    Value="{DynamicResource AccentRedBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Title text -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="12"
                                   FontFamily="{StaticResource MonoFont}"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                    </DockPanel>
                </Grid>

                <!-- ─── Content area ───────────────────────────────────────────── -->
                <ContentControl Grid.Row="1"
                                Content="{Binding}"
                                ContentTemplateSelector="{StaticResource ContentSelector}"
                                Focusable="False"
                                ClipToBounds="True" />

                <!-- ─── Resize handle: right edge (horizontal only) ──────────── -->
                <Thumb Grid.Row="0" Grid.RowSpan="2"
                       x:Name="ResizeThumbRight"
                       Width="6"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Stretch"
                       Margin="0,0,0,18"
                       Cursor="SizeWE"
                       Background="Transparent"
                       BorderThickness="0"
                       DragStarted="OnResizeDragStarted"
                       DragDelta="OnResizeRightDragDelta"
                       DragCompleted="OnResizeDragCompleted"
                       FocusVisualStyle="{x:Null}">
                    <Thumb.Style>
                        <Style TargetType="Thumb">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Thumb.Style>
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="edgeBg" Background="Transparent" Width="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Opacity" Value="0.4" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <!-- ─── Resize handle: bottom edge (vertical only) ────────────── -->
                <Thumb Grid.Row="1"
                       x:Name="ResizeThumbBottom"
                       Height="6"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Bottom"
                       Margin="0,0,18,0"
                       Cursor="SizeNS"
                       Background="Transparent"
                       BorderThickness="0"
                       DragStarted="OnResizeDragStarted"
                       DragDelta="OnResizeBottomDragDelta"
                       DragCompleted="OnResizeDragCompleted"
                       FocusVisualStyle="{x:Null}">
                    <Thumb.Style>
                        <Style TargetType="Thumb">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Thumb.Style>
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="edgeBg" Background="Transparent" Height="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Opacity" Value="0.4" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <!-- ─── Resize handle (bottom-right) — 3 diagonal lines ───────── -->
                <Thumb Grid.Row="1"
                       x:Name="ResizeThumb"
                       Width="18" Height="18"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Cursor="SizeNWSE"
                       Background="Transparent"
                       BorderThickness="0"
                       DragStarted="OnResizeDragStarted"
                       DragDelta="OnResizeDragDelta"
                       DragCompleted="OnResizeDragCompleted"
                       FocusVisualStyle="{x:Null}">
                    <Thumb.Style>
                        <Style TargetType="Thumb">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTiledMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Thumb.Style>
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <!-- 3-line diagonal grip icon — hidden by default, visible on hover -->
                            <Canvas x:Name="GripCanvas" Width="18" Height="18" Opacity="0">
                                <!-- Line 1 (shortest, top) -->
                                <Line X1="5"  Y1="15" X2="15" Y2="5"
                                      Stroke="{DynamicResource Surface2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="0.5" />
                                <!-- Line 2 (middle) -->
                                <Line X1="9" Y1="15" X2="15" Y2="9"
                                      Stroke="{DynamicResource Surface2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="0.75" />
                                <!-- Line 3 (longest, bottom) -->
                                <Line X1="13" Y1="15" X2="15" Y2="13"
                                      Stroke="{DynamicResource Surface2Brush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Opacity="1.0" />
                            </Canvas>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="GripCanvas" Property="Opacity" Value="1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <!-- ─── Size indicator overlay (shown during resize) ──────────── -->
                <Border Grid.Row="1"
                        x:Name="SizeIndicator"
                        Background="#CC1E1E2E"
                        CornerRadius="4"
                        Padding="8,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,24,24"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Panel.ZIndex="100">
                    <TextBlock x:Name="SizeIndicatorText"
                               Text="1200 × 680"
                               Foreground="White"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="12"
                               FontWeight="Medium" />
                </Border>

            </Grid>
            </Border><!-- end glass highlight border -->
        </Border>
    </Grid>
</UserControl>
