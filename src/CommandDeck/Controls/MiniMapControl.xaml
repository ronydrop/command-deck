<UserControl x:Class="CommandDeck.Controls.MiniMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="200" d:DesignHeight="140"
             d:DataContext="{d:DesignInstance Type={x:Type vm:MiniMapViewModel}}"
             Width="{Binding MiniMapWidth}"
             Height="{Binding ControlHeight}"
             IsHitTestVisible="True"
             Focusable="False">

    <!-- Outer border: glass surface with visible shadow and frosted border -->
    <Border CornerRadius="10"
            Opacity="0.96"
            Background="{DynamicResource GlassBgBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1.5"
            ClipToBounds="True">

        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.20" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Header label row -->
                <RowDefinition Height="22" />
                <!-- Map canvas row — collapses to 0 when minimized -->
                <RowDefinition>
                    <RowDefinition.Style>
                        <Style TargetType="RowDefinition">
                            <Setter Property="Height" Value="*" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                    <Setter Property="Height" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RowDefinition.Style>
                </RowDefinition>
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource GlassTitleBarBrush}"
                    CornerRadius="9,9,0,0"
                    Padding="8,0">
                <Grid>
                    <TextBlock Text="Minimap"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtextBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left" />

                    <!-- Collapse / expand toggle button -->
                    <Button Command="{Binding ToggleCollapsedCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="16" Height="16"
                            Cursor="Hand"
                            ToolTip="Minimizar / Maximizar">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="Transparent" CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface1Brush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <!-- Chevron: points UP (=collapse) when expanded, DOWN (=expand) when collapsed -->
                        <Path x:Name="Chevron"
                              Data="M6 9L12 15L18 9"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Width="9" Height="6"
                              Stretch="Uniform"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="ChevronRotation" Angle="180" />
                            </Path.RenderTransform>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="0" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Map canvas ─────────────────────────────────────────────── -->
            <!-- ClipToBounds ensures nothing bleeds outside the area -->
            <Canvas Grid.Row="1"
                    x:Name="MapCanvas"
                    ClipToBounds="True"
                    Background="Transparent"
                    MouseDown="OnMapMouseDown"
                    MouseMove="OnMapMouseMove"
                    MouseUp="OnMapMouseUp"
                    Cursor="Hand">

                <!-- Item rectangles — rendered via ItemsControl so they update reactively -->
                <ItemsControl ItemsSource="{Binding ItemRects}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top"  Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Rectangle Width="{Binding Width}"
                                       Height="{Binding Height}"
                                       RadiusX="1" RadiusY="1"
                                       Opacity="0.85">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <!-- Default: widget colour -->
                                        <Setter Property="Fill"   Value="{DynamicResource AccentYellowBrush}" />
                                        <Setter Property="Stroke" Value="Transparent" />
                                        <Setter Property="StrokeThickness" Value="1" />
                                        <Style.Triggers>
                                            <!-- Terminal colour -->
                                            <DataTrigger Binding="{Binding IsTerminal}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                            </DataTrigger>
                                            <!-- AI terminal colour (overrides terminal) -->
                                            <DataTrigger Binding="{Binding IsAiSession}" Value="True">
                                                <Setter Property="Fill">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{DynamicResource AccentCyan}" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <!-- Selected highlight -->
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Stroke" Value="{DynamicResource AccentMauveBrush}" />
                                                <Setter Property="StrokeThickness" Value="1.5" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Viewport rectangle — shows what is currently visible on the main canvas -->
                <Border x:Name="ViewportRect"
                        IsHitTestVisible="False"
                        BorderThickness="1.5"
                        CornerRadius="1"
                        Canvas.Left="{Binding ViewportRectX}"
                        Canvas.Top="{Binding ViewportRectY}"
                        Width="{Binding ViewportRectW}"
                        Height="{Binding ViewportRectH}">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.9" />
                    </Border.BorderBrush>
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.08" />
                    </Border.Background>
                </Border>

            </Canvas>

        </Grid>
    </Border>
</UserControl>
