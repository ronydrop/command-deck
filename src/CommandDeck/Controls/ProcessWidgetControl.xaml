<UserControl x:Class="CommandDeck.Controls.ProcessWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="350"
             Background="Transparent"
             Padding="14,10,14,14">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Border Width="28" Height="28" CornerRadius="7" VerticalAlignment="Center" Margin="0,0,10,0">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.15" />
                </Border.Background>
                <TextBlock Text="⚡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Processos Ativos"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
                <TextBlock FontSize="10" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7">
                    <Run Text="Monitorando" />
                    <Run Text="{Binding Processes.Count, FallbackValue='0', Mode=OneWay}" />
                    <Run Text="processos" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Column headers -->
        <Border Grid.Row="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="66" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NOME" FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource SubtextBrush}" Opacity="0.6"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="CPU" FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource SubtextBrush}" Opacity="0.6"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="MEM" FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource SubtextBrush}" Opacity="0.6"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Process list -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding Processes}"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,1" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="ItemBg" CornerRadius="6" Padding="10,7" Background="Transparent">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBg" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.4" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="28" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="{Binding Port, StringFormat=':{0}', FallbackValue=''}"
                                       FontSize="9" FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource AccentBlueBrush}" Opacity="0.8" />
                        </StackPanel>

                        <Border Grid.Column="1" CornerRadius="4" Padding="4,2"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AccentYellow}" Opacity="0.1" />
                            </Border.Background>
                            <TextBlock Text="{Binding FormattedCpu}"
                                       FontSize="10" FontFamily="{StaticResource MonoFont}" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentYellowBrush}"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding FormattedMemory}"
                                   FontSize="10" FontFamily="{StaticResource MonoFont}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />

                        <Border Grid.Column="3" Width="22" Height="22" CornerRadius="5"
                                VerticalAlignment="Center" Cursor="Hand"
                                x:Name="KillBg" Background="Transparent">
                            <Button Content="✕" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource AccentRedBrush}"
                                    Click="OnKillProcessClicked"
                                    Tag="{Binding Pid}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom accent line -->
        <Border Grid.Row="3" Height="2" CornerRadius="1" Margin="20,6,20,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0" />
                    <GradientStop Color="{DynamicResource AccentBlue}" Offset="0.5" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>
    </Grid>
</UserControl>
