<UserControl x:Class="CommandDeck.Controls.NotificationHistoryPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             Width="360">

    <UserControl.Resources>
        <conv:NotificationTypeToBrushConverter x:Key="TypeToBrush" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource Surface0Brush}"
            BorderBrush="{DynamicResource Surface1Brush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0"
            MaxHeight="420">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.4" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource Surface1Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,10">
                <DockPanel>
                    <TextBlock Text="Notificações"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource GhostButton}"
                            Content="Limpar"
                            FontSize="11"
                            Padding="8,4"
                            HorizontalAlignment="Right"
                            Command="{Binding DataContext.ClearNotificationHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </DockPanel>
            </Border>

            <!-- Notification list -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="340">
                <ItemsControl ItemsSource="{Binding DataContext.NotificationHistory, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,8"
                                    BorderBrush="{DynamicResource Surface1Brush}"
                                    BorderThickness="0,0,0,0.5"
                                    Background="Transparent">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.5" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Color stripe dot -->
                                    <Ellipse Grid.Column="0"
                                             Width="6" Height="6"
                                             Fill="{Binding Type, Converter={StaticResource TypeToBrush}}"
                                             VerticalAlignment="Top"
                                             Margin="0,5,0,0" />

                                    <!-- Icon -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Icon}"
                                               FontSize="13"
                                               VerticalAlignment="Top"
                                               Margin="0,0,8,0" />

                                    <!-- Content -->
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="30"
                                                   Visibility="{Binding Message, Converter={StaticResource NullToVis}}" />
                                    </StackPanel>

                                    <!-- Time -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding CreatedAt, StringFormat=HH:mm}"
                                               Foreground="{DynamicResource Overlay0Brush}"
                                               FontSize="10"
                                               VerticalAlignment="Top"
                                               Margin="8,2,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Grid.Row="1"
                       Text="Nenhuma notificação"
                       Foreground="{DynamicResource Overlay0Brush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.NotificationHistory.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Footer -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource Surface1Brush}"
                    BorderThickness="0,1,0,0"
                    Padding="14,6">
                <Button Style="{StaticResource GhostButton}"
                        Content="Marcar todas como lidas"
                        FontSize="11"
                        Padding="8,4"
                        HorizontalAlignment="Center"
                        Command="{Binding DataContext.MarkNotificationsAsReadCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
