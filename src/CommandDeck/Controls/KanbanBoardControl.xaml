<UserControl x:Class="CommandDeck.Controls.KanbanBoardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="660" d:DesignHeight="440"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Converters -->
        <conv:HexToBrushConverter x:Key="HexToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <ctrl:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:AgentToModelsConverter x:Key="AgentToModels" />
        <conv:UnresolvedDepsConverter x:Key="UnresolvedDeps" />
        <conv:StringEqualsConverter x:Key="StringEquals" />

        <!-- Column container -->
        <Style x:Key="ColumnBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.5" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Column header band -->
        <Style x:Key="ColumnHeaderStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.6" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card ListBox: no selection highlight, transparent chrome -->
        <Style x:Key="KanbanListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <!-- Card item: no selection blue highlight -->
        <Style x:Key="KanbanCardItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnCardMouseLeftDown" />
            <EventSetter Event="PreviewMouseMove" Handler="OnCardMouseMove" />
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
             Card DataTemplate (shared across all columns)
        ═══════════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="KanbanCardTemplate" DataType="{x:Type vm:KanbanCardViewModel}">
            <Grid>
                <!-- Main card border — left accent via BorderBrush + BorderThickness="3,0,0,0" -->
                <Border x:Name="CardBorder"
                        CornerRadius="6"
                        Margin="0,2"
                        Padding="9,0,6,0"
                        BorderThickness="3,0,0,0"
                        ClipToBounds="True">
                    <Border.BorderBrush>
                        <Binding Path="Color" Converter="{StaticResource HexToBrush}" />
                    </Border.BorderBrush>
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.55" />
                    </Border.Background>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <!-- ── Collapsed card header (always visible) ──────── -->
                        <Grid Margin="0,7,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Title + agent badge -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <!-- Title display — double-click to rename -->
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Tag="{Binding}"
                                           MouseDown="OnCardTitleMouseDown"
                                           Cursor="IBeam"
                                           ToolTip="Clique duplo para renomear">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Inline title editor — visible on double-click -->
                                <TextBox Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" FontWeight="SemiBold"
                                         Background="Transparent"
                                         BorderThickness="0,0,0,1.5"
                                         BorderBrush="{DynamicResource AccentBrush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         VerticalContentAlignment="Center"
                                         Tag="{Binding}"
                                         KeyDown="OnCardTitleKeyDown"
                                         IsVisibleChanged="OnCardTitleEditBoxVisibleChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <Border CornerRadius="6" Padding="5,1" Margin="0,0,4,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.18" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding Agent}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Launched pulsing dot -->
                            <Ellipse x:Name="LaunchedDot"
                                     Grid.Column="1"
                                     Width="7" Height="7"
                                     VerticalAlignment="Top"
                                     Margin="0,2,2,0"
                                     Fill="Transparent">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Launched}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="Opacity"
                                                                From="1" To="0.3"
                                                                Duration="0:0:1" AutoReverse="True">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <SineEase EasingMode="EaseInOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <!-- Execute (▶) button — hidden after launch -->
                            <Button Grid.Column="2"
                                    Tag="{Binding}"
                                    Width="22" Height="22"
                                    VerticalAlignment="Center"
                                    Margin="1,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand"
                                    Click="OnExecuteCardClicked"
                                    Visibility="{Binding Launched, Converter={StaticResource InvBoolToVis}}">
                                <Button.IsEnabled>
                                    <MultiBinding Converter="{StaticResource UnresolvedDeps}" ConverterParameter="bool">
                                        <Binding Path="Card.CardRefs" />
                                        <Binding Path="DataContext.KanbanColumnViewModels"
                                                 RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </Button.IsEnabled>
                                <Button.ToolTip>
                                    <MultiBinding Converter="{StaticResource UnresolvedDeps}">
                                        <Binding Path="Card.CardRefs" />
                                        <Binding Path="DataContext.KanbanColumnViewModels"
                                                 RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </Button.ToolTip>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ExecBg" CornerRadius="4" Background="Transparent"
                                                Width="22" Height="22">
                                            <TextBlock x:Name="ExecIcon" Text="▶" FontSize="9"
                                                       Foreground="{DynamicResource AccentGreenBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ExecBg" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{DynamicResource AccentGreen}" Opacity="0.18" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ExecIcon" Property="Text" Value="⏸" />
                                                <Setter TargetName="ExecIcon" Property="Foreground" Value="{DynamicResource AccentMauveBrush}" />
                                                <Setter TargetName="ExecIcon" Property="Opacity" Value="0.7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Expand (⌄/⌃) toggle button -->
                            <Button Grid.Column="3"
                                    Tag="{Binding}"
                                    Width="20" Height="22"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand"
                                    Click="OnToggleExpandCard">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ExpBg" CornerRadius="4" Background="Transparent"
                                                Width="20" Height="22">
                                            <TextBlock x:Name="ChevronText"
                                                       Text="⌄" FontSize="11"
                                                       Foreground="{DynamicResource SubtextBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ExpBg" Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- ── Expanded detail panel (editor) ───────────────── -->
                        <Border x:Name="ExpandedPanel"
                                Padding="0,0,0,6"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- Thin separator -->
                                <Separator Margin="0,2,0,4">
                                    <Separator.Style>
                                        <Style TargetType="Separator">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" />
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Separator.Style>
                                </Separator>

                                <!-- Tab strip -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <!-- Overview tab button -->
                                    <Border x:Name="TabOverviewBg" CornerRadius="4" Padding="7,3" Margin="0,0,3,0"
                                            Tag="overview" MouseDown="OnCardTabClick" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveTab}" Value="overview">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.18" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Overview" FontSize="9" FontWeight="SemiBold" Cursor="Hand">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveTab}" Value="overview">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <!-- Notes tab button -->
                                    <Border CornerRadius="4" Padding="7,3" Margin="0,0,3,0"
                                            Tag="notes" MouseDown="OnCardTabClick" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveTab}" Value="notes">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.18" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Tag="notes" FontSize="9" FontWeight="SemiBold" Cursor="Hand">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveTab}" Value="notes">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="Notas (" /><Run Text="{Binding Comments.Count, Mode=OneWay}" /><Run Text=")" />
                                        </TextBlock>
                                    </Border>
                                    <!-- Progress tab button -->
                                    <Border CornerRadius="4" Padding="7,3"
                                            Tag="progress" MouseDown="OnCardTabClick" Cursor="Hand"
                                            Visibility="{Binding Launched, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveTab}" Value="progress">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{DynamicResource AccentGreen}" Opacity="0.15" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Progresso" FontSize="9" FontWeight="SemiBold" Cursor="Hand">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveTab}" Value="progress">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <!-- ══ OVERVIEW TAB ══════════════════════════════════════ -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="overview">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Description -->
                                    <TextBlock Text="Descrição" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding DraftDescription, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="48" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"
                                             FontSize="11"
                                             Padding="5,4"
                                             Margin="0,0,0,6"
                                             Tag="{Binding}"
                                             KeyDown="OnCardEditorKeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}" />
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Instructions -->
                                    <TextBlock Text="Instruções" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding DraftInstructions, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="48" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"
                                             FontSize="10"
                                             FontFamily="{StaticResource MonoFont}"
                                             Padding="5,4"
                                             Margin="0,0,0,6"
                                             Tag="{Binding}"
                                             KeyDown="OnCardEditorKeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}" />
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Agent pills -->
                                    <TextBlock Text="Agente" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,3" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border x:Name="AgentClaude" Tag="claude" CornerRadius="10" Padding="7,3" Margin="0,0,3,0"
                                                Cursor="Hand" MouseDown="OnAgentPillClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background">
                                                        <Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" /></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DraftAgent}" Value="claude">
                                                            <Setter Property="Background">
                                                                <Setter.Value><SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.25" /></Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="claude" FontSize="9" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DraftAgent}" Value="claude">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <Border Tag="codex" CornerRadius="10" Padding="7,3" Margin="0,0,3,0"
                                                Cursor="Hand" MouseDown="OnAgentPillClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" /></Setter.Value></Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DraftAgent}" Value="codex">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.25" /></Setter.Value></Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="codex" FontSize="9" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DraftAgent}" Value="codex">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <Border Tag="aider" CornerRadius="10" Padding="7,3" Margin="0,0,3,0"
                                                Cursor="Hand" MouseDown="OnAgentPillClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" /></Setter.Value></Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DraftAgent}" Value="aider">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource AccentGreen}" Opacity="0.2" /></Setter.Value></Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="aider" FontSize="9" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DraftAgent}" Value="aider">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <Border Tag="gemini" CornerRadius="10" Padding="7,3" Margin="0,0,3,0"
                                                Cursor="Hand" MouseDown="OnAgentPillClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" /></Setter.Value></Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DraftAgent}" Value="gemini">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource AccentPeach}" Opacity="0.2" /></Setter.Value></Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="gemini" FontSize="9" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DraftAgent}" Value="gemini">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentPeachBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <Border Tag="shell" CornerRadius="10" Padding="7,3"
                                                Cursor="Hand" MouseDown="OnAgentPillClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" /></Setter.Value></Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DraftAgent}" Value="shell">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="{DynamicResource AccentYellow}" Opacity="0.2" /></Setter.Value></Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="shell" FontSize="9" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DraftAgent}" Value="shell">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentYellowBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- Model pills (hidden for shell) -->
                                    <StackPanel Margin="0,0,0,6">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DraftAgent}" Value="shell">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Modelo" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,3" />
                                        <ItemsControl ItemsSource="{Binding DraftAgent, Converter={StaticResource AgentToModels}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="10" Padding="7,3" Margin="0,0,3,3"
                                                            Cursor="Hand"
                                                            Tag="{Binding}"
                                                            MouseDown="OnModelPillClick">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background">
                                                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" /></Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding Converter="{StaticResource StringEquals}">
                                                                                <Binding />
                                                                                <Binding Path="DataContext.DraftModel"
                                                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter Property="Background">
                                                                            <Setter.Value><SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.28" /></Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="9">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource StringEquals}">
                                                                                    <Binding />
                                                                                    <Binding Path="DataContext.DraftModel"
                                                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding}" />
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Color row -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Cor:" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <Button Width="16" Height="16"
                                                Cursor="Hand"
                                                ToolTip="Escolher cor"
                                                Tag="{Binding}"
                                                Click="OnCardColorPickerClick"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Width="16" Height="16" CornerRadius="8"
                                                            BorderThickness="1.5"
                                                            BorderBrush="{DynamicResource SubtextBrush}">
                                                        <Border.Background>
                                                            <Binding Path="DraftColor" Converter="{StaticResource HexToBrush}" />
                                                        </Border.Background>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>

                                    <!-- Action row: Save / Cancel / Delete -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
                                        <!-- Delete -->
                                        <Button Content="Excluir"
                                                Padding="7,4"
                                                Margin="0,0,4,0"
                                                Tag="{Binding}"
                                                Click="OnDeleteCardClicked"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="DelBg" CornerRadius="4" Padding="7,4">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{DynamicResource AccentRed}" Opacity="0.12" />
                                                        </Border.Background>
                                                        <TextBlock Text="Excluir" FontSize="9"
                                                                   Foreground="{DynamicResource AccentRedBrush}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="DelBg" Property="Background">
                                                                <Setter.Value><SolidColorBrush Color="{DynamicResource AccentRed}" Opacity="0.22" /></Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Cancel -->
                                        <Button Content="Cancelar"
                                                Padding="7,4"
                                                Margin="0,0,4,0"
                                                Tag="{Binding}"
                                                Click="OnCancelCardEdit"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="CancelBg" CornerRadius="4" Padding="7,4">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" />
                                                        </Border.Background>
                                                        <TextBlock Text="Cancelar" FontSize="9"
                                                                   Foreground="{DynamicResource SubtextBrush}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CancelBg" Property="Background">
                                                                <Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.8" /></Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Save -->
                                        <Button Content="Salvar"
                                                Padding="7,4"
                                                Tag="{Binding}"
                                                Click="OnSaveCardEdit"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                    <Setter Property="FontSize" Value="9" />
                                                    <Setter Property="Padding" Value="7,4" />
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ══ NOTES TAB ═════════════════════════════════════════ -->
                                <StackPanel MaxHeight="200">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="notes">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto"
                                                  Margin="0,0,0,6"
                                                  x:Name="NotesScrollViewer">
                                        <ItemsControl ItemsSource="{Binding Comments}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,4" Padding="6,4" CornerRadius="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background">
                                                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.3" /></Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAgentOutput}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentGreenBrush}" />
                                                                        <Setter Property="BorderThickness" Value="2,0,0,0" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Text}" FontSize="10"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource SubtextBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAgentOutput}" Value="True">
                                                                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Add comment input -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="NewCommentBox"
                                                 Tag="{Binding}"
                                                 Height="24" FontSize="10"
                                                 Padding="5,3"
                                                 VerticalContentAlignment="Center"
                                                 KeyDown="OnNewCommentKeyDown">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}" />
                                            </TextBox.Style>
                                        </TextBox>
                                        <Button Grid.Column="2"
                                                Content="+ Nota"
                                                Height="24" Padding="6,0"
                                                Tag="{Binding}"
                                                Click="OnAddCommentClick"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="AddNoteBg" CornerRadius="4" Padding="6,0" Height="24">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.15" />
                                                        </Border.Background>
                                                        <TextBlock Text="+ Nota" FontSize="9" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource AccentBlueBrush}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="AddNoteBg" Property="Background">
                                                                <Setter.Value><SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.25" /></Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- ══ PROGRESS TAB ══════════════════════════════════════ -->
                                <StackPanel MaxHeight="200">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveTab}" Value="progress">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Not launched message -->
                                    <TextBlock FontSize="10" Foreground="{DynamicResource SubtextBrush}"
                                               Text="Execute este card para ver atualizações do agente aqui."
                                               TextWrapping="Wrap" Margin="0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Launched}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding Launched, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl x:Name="ProgressList">
                                            <ItemsControl.ItemsSource>
                                                <Binding Path="Comments" />
                                            </ItemsControl.ItemsSource>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="6">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Setter Property="Background">
                                                                    <Setter.Value><SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.6" /></Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAgentOutput}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontSize="10"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource TextBrush}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- JustMoved green flash overlay (same position, no hit test) -->
                <Border x:Name="MovedFlash"
                        CornerRadius="6"
                        Margin="0,2"
                        BorderThickness="2"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource AccentGreen}" Opacity="0.85" />
                    </Border.BorderBrush>
                </Border>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding JustMoved}" Value="True">
                    <Setter TargetName="MovedFlash" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════════════════════
         Main layout: Header + Columns
    ══════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ─── Board header ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="12,0" BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
            </Border.BorderBrush>
            <DockPanel VerticalAlignment="Center">

                <!-- Left: icon + label -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Border Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.15" />
                        </Border.Background>
                        <TextBlock Text="🗂" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Kanban" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Card count badge -->
                <Border DockPanel.Dock="Left" CornerRadius="8" Padding="6,2"
                        Margin="8,0,0,0" VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.6" />
                    </Border.Background>
                    <TextBlock FontSize="9" FontFamily="{StaticResource MonoFont}"
                               Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding KanbanCardCount, Mode=OneWay}" /><Run Text=" cards" />
                    </TextBlock>
                </Border>

                <!-- Right: Refresh button -->
                <Button DockPanel.Dock="Right"
                        Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Atualizar board"
                        VerticalAlignment="Center"
                        Click="OnRefreshClicked">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="4" Background="Transparent" Width="24" Height="24">
                                <TextBlock Text="↻" FontSize="14"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Right: Add column button -->
                <Button DockPanel.Dock="Right"
                        Height="24"
                        Padding="8,0"
                        Margin="0,0,6,0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Adicionar nova coluna"
                        VerticalAlignment="Center"
                        Click="OnAddColumnClicked">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="AddColBg" CornerRadius="4" Padding="7,0"
                                    Height="24">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.12" />
                                </Border.Background>
                                <TextBlock Text="⊕ Lista" FontSize="10"
                                           Foreground="{DynamicResource AccentBlueBrush}"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AddColBg" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.22" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </DockPanel>
        </Border>

        <!-- ─── Columns area ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="10,8,4,4">
            <ItemsControl ItemsSource="{Binding KanbanColumnViewModels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:KanbanColumnViewModel}">
                        <!-- ── Single column ──────────────────────────── -->
                        <Border Width="168" Margin="0,0,6,0"
                                Style="{StaticResource ColumnBorderStyle}">
                            <!-- Drag-over overlay -->
                            <Grid>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Column header -->
                                    <Border Grid.Row="0"
                                            Style="{StaticResource ColumnHeaderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Title display (double-click to rename) -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{DynamicResource SubtextBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Tag="{Binding}"
                                                       MouseDown="OnColumnTitleMouseDown"
                                                       Cursor="Hand"
                                                       ToolTip="Clique duplo para renomear">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Title editor (visible when IsEditingTitle) -->
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="9" FontWeight="Bold"
                                                     Background="Transparent"
                                                     BorderThickness="0,0,0,1"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     VerticalAlignment="Center"
                                                     Tag="{Binding}"
                                                     KeyDown="OnColumnTitleKeyDown"
                                                     IsVisibleChanged="OnColumnEditBoxVisibleChanged">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingTitle}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <!-- Card count badge -->
                                            <Border Grid.Column="1"
                                                    CornerRadius="7" Padding="5,1"
                                                    Margin="4,0,2,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.5" />
                                                </Border.Background>
                                                <TextBlock Text="{Binding CardCount}"
                                                           FontSize="9"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{DynamicResource SubtextBrush}" />
                                            </Border>

                                            <!-- Add card to this column -->
                                            <Button Grid.Column="2"
                                                    Width="20" Height="20"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Adicionar card nesta coluna"
                                                    Tag="{Binding}"
                                                    Click="OnAddCardToColumnClick">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="AddBg" CornerRadius="4" Background="Transparent"
                                                                Width="20" Height="20">
                                                            <TextBlock Text="+" FontSize="12"
                                                                       Foreground="{DynamicResource SubtextBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="AddBg" Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{DynamicResource AccentGreen}" Opacity="0.15" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Delete column -->
                                            <Button Grid.Column="3"
                                                    Width="20" Height="20"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Excluir coluna"
                                                    Tag="{Binding}"
                                                    Click="OnDeleteColumnClick">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="DelColBg" CornerRadius="4" Background="Transparent"
                                                                Width="20" Height="20">
                                                            <TextBlock Text="✕" FontSize="9"
                                                                       Foreground="{DynamicResource SubtextBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DelColBg" Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="{DynamicResource AccentRed}" Opacity="0.12" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Card list with drag-drop support -->
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding Cards}"
                                             ItemTemplate="{StaticResource KanbanCardTemplate}"
                                             ItemContainerStyle="{StaticResource KanbanCardItemStyle}"
                                             Style="{StaticResource KanbanListBoxStyle}"
                                             AllowDrop="True"
                                             Drop="OnColumnDrop"
                                             DragEnter="OnColumnDragEnter"
                                             DragOver="OnColumnDragOver"
                                             DragLeave="OnColumnDragLeave"
                                             SelectionMode="Single"
                                             HorizontalContentAlignment="Stretch"
                                             Tag="{Binding}" />

                                    <!-- Inline add-card input (shown when IsAddingCard) -->
                                    <Border Grid.Row="2"
                                            Padding="5,4,5,5"
                                            BorderThickness="0,1,0,0"
                                            Visibility="{Binding IsAddingCard, Converter={StaticResource BoolToVis}}">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.4" />
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="22" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding NewCardTitle, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="{Binding}"
                                                     Height="24" FontSize="11"
                                                     Padding="6,3"
                                                     VerticalContentAlignment="Center"
                                                     KeyDown="OnColumnAddCardKeyDown"
                                                     IsVisibleChanged="OnAddCardBoxVisibleChanged">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}" />
                                                </TextBox.Style>
                                            </TextBox>
                                            <Button Grid.Column="2"
                                                    Tag="{Binding}"
                                                    Content="×" FontSize="14"
                                                    Width="22" Height="24"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand"
                                                    Foreground="{DynamicResource SubtextBrush}"
                                                    Click="OnCancelAddCard" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Drag-over visual indicator (overlaid on top, no hit test) -->
                                <Border CornerRadius="6" IsHitTestVisible="False"
                                        Visibility="{Binding IsDragOver, Converter={StaticResource BoolToVis}}">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.6" />
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.06" />
                                    </Border.Background>
                                    <Border BorderBrush="{DynamicResource AccentBlueBrush}"
                                            BorderThickness="1.5" CornerRadius="6"
                                            Background="Transparent" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
