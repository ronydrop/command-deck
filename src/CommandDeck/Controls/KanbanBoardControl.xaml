<UserControl x:Class="CommandDeck.Controls.KanbanBoardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             mc:Ignorable="d"
             d:DesignWidth="600" d:DesignHeight="440"
             Background="Transparent">

    <UserControl.Resources>
        <ctrl:ColumnIdToVisibilityConverter x:Key="ColVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <ctrl:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />

        <!-- Shared card DataTemplate used in every column -->
        <DataTemplate x:Key="KanbanCardTemplate">
            <Border x:Name="CardBg"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,2"
                    ClipToBounds="True">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
                </Border.Background>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.6" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left accent strip (card Color) -->
                    <Border Grid.Column="0"
                            CornerRadius="2"
                            Margin="-10,-8,-6,-8">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.7" />
                        </Border.Background>
                    </Border>

                    <!-- Card body -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <!-- Title -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" />

                        <!-- Agent badge + launched dot -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Border CornerRadius="6" Padding="5,1" Margin="0,0,4,0">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource AccentPurple}" Opacity="0.18" />
                                </Border.Background>
                                <TextBlock Text="{Binding Agent}"
                                           FontSize="9" FontWeight="SemiBold"
                                           FontFamily="{StaticResource MonoFont}"
                                           Foreground="{DynamicResource AccentBrush}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Launched indicator dot -->
                    <Ellipse Grid.Column="3"
                             Width="7" Height="7"
                             VerticalAlignment="Top"
                             Margin="0,2,0,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Launched}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.3"
                                                                     Duration="0:0:1" AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Execute button — visible only when card has not yet been launched -->
                    <Button Grid.Column="4"
                            Tag="{Binding}"
                            Width="22" Height="22"
                            Margin="3,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Executar tarefa com agente AI"
                            Click="OnExecuteCardClicked"
                            Visibility="{Binding Launched,
                                Converter={StaticResource InvBoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ExecBg" CornerRadius="4" Background="Transparent"
                                        Width="22" Height="22">
                                    <TextBlock Text="▶" FontSize="9"
                                               Foreground="{DynamicResource AccentGreenBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ExecBg" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{DynamicResource AccentGreen}" Opacity="0.18" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Column border style (shared) -->
        <Style x:Key="ColumnBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.5" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColumnHeaderBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.6" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <!-- ─── Header ───────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Padding="12,0"
                BorderThickness="0,0,0,1">
            <Border.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
            </Border.BorderBrush>
            <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Border Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource AccentBlue}" Opacity="0.15" />
                        </Border.Background>
                        <TextBlock Text="🗂" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Kanban"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Border DockPanel.Dock="Left" CornerRadius="8" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.6" />
                    </Border.Background>
                    <TextBlock FontSize="9" FontFamily="{StaticResource MonoFont}"
                               Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding KanbanCards.Count, Mode=OneWay}" /><Run Text=" cards" />
                    </TextBlock>
                </Border>

                <Button DockPanel.Dock="Right"
                        Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Click="OnRefreshClicked"
                        ToolTip="Atualizar board"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="4" Background="Transparent" Width="24" Height="24">
                                <TextBlock Text="↻" FontSize="14"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.5" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- ─── Columns area ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="10,8,10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Backlog ──────────────────────────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource ColumnBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource ColumnHeaderBorderStyle}">
                        <TextBlock Text="BACKLOG" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="5,4">
                        <ItemsControl ItemsSource="{Binding KanbanCards}"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Visibility"
                                            Value="{Binding ColumnId,
                                                Converter={StaticResource ColVis},
                                                ConverterParameter=backlog}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── Executando ───────────────────────────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource ColumnBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource ColumnHeaderBorderStyle}">
                        <TextBlock Text="EXECUTANDO" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="5,4">
                        <ItemsControl ItemsSource="{Binding KanbanCards}"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Visibility"
                                            Value="{Binding ColumnId,
                                                Converter={StaticResource ColVis},
                                                ConverterParameter=running}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── Revisão ──────────────────────────────────────────────── -->
            <Border Grid.Column="4" Style="{StaticResource ColumnBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource ColumnHeaderBorderStyle}">
                        <TextBlock Text="REVISÃO" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentYellowBrush}" VerticalAlignment="Center" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="5,4">
                        <ItemsControl ItemsSource="{Binding KanbanCards}"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Visibility"
                                            Value="{Binding ColumnId,
                                                Converter={StaticResource ColVis},
                                                ConverterParameter=review}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── Concluído ─────────────────────────────────────────────── -->
            <Border Grid.Column="6" Style="{StaticResource ColumnBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource ColumnHeaderBorderStyle}">
                        <TextBlock Text="CONCLUÍDO" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentGreenBrush}" VerticalAlignment="Center" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="5,4">
                        <ItemsControl ItemsSource="{Binding KanbanCards}"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Visibility"
                                            Value="{Binding ColumnId,
                                                Converter={StaticResource ColVis},
                                                ConverterParameter=done}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── Add card input ───────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="10,5" BorderThickness="0,1,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="{DynamicResource Surface1}" Opacity="0.4" />
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="26" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="NewCardInput"
                         Style="{StaticResource DarkTextBox}"
                         Tag="Nova tarefa..."
                         Padding="8,3"
                         Height="26"
                         FontSize="12"
                         VerticalContentAlignment="Center"
                         KeyDown="OnAddCardKeyDown" />

                <Button Grid.Column="2"
                        Content="+"
                        Width="26" Height="26"
                        FontSize="15"
                        Style="{StaticResource AccentButton}"
                        Click="OnAddCardButtonClick"
                        ToolTip="Adicionar ao Backlog (Enter)" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
