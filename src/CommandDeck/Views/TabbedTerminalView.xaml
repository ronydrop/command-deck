<UserControl x:Class="CommandDeck.Views.TabbedTerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:controls="clr-namespace:CommandDeck.Controls"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="700"
             Background="{DynamicResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:TerminalStatusToColorConverter x:Key="StatusToColor" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Tab bar + toolbar -->
            <RowDefinition Height="38" />
            <!-- Terminal content area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             TAB BAR
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource GlassToolbarBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- Right side: Split + New buttons -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0">

                    <!-- Close Split button (visible only when split) -->
                    <Button Style="{DynamicResource IconButton}"
                            Width="28" Height="28"
                            Margin="0,0,2,0"
                            Command="{Binding CloseSplitCommand}"
                            ToolTip="Fechar Divisão"
                            Visibility="{Binding IsSplit, Converter={StaticResource BoolToVis}}">
                        <Path Width="12" Height="12" Stretch="Uniform"
                              Data="M4,12 L12,4 M4,4 L12,12"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Button>

                    <!-- Split Vertical button -->
                    <Button Style="{DynamicResource IconButton}"
                            Width="28" Height="28"
                            Margin="0,0,2,0"
                            Command="{Binding SplitVerticalCommand}"
                            ToolTip="Dividir Verticalmente">
                        <Grid Width="14" Height="12">
                            <Rectangle RadiusX="1.5" RadiusY="1.5"
                                       Stroke="{DynamicResource SubtextBrush}"
                                       StrokeThickness="1.2"
                                       Fill="Transparent" />
                            <Line X1="7" Y1="1" X2="7" Y2="11"
                                  Stroke="{DynamicResource SubtextBrush}"
                                  StrokeThickness="1.2" />
                        </Grid>
                    </Button>

                    <!-- Split Horizontal button -->
                    <Button Style="{DynamicResource IconButton}"
                            Width="28" Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding SplitHorizontalCommand}"
                            ToolTip="Dividir Horizontalmente">
                        <Grid Width="12" Height="14">
                            <Rectangle RadiusX="1.5" RadiusY="1.5"
                                       Stroke="{DynamicResource SubtextBrush}"
                                       StrokeThickness="1.2"
                                       Fill="Transparent" />
                            <Line X1="1" Y1="7" X2="11" Y2="7"
                                  Stroke="{DynamicResource SubtextBrush}"
                                  StrokeThickness="1.2" />
                        </Grid>
                    </Button>

                    <!-- Separator -->
                    <Separator Width="1" Height="16"
                               Background="{DynamicResource GlassBorderBrush}"
                               Margin="0,0,4,0" />

                    <!-- New terminal button -->
                    <Button Style="{DynamicResource IconButton}"
                            Width="28" Height="28"
                            Command="{Binding NewTerminalInTabsCommand}"
                            ToolTip="Novo Terminal (Ctrl+Shift+T)">
                        <Path Data="{DynamicResource PlusIcon}"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="11" Height="11"
                              Stretch="Uniform" />
                    </Button>
                </StackPanel>

                <!-- Tab list -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Stretch">
                    <ItemsControl ItemsSource="{Binding TerminalManager.Terminals}"
                                  VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TerminalViewModel}">
                                <Border x:Name="TabBorder"
                                        MinWidth="120" MaxWidth="200"
                                        Padding="12,0,6,0"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="OnTabMouseDown">
                                    <DockPanel VerticalAlignment="Center">
                                        <!-- Status dot -->
                                        <Ellipse DockPanel.Dock="Left"
                                                 Width="6" Height="6"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Session.Status, Converter={StaticResource StatusToColor}}" />

                                        <!-- Close button -->
                                        <Button DockPanel.Dock="Right"
                                                Style="{DynamicResource IconButton}"
                                                Width="18" Height="18"
                                                Margin="4,0,0,0"
                                                Command="{Binding DataContext.CloseTerminalInTabsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Fechar Terminal">
                                            <Path Data="M3,3 L9,9 M3,9 L9,3"
                                                  Width="7" Height="7"
                                                  Stroke="{DynamicResource Overlay0Brush}"
                                                  StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Stretch="Uniform" />
                                        </Button>

                                        <!-- Title -->
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource SubtextBrush}" />
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background"
                                                Value="{DynamicResource BaseBgBrush}" />
                                        <Setter TargetName="TabBorder" Property="BorderBrush"
                                                Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             TERMINAL CONTENT AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- ── Single pane (no split) ── -->
            <Grid Visibility="{Binding IsSinglePane, Converter={StaticResource BoolToVis}}">
                <controls:TerminalControl
                    DataContext="{Binding TerminalManager.ActiveTerminal}"
                    Visibility="{Binding TerminalManager.ActiveTerminal,
                                 Converter={StaticResource NullToVis}}" />

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding TerminalManager.ActiveTerminal,
                                         Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                    <Path Data="{DynamicResource TerminalIcon}"
                          Stroke="{DynamicResource Surface2Brush}"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Width="48" Height="48"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,16" />
                    <TextBlock Text="Nenhum terminal aberto"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Surface2Brush}" />
                    <TextBlock Text="Pressione Ctrl+Shift+T para abrir um novo terminal"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SubtextBrush}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Grid>

            <!-- ── Horizontal split (side-by-side) ── -->
            <Grid Visibility="{Binding IsSplitHorzVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" MinWidth="200" />
                </Grid.ColumnDefinitions>

                <!-- Left: active terminal -->
                <controls:TerminalControl Grid.Column="0"
                    DataContext="{Binding TerminalManager.ActiveTerminal}" />

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource GlassBorderBrush}"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns" />

                <!-- Right: split terminal -->
                <controls:TerminalControl Grid.Column="2"
                    DataContext="{Binding SplitTerminal}" />
            </Grid>

            <!-- ── Vertical split (top/bottom) ── -->
            <Grid Visibility="{Binding IsSplitVertVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="100" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- Top: active terminal -->
                <controls:TerminalControl Grid.Row="0"
                    DataContext="{Binding TerminalManager.ActiveTerminal}" />

                <!-- Splitter -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource GlassBorderBrush}"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Rows" />

                <!-- Bottom: split terminal -->
                <controls:TerminalControl Grid.Row="2"
                    DataContext="{Binding SplitTerminal}" />
            </Grid>

        </Grid>
    </Grid>
</UserControl>
