<UserControl x:Class="CommandDeck.Views.AssistantPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:models="clr-namespace:CommandDeck.Models"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AssistantPanelViewModel}"
             Background="{DynamicResource BaseBgBrush}"
             Width="320">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVisWpf" />

        <!-- Chat message template -->
        <DataTemplate x:Key="ChatMessageTemplate" DataType="{x:Type models:ChatMessage}">
            <Grid Margin="12,4">
                <!-- User message -->
                <Border x:Name="UserBubble"
                        HorizontalAlignment="Stretch"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="24,0,0,0"
                        Background="#1AFFFFFF"
                        Visibility="Collapsed">
                    <TextBlock Text="{Binding Content}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12.5"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Assistant message -->
                <Border x:Name="AssistantBubble"
                        HorizontalAlignment="Stretch"
                        CornerRadius="0"
                        Padding="0,6"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{Binding Content}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"
                                   LineHeight="20" />
                        <!-- Streaming dots -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,6,0,0"
                                    Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentBrush}" Margin="0,0,4,0" Opacity="0.9" />
                            <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentBrush}" Margin="0,0,4,0" Opacity="0.5" />
                            <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentBrush}" Opacity="0.2" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                    <Setter TargetName="AssistantBubble" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUser}" Value="False">
                    <Setter TargetName="UserBubble" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AssistantBubble" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Tab bar -->
            <RowDefinition Height="Auto" />
            <!-- Input area (top, like Cursor) -->
            <RowDefinition Height="Auto" />
            <!-- Chat messages -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             TAB BAR (Cursor-style)
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource MantelBgBrush}"
                BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,0,1"
                Padding="4,0">
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Active tab -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource Surface0Brush}"
                            CornerRadius="6,6,0,0"
                            Padding="10,5,6,5"
                            Margin="4,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource TerminalIcon}"
                                  Stroke="{DynamicResource SubtextBrush}"
                                  StrokeThickness="1.2"
                                  Width="12" Height="12"
                                  Stretch="Uniform"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="Chat"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <!-- Close tab -->
                            <Button Style="{StaticResource IconButton}"
                                    Width="18" Height="18"
                                    Margin="6,0,0,0"
                                    Command="{Binding ClearHistoryCommand}"
                                    ToolTip="Limpar chat"
                                    Opacity="0.5">
                                <Path Data="{StaticResource CloseIcon}"
                                      Stroke="{DynamicResource SubtextBrush}"
                                      StrokeThickness="1.2"
                                      Width="8" Height="8"
                                      Stretch="Uniform" />
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Tab bar actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <!-- New chat -->
                    <Button Style="{StaticResource IconButton}"
                            Width="26" Height="26"
                            Command="{Binding ClearHistoryCommand}"
                            ToolTip="Novo chat"
                            Margin="0,0,2,0">
                        <Path Data="{StaticResource PlusIcon}"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              Width="12" Height="12"
                              Stretch="Uniform" />
                    </Button>
                    <!-- Close panel -->
                    <Button Style="{StaticResource IconButton}"
                            Width="26" Height="26"
                            Command="{Binding DataContext.ToggleAIPanelCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Fechar painel (Ctrl+I)">
                        <Path Data="{StaticResource CloseIcon}"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              Width="10" Height="10"
                              Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             INPUT AREA (Cursor-style: top position, multiline box)
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource BaseBgBrush}"
                Padding="10,10,10,6">
            <StackPanel>
                <!-- Input box with rounded border -->
                <Border Background="{DynamicResource Surface0Brush}"
                        BorderBrush="{DynamicResource Surface1Brush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="2">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Text input -->
                        <TextBox Grid.Row="0"
                                 x:Name="ChatInput"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 FontSize="13"
                                 Padding="10,10,10,6"
                                 MinHeight="60"
                                 MaxHeight="140"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Tag="Pergunte algo, / para comandos...">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SendMessageCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Bottom toolbar inside the input box -->
                        <Grid Grid.Row="1" Margin="6,0,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Provider pill (status dot + name) -->
                            <Border Grid.Column="0"
                                    CornerRadius="5"
                                    Background="{DynamicResource Surface1Brush}"
                                    Padding="8,3"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource AccentRedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsProviderAvailable}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding SelectedProviderLabel}"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Model selector ComboBox -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableModels}"
                                      SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                                      Visibility="{Binding IsProviderAvailable, Converter={StaticResource BoolToVis}}"
                                      VerticalAlignment="Center"
                                      FontSize="10.5"
                                      MinWidth="80"
                                      MaxWidth="180"
                                      Padding="6,2"
                                      Margin="0,0,4,0"
                                      Focusable="False"
                                      IsTabStop="False">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Foreground" Value="{DynamicResource Overlay0Brush}" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBox">
                                                    <Grid>
                                                        <ToggleButton x:Name="ToggleButton"
                                                                      Background="Transparent"
                                                                      BorderThickness="0"
                                                                      Focusable="False"
                                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      ClickMode="Press"
                                                                      Cursor="Hand">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent" Padding="0">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"
                                                                           Foreground="{DynamicResource Overlay0Brush}"
                                                                           FontSize="10.5"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="150" />
                                                                <Path Data="M0,0 L4,4 L8,0"
                                                                      Stroke="{DynamicResource Overlay0Brush}"
                                                                      StrokeThickness="1.2"
                                                                      Fill="Transparent"
                                                                      Width="8" Height="4"
                                                                      Stretch="Uniform"
                                                                      Margin="4,1,0,0"
                                                                      VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </ToggleButton>
                                                        <Popup x:Name="Popup"
                                                               Placement="Bottom"
                                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                                               AllowsTransparency="True"
                                                               Focusable="False"
                                                               PopupAnimation="Slide">
                                                            <Border Background="{DynamicResource Surface0Brush}"
                                                                    BorderBrush="{DynamicResource Surface1Brush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    MinWidth="{TemplateBinding ActualWidth}"
                                                                    MaxHeight="200">
                                                                <Border.Effect>
                                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.4" Color="#000000" />
                                                                </Border.Effect>
                                                                <ScrollViewer SnapsToDevicePixels="True">
                                                                    <StackPanel IsItemsHost="True"
                                                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                                                </ScrollViewer>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="ItemContainerStyle">
                                            <Setter.Value>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
                                                    <Setter Property="FontSize" Value="11" />
                                                    <Setter Property="Padding" Value="10,5" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBoxItem">
                                                                <Border x:Name="Bd"
                                                                        Background="{TemplateBinding Background}"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <TextBlock Text="{TemplateBinding Content}"
                                                                               FontSize="{TemplateBinding FontSize}"
                                                                               Foreground="{TemplateBinding Foreground}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface1Brush}" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>

                            <!-- Quick actions: Explain Output -->
                            <Button Grid.Column="3"
                                    Style="{StaticResource IconButton}"
                                    Width="26" Height="26"
                                    Command="{Binding ExplainOutputCommand}"
                                    ToolTip="Explicar Output do Terminal"
                                    Margin="0,0,2,0">
                                <Path Data="{StaticResource TerminalIcon}"
                                      Stroke="{DynamicResource Overlay0Brush}"
                                      StrokeThickness="1.3"
                                      Width="13" Height="13"
                                      Stretch="Uniform" />
                            </Button>

                            <!-- Send button -->
                            <Grid Grid.Column="4">
                                <!-- Send -->
                                <Button Style="{StaticResource IconButton}"
                                        Width="28" Height="28"
                                        Command="{Binding SendMessageCommand}"
                                        ToolTip="Enviar (Enter)"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis},
                                                     ConverterParameter=Invert}">
                                    <Border Width="24" Height="24"
                                            CornerRadius="6"
                                            Background="{DynamicResource AccentBrush}">
                                        <Path Data="{StaticResource ChevronRightIcon}"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              Width="10" Height="10"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                </Button>
                                <!-- Cancel -->
                                <Button Style="{StaticResource IconButton}"
                                        Width="28" Height="28"
                                        Command="{Binding CancelRequestCommand}"
                                        ToolTip="Cancelar"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                    <Border Width="24" Height="24"
                                            CornerRadius="6"
                                            Background="{DynamicResource AccentRedBrush}">
                                        <Path Data="{StaticResource StopIcon}"
                                              Stroke="White"
                                              StrokeThickness="1.5"
                                              Width="10" Height="10"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Status text below input -->
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource Overlay0Brush}"
                           FontSize="10.5"
                           Margin="4,6,0,0"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             CHAT MESSAGES (below input, scrollable)
             ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource BaseBgBrush}"
                      Padding="0,4">
            <Grid>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="16,48"
                            Visibility="{Binding Messages.Count, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                    <Border Width="40" Height="40"
                            CornerRadius="10"
                            Background="{DynamicResource Surface0Brush}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <TextBlock Text="AI"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Como posso ajudar?"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="15"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Foreground="{DynamicResource Overlay0Brush}"
                               FontSize="11.5"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               LineHeight="18">
                        <Run Text="Pergunte sobre o terminal," />
                        <LineBreak />
                        <Run Text="peça sugestoes de comandos" />
                        <LineBreak />
                        <Run Text="ou explique erros." />
                    </TextBlock>

                    <!-- Quick action chips (empty state) -->
                    <WrapPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding ExplainOutputCommand}"
                                Margin="2" Padding="10,5"
                                FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource TerminalIcon}"
                                      Stroke="{DynamicResource SubtextBrush}"
                                      StrokeThickness="1.2"
                                      Width="11" Height="11"
                                      Stretch="Uniform"
                                      Margin="0,0,5,0" />
                                <TextBlock Text="Explicar Output" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding SuggestCommandCommand}"
                                Margin="2" Padding="10,5"
                                FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource SearchIcon}"
                                      Stroke="{DynamicResource SubtextBrush}"
                                      StrokeThickness="1.2"
                                      Width="11" Height="11"
                                      Stretch="Uniform"
                                      Margin="0,0,5,0" />
                                <TextBlock Text="Sugerir Comando" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>

                <!-- Messages list -->
                <ItemsControl ItemsSource="{Binding Messages}"
                              ItemTemplate="{StaticResource ChatMessageTemplate}"
                              Visibility="{Binding Messages.Count, Converter={StaticResource NullToVis}}" />
            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
