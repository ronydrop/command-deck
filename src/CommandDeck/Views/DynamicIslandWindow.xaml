<Window x:Class="CommandDeck.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CommandDeck.Converters"
        xmlns:models="clr-namespace:CommandDeck.Models"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="200"
        SourceInitialized="OnSourceInitialized"
        Loaded="OnLoaded">

    <Window.Resources>
        <conv:SessionStateToColorConverter x:Key="SessionStateToColor" />

        <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut" />

        <Style x:Key="SessionRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Hidden" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentRedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border: pill shape, always visible -->
    <!-- Margin creates transparent space so the drop shadow isn't clipped by the window edge -->
    <Border x:Name="PillBorder"
            CornerRadius="20"
            Margin="12,8,12,20"
            Padding="12,8"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            MouseEnter="OnMouseEnter"
            MouseLeave="OnMouseLeave"
            MouseLeftButtonUp="OnPillClick"
            Cursor="Hand">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.92" />
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270"
                              Color="#000000" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <!-- Pill mode (collapsed) -->
            <StackPanel x:Name="PillContent"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Height="24">
                <Ellipse x:Name="StatusDot"
                         Width="8" Height="8"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush x:Name="StatusDotBrush" Color="#A6E3A1" />
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock x:Name="SessionCountText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextBrush}" />
            </StackPanel>

            <!-- Expanded panel -->
            <Border x:Name="ExpandedContent"
                    Visibility="Collapsed"
                    MinWidth="280"
                    MaxHeight="0"
                    Opacity="0">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Sessões de Terminal"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="&#x2212;"
                                Width="22" Height="22"
                                FontSize="14"
                                Background="Transparent"
                                Foreground="{DynamicResource SubtextBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Minimizar"
                                Click="OnMinimizeClick" />
                    </Grid>

                    <!-- Session list -->
                    <ItemsControl x:Name="SessionList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DynamicIslandSessionItem}">
                                <Border x:Name="SessionRow"
                                        Style="{StaticResource SessionRowStyle}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="OnSessionRowClick"
                                        Tag="{Binding SessionId}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Status dot -->
                                        <Ellipse Grid.Column="0"
                                                 Width="7" Height="7"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding SessionState, Converter={StaticResource SessionStateToColor}}" />

                                        <!-- Title + info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ShellType}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding SessionState}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="0,0,6,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DurationDisplay}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0" />

                                        <!-- Close button (shown on hover) -->
                                        <Button Grid.Column="3"
                                                x:Name="CloseBtn"
                                                Style="{StaticResource CloseButtonStyle}"
                                                Content="✕"
                                                Tag="{Binding SessionId}"
                                                Click="OnSessionCloseClick" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Correct pattern: Trigger with SourceName references the named element -->
                                    <Trigger SourceName="SessionRow" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock x:Name="EmptyLabel"
                               Text="Nenhuma sessão ativa"
                               FontSize="11"
                               Foreground="{DynamicResource SubtextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8"
                               Visibility="Collapsed" />

                    <!-- Footer -->
                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource Surface1Brush}"
                            Margin="0,8,0,0"
                            Padding="0,6,0,0">
                        <TextBlock Text="Abrir CommandDeck"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="OnOpenCommandDeckClick" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
