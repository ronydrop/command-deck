<Window x:Class="CommandDeck.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CommandDeck.Converters"
        xmlns:models="clr-namespace:CommandDeck.Models"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        MinWidth="200"
        MaxWidth="420"
        Width="200"
        SourceInitialized="OnSourceInitialized"
        Loaded="OnLoaded">

    <Window.Resources>
        <conv:SessionStateToColorConverter x:Key="SessionStateToColor" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:DynamicIslandToneToBrushConverter x:Key="IslandToneToBrush" />
        <Storyboard x:Key="HeartbeatPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.35" To="1" Duration="0:0:0.45" />
        </Storyboard>

        <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut" />

        <Style x:Key="SessionRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Hidden" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentRedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border: pill shape, always visible -->
    <!-- Margin creates transparent space so the drop shadow isn't clipped by the window edge -->
    <Border x:Name="PillBorder"
            CornerRadius="20"
            Margin="12,8,12,20"
            Padding="12,8"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            MouseEnter="OnMouseEnter"
            MouseLeave="OnMouseLeave"
            MouseLeftButtonUp="OnPillClick"
            Cursor="Hand">
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.92" />
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270"
                              Color="#000000" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <!-- Pill mode (collapsed): idle summary vs live event -->
            <Grid x:Name="PillContent"
                  VerticalAlignment="Center"
                  MinHeight="28">
                <!-- Session-only summary (no primary event) -->
                <StackPanel x:Name="PillSessionSummary"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding PrimaryEvent, Converter={StaticResource NullToVis}, ConverterParameter=Inverse}">
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush x:Name="StatusDotBrush" Color="#A6E3A1" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="SessionCountText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextBrush}" />
                </StackPanel>

                <!-- Event-centric pill (primary feed item) -->
                <Grid x:Name="PillEventPanel"
                      Visibility="{Binding PrimaryEvent, Converter={StaticResource NullToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Ellipse x:Name="HeartbeatEllipse"
                                 Width="6" Height="6"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsPrimaryAgentBusy, Converter={StaticResource BoolToVis}}">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{DynamicResource AccentBlue}" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Border CornerRadius="6"
                                Padding="6,2"
                                VerticalAlignment="Center"
                                Background="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Background}"
                                BorderBrush="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Border}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding PrimaryEvent.CompactBadge}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Foreground}" />
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PrimaryEvent.Title}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding PrimaryEvent.SessionTitle}"
                                   FontSize="9"
                                   Margin="0,1,0,0"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding PrimaryEvent.HasSessionTitle, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding CurrentPreview}"
                                   FontSize="10"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280" />
                        <TextBlock Text="{Binding CurrentActionDetail}"
                                   FontSize="9"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Opacity="0.85"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280"
                                   Margin="0,1,0,0"
                                   Visibility="{Binding CurrentActionDetail, Converter={StaticResource StringToVis}}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Expanded panel -->
            <Border x:Name="ExpandedContent"
                    Visibility="Collapsed"
                    MinWidth="280"
                    MaxHeight="0"
                    Opacity="0">
                <StackPanel>
                    <!-- Primary event card -->
                    <Border x:Name="PrimaryEventCard"
                            Margin="0,0,0,10"
                            Padding="10,8"
                            CornerRadius="10"
                            Background="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Background}"
                            BorderBrush="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Border}"
                            BorderThickness="1"
                            Visibility="{Binding PrimaryEvent, Converter={StaticResource NullToVis}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        CornerRadius="6"
                                        Padding="6,2"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Top"
                                        Background="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Background}"
                                        BorderBrush="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Border}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding PrimaryEvent.CompactBadge}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding PrimaryEvent.AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Foreground}" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding PrimaryEvent.Title}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding PrimaryEvent.Subtitle}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding PrimaryEvent.SessionTitle}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding PrimaryEvent.HasSessionTitle, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock conv:MarkdownTextBlock.Markdown="{Binding PrimaryEvent.PrimarySnippet}"
                                       FontSize="11.5"
                                       LineHeight="18"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Opacity="0.9" />
                            <TextBlock conv:MarkdownTextBlock.Markdown="{Binding PrimaryEvent.SecondarySnippet}"
                                       FontSize="10"
                                       LineHeight="16"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding PrimaryEvent.HasSecondarySnippet, Converter={StaticResource BoolToVis}}" />
                            <ProgressBar Height="3"
                                         Margin="0,6,0,0"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsPrimaryAgentBusy, Converter={StaticResource BoolToVis}}"
                                         Background="Transparent"
                                         Foreground="{DynamicResource AccentBlueBrush}"
                                         BorderThickness="0" />
                            <ItemsControl Margin="0,8,0,0"
                                          ItemsSource="{Binding PrimaryEvent.ChoiceOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DynamicIslandChoiceOption}">
                                        <Button Content="{Binding Label}"
                                                Command="{Binding Command}"
                                                Margin="0,2,6,2"
                                                Padding="8,4"
                                                FontSize="10"
                                                Cursor="Hand"
                                                Background="{DynamicResource Surface0Brush}"
                                                BorderBrush="{DynamicResource Surface2Brush}"
                                                BorderThickness="1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding PrimaryEvent.PrimaryActionLabel, Converter={StaticResource NullToVis}}">
                                <Button Content="{Binding PrimaryEvent.SecondaryActionLabel}"
                                        Margin="0,0,6,0"
                                        Padding="10,4"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Command="{Binding PrimaryEvent.SecondaryActionCommand}"
                                        Visibility="{Binding PrimaryEvent.SecondaryActionLabel, Converter={StaticResource NullToVis}}" />
                                <Button Content="{Binding PrimaryEvent.PrimaryActionLabel}"
                                        Padding="12,5"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Command="{Binding PrimaryEvent.PrimaryActionCommand}"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="{DynamicResource BaseBgBrush}"
                                        BorderThickness="0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Secondary queue -->
                    <Border Margin="0,0,0,8"
                            Padding="0,0,0,6"
                            BorderBrush="{DynamicResource Surface1Brush}"
                            BorderThickness="0,0,0,1"
                            Visibility="{Binding HasQueuedEvents, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Na fila"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtextBrush}" />
                                <Border Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Padding="6,2"
                                        CornerRadius="6"
                                        Background="{DynamicResource Surface1Brush}">
                                    <TextBlock Text="{Binding BusyEventCount, StringFormat='Busy {0}'}"
                                               FontSize="9"
                                               Foreground="{DynamicResource AccentBlueBrush}" />
                                </Border>
                                <Border Grid.Column="2"
                                        Margin="6,0,0,0"
                                        Padding="6,2"
                                        CornerRadius="6"
                                        Background="{DynamicResource Surface1Brush}">
                                    <TextBlock Text="{Binding DecisionEventCount, StringFormat='Ações {0}'}"
                                               FontSize="9"
                                               Foreground="{DynamicResource AccentYellowBrush}" />
                                </Border>
                                <Border Grid.Column="3"
                                        Margin="6,0,0,0"
                                        Padding="6,2"
                                        CornerRadius="6"
                                        Background="{DynamicResource Surface1Brush}">
                                    <TextBlock Text="{Binding AttentionEventCount, StringFormat='Alertas {0}'}"
                                               FontSize="9"
                                               Foreground="{DynamicResource AccentRedBrush}" />
                                </Border>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding QueuedEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DynamicIslandEventItem}">
                                        <Border Margin="0,2"
                                                Padding="8,6"
                                                CornerRadius="8"
                                                Background="{DynamicResource Surface1Brush}"
                                                BorderBrush="{Binding AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Border}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Left"
                                                            Margin="0,0,6,0"
                                                            Padding="6,2"
                                                            CornerRadius="6"
                                                            Background="{Binding AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Background}">
                                                        <TextBlock Text="{Binding CompactBadge}"
                                                                   FontSize="9"
                                                                   Foreground="{Binding AccentTone, Converter={StaticResource IslandToneToBrush}, ConverterParameter=Foreground}" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding PrimarySnippet}"
                                                           Margin="0,3,0,0"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding QueuedOverflowHint}"
                                       FontSize="9"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       Margin="0,4,0,0"
                                       Opacity="0.9"
                                       Visibility="{Binding QueuedOverflowHint, Converter={StaticResource StringToVis}}" />
                        </StackPanel>
                    </Border>

                    <!-- Header -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Todas as sessões"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="&#x2212;"
                                Width="22" Height="22"
                                FontSize="14"
                                Background="Transparent"
                                Foreground="{DynamicResource SubtextBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Minimizar"
                                Click="OnMinimizeClick" />
                    </Grid>

                    <!-- Session list -->
                    <ItemsControl x:Name="SessionList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DynamicIslandSessionItem}">
                                <Border x:Name="SessionRow"
                                        Style="{StaticResource SessionRowStyle}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="OnSessionRowClick"
                                        Tag="{Binding SessionId}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Status dot -->
                                        <Ellipse Grid.Column="0"
                                                 Width="7" Height="7"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding SessionState, Converter={StaticResource SessionStateToColor}}" />

                                        <!-- Title + info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ShellType}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding SessionState}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           Margin="0,0,6,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DurationDisplay}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0" />

                                        <!-- Close button (shown on hover) -->
                                        <Button Grid.Column="3"
                                                x:Name="CloseBtn"
                                                Style="{StaticResource CloseButtonStyle}"
                                                Content="✕"
                                                Tag="{Binding SessionId}"
                                                Click="OnSessionCloseClick" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Correct pattern: Trigger with SourceName references the named element -->
                                    <Trigger SourceName="SessionRow" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock x:Name="EmptyLabel"
                               Text="Nenhuma sessão ativa"
                               FontSize="11"
                               Foreground="{DynamicResource SubtextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8"
                               Visibility="Collapsed" />

                    <!-- Footer -->
                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource Surface1Brush}"
                            Margin="0,8,0,0"
                            Padding="0,6,0,0">
                        <TextBlock Text="Abrir CommandDeck"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="OnOpenCommandDeckClick" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
