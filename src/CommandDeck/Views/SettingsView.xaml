<UserControl x:Class="CommandDeck.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:helpers="clr-namespace:CommandDeck.Helpers"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="900"
             Background="{DynamicResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:InverseStringToVisibilityConverter x:Key="InvStringToVis" />
        <conv:StringToStretchConverter x:Key="StringToStretch" />

        <!-- Tab styling -->
        <Style x:Key="SettingsTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Pill nav bar -->
                            <Border Grid.Row="0" Background="{DynamicResource Surface0Brush}"
                                    CornerRadius="10" Padding="4" Margin="0,0,0,20"
                                    HorizontalAlignment="Left">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <!-- Content without any border -->
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="16,8" Cursor="Hand"
                                Background="Transparent" CornerRadius="7">
                            <TextBlock x:Name="HeaderText"
                                       Text="{TemplateBinding Header}"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SubtextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource Surface1Brush}"/>
                                <Setter TargetName="HeaderText" Property="Foreground"
                                        Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource Surface1Brush}"/>
                                <Setter TargetName="HeaderText" Property="Foreground"
                                        Value="{DynamicResource TextBrush}"/>
                                <Setter TargetName="HeaderText" Property="FontWeight"
                                        Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch for notifications -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="40" Height="22" CornerRadius="11"
                                Background="{DynamicResource Surface2Brush}" Cursor="Hand"
                                VerticalAlignment="Center">
                            <Ellipse x:Name="Thumb" Width="16" Height="16"
                                     Fill="{DynamicResource SubtextBrush}"
                                     HorizontalAlignment="Left" Margin="3,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider active button template -->
        <ControlTemplate x:Key="ProviderButtonTemplate" TargetType="Button">
            <Border x:Name="btnBorder" Background="{TemplateBinding Background}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}" BorderThickness="0">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid Margin="24,24" MaxWidth="900" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Configurações" Style="{StaticResource HeadingText}" Margin="0,0,0,4"/>
            <TextBlock Text="Personalize sua experiência" Style="{StaticResource CaptionText}" Opacity="0.5"/>
        </StackPanel>

        <!-- TAB CONTROL -->
        <TabControl Grid.Row="1" Style="{StaticResource SettingsTabControl}"
                    SelectedIndex="{Binding SelectedTabIndex}">

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 1: GERAL
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Geral">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Projetos -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Projetos" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                                <TextBlock Text="Diretório de scan" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding ProjectScanDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="C:\Users\..." Margin="0,0,0,12"/>
                                <TextBlock Text="Profundidade máxima" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding ProjectScanMaxDepth, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="3" Margin="0,0,0,12"/>
                                <CheckBox IsChecked="{Binding StartWithLastProject}"
                                          Foreground="{DynamicResource TextBrush}" FontSize="13">
                                    <TextBlock Text="Abrir último projeto ao iniciar" Foreground="{DynamicResource TextBrush}"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- Monitoramento -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Monitoramento" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Refresh do Git" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Style="{StaticResource DarkTextBox}"
                                                     Text="{Binding GitRefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="5"/>
                                            <TextBlock Grid.Column="1" Text="seg" Style="{StaticResource CaptionText}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.5"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Monitor de processos" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Style="{StaticResource DarkTextBox}"
                                                     Text="{Binding ProcessMonitorIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="3"/>
                                            <TextBlock Grid.Column="1" Text="seg" Style="{StaticResource CaptionText}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.5"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 2: TERMINAL
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Terminal">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Terminal settings -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Terminal" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>

                                <TextBlock Text="Fonte" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding TerminalFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Cascadia Code, Consolas" Margin="0,0,0,12"/>

                                <TextBlock Text="Tamanho da fonte" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding TerminalFontSize, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="14" Margin="0,0,0,12"/>

                                <TextBlock Text="Shell padrao" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableShells}"
                                          SelectedItem="{Binding DefaultShell}" Margin="0,0,0,12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Comportamento de resize" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableResizeBehaviors}"
                                          SelectedItem="{Binding TerminalResizeBehavior}" Margin="0,0,0,12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Modo de zoom" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableZoomModes}"
                                          SelectedItem="{Binding CanvasZoomMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Atalhos -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Atalhos de Teclado" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>

                                <TextBlock Text="Novo Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding NewTerminalShortcut, UpdateSourceTrigger=PropertyChanged}" Tag="Ctrl+Shift+T" Margin="0,0,0,10"/>

                                <TextBlock Text="Fechar Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding CloseTerminalShortcut, UpdateSourceTrigger=PropertyChanged}" Tag="Ctrl+Shift+W" Margin="0,0,0,10"/>

                                <TextBlock Text="Próximo Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding NextTerminalShortcut, UpdateSourceTrigger=PropertyChanged}" Tag="Ctrl+Tab" Margin="0,0,0,10"/>

                                <TextBlock Text="Terminal Anterior" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding PreviousTerminalShortcut, UpdateSourceTrigger=PropertyChanged}" Tag="Ctrl+Shift+Tab" Margin="0,0,0,10"/>

                                <TextBlock Text="Alternar Sidebar" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding ToggleSidebarShortcut, UpdateSourceTrigger=PropertyChanged}" Tag="Ctrl+B" Margin="0,0,0,10"/>

                                <TextBlock Text="Focar Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding FocusTerminalShortcut, UpdateSourceTrigger=PropertyChanged}" Tag="Ctrl+`"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 3: APARENCIA
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Aparência">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <StackPanel>

                        <!-- Tema -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="M12 3C7.03 3 3 7.03 3 12C3 16.97 7.03 21 12 21C12.83 21 13.5 20.33 13.5 19.5C13.5 19.11 13.35 18.76 13.11 18.49C12.88 18.23 12.73 17.88 12.73 17.5C12.73 16.67 13.4 16 14.23 16H16C18.76 16 21 13.76 21 11C21 6.58 16.97 3 12 3Z M6.5 12C5.67 12 5 11.33 5 10.5C5 9.67 5.67 9 6.5 9C7.33 9 8 9.67 8 10.5C8 11.33 7.33 12 6.5 12Z M9.5 8C8.67 8 8 7.33 8 6.5C8 5.67 8.67 5 9.5 5C10.33 5 11 5.67 11 6.5C11 7.33 10.33 8 9.5 8Z M14.5 8C13.67 8 13 7.33 13 6.5C13 5.67 13.67 5 14.5 5C15.33 5 16 5.67 16 6.5C16 7.33 15.33 8 14.5 8Z M17.5 12C16.67 12 16 11.33 16 10.5C16 9.67 16.67 9 17.5 9C18.33 9 19 9.67 19 10.5C19 11.33 18.33 12 17.5 12Z"
                                      Fill="{DynamicResource AccentBrush}"
                                      Width="20" Height="20" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Tema" Style="{StaticResource SubheadingText}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Escolha o esquema de cores da interface" Style="{StaticResource CaptionText}" Opacity="0.7"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableThemes}"
                                          SelectedItem="{Binding SelectedTheme}"
                                          VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Wallpaper do Canvas -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="M4 5C4 3.89543 4.89543 3 6 3H14L20 9V19C20 20.1046 19.1046 21 18 21H6C4.89543 21 4 20.1046 4 19V5Z M14 3V9H20 M9 13L11 17L13 13L15 17"
                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="20" Height="20" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Wallpaper do Canvas" Style="{StaticResource SubheadingText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Imagem de fundo na area de terminais"
                                           Style="{StaticResource CaptionText}" Margin="0,0,0,16" />
                                <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16"
                                        MinHeight="160" MaxHeight="200"
                                        Background="{DynamicResource Surface0Brush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1.5">
                                    <Grid>
                                        <Image Source="{Binding CanvasWallpaperPath}" Stretch="{Binding CanvasWallpaperStretch, Converter={StaticResource StringToStretch}}"
                                               Opacity="{Binding CanvasWallpaperOpacity}"
                                               Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}" />
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource InvStringToVis}}">
                                            <Path Data="M4 16L8 12L12 16M14 14L16 12L20 16M6 20H18C19.1046 20 20 19.1046 20 18V6C20 4.89543 19.1046 4 18 4H6C4.89543 4 4 4.89543 4 6V18C4 19.1046 4.89543 20 6 20Z M14.5 9.5C14.5 10.3284 13.8284 11 13 11C12.1716 11 11.5 10.3284 11.5 9.5C11.5 8.67157 12.1716 8 13 8C13.8284 8 14.5 8.67157 14.5 9.5Z"
                                                  Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="40" Height="40" Stretch="Uniform" Opacity="0.4"
                                                  HorizontalAlignment="Center" Margin="0,0,0,10" />
                                            <TextBlock Text="Nenhuma imagem selecionada" Style="{StaticResource CaptionText}" Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                            <Button Style="{StaticResource AccentButton}" Content="Escolher Imagem"
                                                    Command="{Binding BrowseWallpaperCommand}" HorizontalAlignment="Center" Padding="20,8" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8"
                                                    Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <Button Style="{StaticResource GhostButton}" Content="Trocar" FontSize="11" Command="{Binding BrowseWallpaperCommand}" Padding="12,5" Margin="0,0,4,0">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                            <Button Style="{StaticResource DangerButton}" Content="Remover" FontSize="11" Command="{Binding ClearWallpaperCommand}" Padding="12,5">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,4"
                                        Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Opacidade" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding CanvasWallpaperOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11">
                                                    <TextBlock.Text><Binding Path="CanvasWallpaperOpacity" StringFormat="{}{0:P0}" /></TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Ajuste" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableStretchModes}" SelectedItem="{Binding CanvasWallpaperStretch}">
                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Fundo dos Terminais -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="{StaticResource TerminalIcon}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Fundo dos Terminais" Style="{StaticResource SubheadingText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Personalize o fundo dentro de cada terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,16" />
                                <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16" MinHeight="180" MaxHeight="220" Background="{DynamicResource Surface0Brush}" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1.5">
                                    <Grid>
                                        <Image Source="{Binding TerminalWallpaperPath}" Stretch="{Binding TerminalWallpaperStretch, Converter={StaticResource StringToStretch}}" Opacity="{Binding TerminalWallpaperOpacity}" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}" />
                                        <Rectangle Opacity="{Binding TerminalWallpaperOverlayOpacity}" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Fill" Value="#000000" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TerminalWallpaperDarkOverlay}" Value="False">
                                                            <Setter Property="Fill" Value="#FFFFFF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Center" Margin="20,16" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource AccentBrush}" Opacity="0.8" Text="~/projects/commanddeck" Margin="0,0,0,2" />
                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource TextBrush}" Opacity="0.6" Text="$ dotnet build" Margin="0,0,0,2" />
                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource SubtextBrush}" Opacity="0.5" Text="Build succeeded. 0 Warning(s) 0 Error(s)" />
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource InvStringToVis}}">
                                            <Path Data="{StaticResource TerminalIcon}" Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="40" Height="40" Stretch="Uniform" Opacity="0.3" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                            <TextBlock Text="Nenhuma imagem de fundo" Style="{StaticResource CaptionText}" Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                            <Button Style="{StaticResource AccentButton}" Content="Escolher Imagem" Command="{Binding BrowseTerminalWallpaperCommand}" HorizontalAlignment="Center" Padding="20,8" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <Button Style="{StaticResource GhostButton}" Content="Trocar" FontSize="11" Command="{Binding BrowseTerminalWallpaperCommand}" Padding="12,5" Margin="0,0,4,0">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                            <Button Style="{StaticResource DangerButton}" Content="Remover" FontSize="11" Command="{Binding ClearTerminalWallpaperCommand}" Padding="12,5">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding TerminalWallpaperStatusText}" Foreground="#F38BA8" Style="{StaticResource CaptionText}" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperStatusText, Converter={StaticResource StringToVis}}" />
                                <!-- IMAGEM controls -->
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="IMAGEM" Style="{StaticResource CaptionText}" FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Opacidade" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding TerminalWallpaperOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperOpacity" StringFormat="{}{0:P0}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Desfoque" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="30" Value="{Binding TerminalWallpaperBlurRadius}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperBlurRadius" StringFormat="{}{0:F0}px" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Ajuste" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableStretchModes}" SelectedItem="{Binding TerminalWallpaperStretch}">
                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <!-- OVERLAY controls -->
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="OVERLAY" Style="{StaticResource CaptionText}" FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Modo" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <RadioButton GroupName="TerminalOverlay" IsChecked="{Binding TerminalWallpaperDarkOverlay}" VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="12" Height="12" Fill="#1E1E2E" Stroke="{DynamicResource GlassBorderBrush}" StrokeThickness="1" Margin="0,0,5,0" />
                                                        <TextBlock Text="Escuro" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton GroupName="TerminalOverlay" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="12" Height="12" Fill="#FFFFFF" Stroke="{DynamicResource GlassBorderBrush}" StrokeThickness="1" Margin="0,0,5,0" />
                                                        <TextBlock Text="Claro" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                                    </StackPanel>
                                                </RadioButton>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Intensidade" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding TerminalWallpaperOverlayOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperOverlayOpacity" StringFormat="{}{0:P0}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <!-- AJUSTES controls -->
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="AJUSTES" Style="{StaticResource CaptionText}" FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Brilho" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding TerminalWallpaperBrightness}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperBrightness" StringFormat="{}{0:F2}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Contraste" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding TerminalWallpaperContrast}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperContrast" StringFormat="{}{0:F2}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Button Content="Restaurar Padrao" Style="{StaticResource GhostButton}" Command="{Binding ClearTerminalWallpaperCommand}" HorizontalAlignment="Left" Padding="16,6" FontSize="11" Opacity="0.7" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 4: PROVEDORES DE IA
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Provedores de IA">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- General AI settings -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding AiAssistantVisible}" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="Mostrar painel do Assistente" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                                    </CheckBox>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Desativar IA" Style="{StaticResource GhostButton}"
                                        Command="{Binding SetActiveProviderCommand}" CommandParameter="none"
                                        Padding="12,6" FontSize="12"
                                        Visibility="{Binding IsAiEnabled, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>

                        <!-- Provider cards 2x2 -->
                        <UniformGrid Columns="2" Rows="2">

                            <!-- ANTHROPIC -->
                            <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource Surface0Brush}" Margin="0,0,10,0">
                                                <Image Source="/Resources/Images/anthropic.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Anthropic" Style="{StaticResource SubheadingText}" FontSize="14" Margin="0"/>
                                                <TextBlock Text="Claude" Style="{StaticResource CaptionText}" Opacity="0.5" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#585B70" Opacity="0.3"/></Setter.Value></Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AiProvider}" Value="anthropic">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#A6E3A1" Opacity="0.15"/></Setter.Value></Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock"><Setter Property="Text" Value="Inativo"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                                        <Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="anthropic"><Setter Property="Text" Value="Ativo"/><Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/></DataTrigger></Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Modelo" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableAnthropicModels}" SelectedItem="{Binding AnthropicModel}" Tag="Selecione um modelo" Margin="0,0,0,12"/>
                                    <TextBlock Text="Autenticação" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableAnthropicAuthModes}" SelectedItem="{Binding AnthropicAuthMode}" Tag="Selecione o tipo" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Visibility="{Binding IsAnthropicOAuthMode, Converter={StaticResource BoolToVis}}">
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#F38BA8"/><Style.Triggers><DataTrigger Binding="{Binding IsClaudeCodeDetected}" Value="True"><Setter Property="Fill" Value="#A6E3A1"/></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding ClaudeSubscriptionInfo}" Style="{StaticResource CaptionText}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding IsAnthropicOAuthMode}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                        <TextBlock Text="API Key" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                        <PasswordBox Style="{StaticResource DarkPasswordBox}" helpers:PasswordBoxHelper.BoundPassword="{Binding AnthropicApiKey, Mode=TwoWay}" Tag="sk-ant-..." Margin="0,0,0,12"/>
                                    </StackPanel>
                                    <Button Command="{Binding SetActiveProviderCommand}" CommandParameter="anthropic" IsEnabled="{Binding CanActivateAnthropic}" Padding="12,7" HorizontalAlignment="Stretch" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                                        <Button.Style>
                                            <Style TargetType="Button"><Setter Property="Background" Value="{DynamicResource Surface0Brush}"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Setter Property="Content" Value="Definir como Ativo"/><Setter Property="Template" Value="{StaticResource ProviderButtonTemplate}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AiProvider}" Value="anthropic"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="Content" Value="Provedor Ativo"/></DataTrigger>
                                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- OPENAI -->
                            <Border Style="{StaticResource Card}" Margin="8,0,0,8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource Surface0Brush}" Margin="0,0,10,0">
                                                <Image Source="/Resources/Images/openai.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="OpenAI" Style="{StaticResource SubheadingText}" FontSize="14" Margin="0"/>
                                                <TextBlock Text="GPT" Style="{StaticResource CaptionText}" Opacity="0.5" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="#585B70" Opacity="0.3"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="openai"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="#A6E3A1" Opacity="0.15"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Inativo"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="openai"><Setter Property="Text" Value="Ativo"/><Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Modelo" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableOpenAiModels}" SelectedItem="{Binding OpenAiModel}" Tag="Selecione um modelo" Margin="0,0,0,12"/>
                                    <TextBlock Text="API Key" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <PasswordBox Style="{StaticResource DarkPasswordBox}" helpers:PasswordBoxHelper.BoundPassword="{Binding OpenAiApiKey, Mode=TwoWay}" Tag="sk-..." Margin="0,0,0,12"/>
                                    <Button Command="{Binding SetActiveProviderCommand}" CommandParameter="openai" IsEnabled="{Binding CanActivateOpenAi}" Padding="12,7" HorizontalAlignment="Stretch" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                                        <Button.Style><Style TargetType="Button"><Setter Property="Background" Value="{DynamicResource Surface0Brush}"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Setter Property="Content" Value="Definir como Ativo"/><Setter Property="Template" Value="{StaticResource ProviderButtonTemplate}"/><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="openai"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="Content" Value="Provedor Ativo"/></DataTrigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger></Style.Triggers></Style></Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- OPENROUTER -->
                            <Border Style="{StaticResource Card}" Margin="0,8,8,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource Surface0Brush}" Margin="0,0,10,0">
                                                <Image Source="/Resources/Images/openrouter.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="OpenRouter" Style="{StaticResource SubheadingText}" FontSize="14" Margin="0"/>
                                                <TextBlock Text="Multi-provider" Style="{StaticResource CaptionText}" Opacity="0.5" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="#585B70" Opacity="0.3"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="openrouter"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="#A6E3A1" Opacity="0.15"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Inativo"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="openrouter"><Setter Property="Text" Value="Ativo"/><Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Modelo" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource DarkComboBox}" IsEditable="True" ItemsSource="{Binding AvailableOpenRouterModels}" Text="{Binding OpenRouterModel}" Tag="Selecione ou digite um modelo" Margin="0,0,0,12"/>
                                    <TextBlock Text="API Key" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <PasswordBox Style="{StaticResource DarkPasswordBox}" helpers:PasswordBoxHelper.BoundPassword="{Binding OpenRouterApiKey, Mode=TwoWay}" Tag="sk-or-..." Margin="0,0,0,12"/>
                                    <Button Command="{Binding SetActiveProviderCommand}" CommandParameter="openrouter" IsEnabled="{Binding CanActivateOpenRouter}" Padding="12,7" HorizontalAlignment="Stretch" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                                        <Button.Style><Style TargetType="Button"><Setter Property="Background" Value="{DynamicResource Surface0Brush}"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Setter Property="Content" Value="Definir como Ativo"/><Setter Property="Template" Value="{StaticResource ProviderButtonTemplate}"/><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="openrouter"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="Content" Value="Provedor Ativo"/></DataTrigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger></Style.Triggers></Style></Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- OLLAMA (LOCAL) -->
                            <Border Style="{StaticResource Card}" Margin="8,8,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource Surface0Brush}" Margin="0,0,10,0">
                                                <Image Source="/Resources/Images/ollama.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Ollama" Style="{StaticResource SubheadingText}" FontSize="14" Margin="0"/>
                                                <TextBlock Text="Local" Style="{StaticResource CaptionText}" Opacity="0.5" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                                            <Border.Style><Style TargetType="Border"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="#585B70" Opacity="0.3"/></Setter.Value></Setter><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="local"><Setter Property="Background"><Setter.Value><SolidColorBrush Color="#A6E3A1" Opacity="0.15"/></Setter.Value></Setter></DataTrigger></Style.Triggers></Style></Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="Inativo"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="local"><Setter Property="Text" Value="Ativo"/><Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Modelo" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}" Tag="llama3.2" Margin="0,0,0,12"/>
                                    <TextBlock Text="Base URL" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding OllamaBaseUrl, UpdateSourceTrigger=PropertyChanged}" Tag="http://localhost:11434" Margin="0,0,0,12"/>
                                    <Button Command="{Binding SetActiveProviderCommand}" CommandParameter="local" Padding="12,7" HorizontalAlignment="Stretch" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                                        <Button.Style><Style TargetType="Button"><Setter Property="Background" Value="{DynamicResource Surface0Brush}"/><Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/><Setter Property="Content" Value="Definir como Ativo"/><Setter Property="Template" Value="{StaticResource ProviderButtonTemplate}"/><Style.Triggers><DataTrigger Binding="{Binding AiProvider}" Value="local"><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="Content" Value="Provedor Ativo"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 5: NOTIFICAÇÕES
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Notificações">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Notificações" Style="{StaticResource SubheadingText}" Margin="0,0,0,16" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Notificações ativas" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                        <TextBlock Text="Habilita ou desabilita todas as notificações do sistema" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotificationsEnabled}" />
                                </Grid>
                            </Border>
                            <TextBlock Text="FONTES DE NOTIFICAÇÃO" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,8" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="0" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Terminal" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyTerminalEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Git" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyGitEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Processos" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyProcessEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Assistente IA" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyAiEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Sistema" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifySystemEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Som de notificação" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                        <TextBlock Text="Reproduz um som ao receber notificações" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotificationSoundEnabled}" IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 6: SOBRE
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Sobre">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Sobre" Style="{StaticResource SubheadingText}" Margin="0,0,0,16" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="10" Padding="20,18" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="42" Height="42" CornerRadius="10" Background="{DynamicResource AccentBrush}" Margin="0,0,14,0">
                                            <TextBlock Text="DW" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Command Deck" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Border CornerRadius="4" Padding="8,2" Background="{DynamicResource AccentBrush}" Margin="0,0,8,0">
                                                    <TextBlock VerticalAlignment="Center">
                                                        <Run Text="v" FontWeight="SemiBold" Foreground="White" />
                                                        <Run Text="{Binding AppVersion, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" Foreground="White" />
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="MIT License" Style="{StaticResource CaptionText}" Opacity="0.5" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Terminal manager e dashboard de desenvolvimento para Windows." Style="{StaticResource BodyText}" TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="INFORMAÇÕES" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,8" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="0" Margin="0,0,0,20">
                                <StackPanel>
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Dev" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Rony Oliveira" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Repo" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="github.com/ronydrop/dev-workspace-hub" Style="{StaticResource BodyText}" FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Stack" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text=".NET 8 + WPF + CommunityToolkit.Mvvm" Style="{StaticResource BodyText}" FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="ATUALIZAÇÕES" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,8" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="16,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Style="{StaticResource AccentButton}" Content="Verificar Atualizações" Command="{Binding CheckForUpdateCommand}" Padding="16,8" FontSize="13" Margin="0,0,10,0" />
                                        <Button Style="{StaticResource GhostButton}" Content="Baixar Atualização" Command="{Binding OpenUpdatePageCommand}" Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}" Padding="16,8" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UpdateStatusText}" Style="{StaticResource CaptionText}" Opacity="0.6" Visibility="{Binding UpdateStatusText, Converter={StaticResource NullToVis}}" />
                                </StackPanel>
                            </Border>
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionText}" Opacity="0.35" FontSize="11" Margin="0,20,0,0">
                                <Run Text="Made with C# and WPF" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- BOTÕES DE AÇÃO -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource GhostButton}" Content="Restaurar Padrões" Command="{Binding ResetDefaultsCommand}" Padding="16,8" Margin="0,0,8,0" />
            <Button Style="{StaticResource GhostButton}" Content="Cancelar" Command="{Binding CancelCommand}" Padding="16,8" Margin="0,0,8,0" />
            <Button Style="{StaticResource AccentButton}" Content="Salvar" Command="{Binding SaveCommand}" Padding="24,8" />
        </StackPanel>
    </Grid>
</UserControl>
