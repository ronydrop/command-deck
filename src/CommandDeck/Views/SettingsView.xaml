<UserControl x:Class="CommandDeck.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:helpers="clr-namespace:CommandDeck.Helpers"
             xmlns:models="clr-namespace:CommandDeck.Models"
             xmlns:controls="clr-namespace:CommandDeck.Controls"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="900"
             Background="{DynamicResource BaseBgBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:StringToStretchConverter x:Key="StringToStretch" />
        <conv:StringToImageSourceConverter x:Key="StringToImageSource" />

        <!-- Tab styling -->
        <Style x:Key="SettingsTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Pill nav bar -->
                            <Border Grid.Row="0" Background="{DynamicResource Surface0Brush}"
                                    CornerRadius="10" Padding="4" Margin="0,0,0,20"
                                    HorizontalAlignment="Left">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <!-- Content without any border -->
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"
                                              HorizontalAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="8,8" Cursor="Hand"
                                Background="Transparent" CornerRadius="7">
                            <TextBlock x:Name="HeaderText"
                                       Text="{TemplateBinding Header}"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SubtextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource Surface1Brush}"/>
                                <Setter TargetName="HeaderText" Property="Foreground"
                                        Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{DynamicResource Surface1Brush}"/>
                                <Setter TargetName="HeaderText" Property="Foreground"
                                        Value="{DynamicResource TextBrush}"/>
                                <Setter TargetName="HeaderText" Property="FontWeight"
                                        Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch for notifications -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="40" Height="22" CornerRadius="11"
                                Background="{DynamicResource Surface2Brush}" Cursor="Hand"
                                VerticalAlignment="Center">
                            <Ellipse x:Name="Thumb" Width="16" Height="16"
                                     Fill="{DynamicResource SubtextBrush}"
                                     HorizontalAlignment="Left" Margin="3,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider active button template -->
        <ControlTemplate x:Key="ProviderButtonTemplate" TargetType="Button">
            <Border x:Name="btnBorder" Background="{TemplateBinding Background}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}" BorderThickness="0">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Shortcut capture button -->
        <Style x:Key="ShortcutCaptureButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Surface0Brush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Surface1Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shortcut reset icon button -->
        <Style x:Key="ShortcutResetButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Surface1Brush}"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
    <Grid Margin="16,16" MaxWidth="1800" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Configurações" Style="{StaticResource HeadingText}" Margin="0,0,0,4"/>
            <TextBlock Text="Personalize sua experiência" Style="{StaticResource CaptionText}" Opacity="0.5"/>
        </StackPanel>

        <!-- TAB CONTROL -->
        <TabControl Grid.Row="1" Style="{StaticResource SettingsTabControl}"
                    SelectedIndex="{Binding SelectedTabIndex}">

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 1: GERAL
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Geral">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Projetos -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Projetos" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                                <TextBlock Text="Diretório de scan" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding ProjectScanDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="C:\Users\..." Margin="0,0,0,12"/>
                                <TextBlock Text="Profundidade máxima" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <controls:NumericUpDownControl
                                    Value="{Binding ProjectScanMaxDepth, UpdateSourceTrigger=PropertyChanged}"
                                    Minimum="1" Maximum="20" Step="1"
                                    Margin="0,0,0,12"/>
                                <CheckBox IsChecked="{Binding StartWithLastProject}"
                                          Foreground="{DynamicResource TextBrush}" FontSize="13">
                                    <TextBlock Text="Abrir último projeto ao iniciar" Foreground="{DynamicResource TextBrush}"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- Monitoramento -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Monitoramento" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Refresh do Git" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <controls:NumericUpDownControl
                                                Value="{Binding GitRefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1" Maximum="300" Step="1"/>
                                            <TextBlock Grid.Column="1" Text="seg" Style="{StaticResource CaptionText}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.5"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Monitor de processos" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <controls:NumericUpDownControl
                                                Value="{Binding ProcessMonitorIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1" Maximum="300" Step="1"/>
                                            <TextBlock Grid.Column="1" Text="seg" Style="{StaticResource CaptionText}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.5"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 2: TERMINAL
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Terminal">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Terminal settings -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Terminal" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>

                                <TextBlock Text="Fonte" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding TerminalFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="Cascadia Code, Consolas" Margin="0,0,0,12"/>

                                <TextBlock Text="Tamanho da fonte" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <controls:NumericUpDownControl
                                    Value="{Binding TerminalFontSize, UpdateSourceTrigger=PropertyChanged}"
                                    Minimum="8" Maximum="48" Step="1"
                                    Margin="0,0,0,12"/>

                                <TextBlock Text="Shell padrao" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableShells}"
                                          SelectedItem="{Binding DefaultShell}" Margin="0,0,0,12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Comportamento de resize" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableResizeBehaviors}"
                                          SelectedItem="{Binding TerminalResizeBehavior}" Margin="0,0,0,12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Modo de zoom" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableZoomModes}"
                                          SelectedItem="{Binding CanvasZoomMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Atalhos -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Atalhos de Teclado" Style="{StaticResource SubheadingText}" Margin="0,0,0,12"/>

                                <TextBlock Text="Novo Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ShortcutCaptureButton}"
                                            Content="{Binding NewTerminalShortcut}" Tag="NewTerminalShortcut" Click="OnEditShortcut"/>
                                    <Button Grid.Column="1" Style="{StaticResource ShortcutResetButton}"
                                            Tag="NewTerminalShortcut" ToolTip="Restaurar padrão (Ctrl+Shift+T)" Click="OnResetShortcut"
                                            Visibility="{Binding IsNewTerminalShortcutModified, Converter={StaticResource BoolToVis}}">
                                        <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                              Fill="{DynamicResource SubtextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Fechar Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ShortcutCaptureButton}"
                                            Content="{Binding CloseTerminalShortcut}" Tag="CloseTerminalShortcut" Click="OnEditShortcut"/>
                                    <Button Grid.Column="1" Style="{StaticResource ShortcutResetButton}"
                                            Tag="CloseTerminalShortcut" ToolTip="Restaurar padrão (Ctrl+Shift+W)" Click="OnResetShortcut"
                                            Visibility="{Binding IsCloseTerminalShortcutModified, Converter={StaticResource BoolToVis}}">
                                        <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                              Fill="{DynamicResource SubtextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Próximo Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ShortcutCaptureButton}"
                                            Content="{Binding NextTerminalShortcut}" Tag="NextTerminalShortcut" Click="OnEditShortcut"/>
                                    <Button Grid.Column="1" Style="{StaticResource ShortcutResetButton}"
                                            Tag="NextTerminalShortcut" ToolTip="Restaurar padrão (Ctrl+Tab)" Click="OnResetShortcut"
                                            Visibility="{Binding IsNextTerminalShortcutModified, Converter={StaticResource BoolToVis}}">
                                        <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                              Fill="{DynamicResource SubtextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Terminal Anterior" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ShortcutCaptureButton}"
                                            Content="{Binding PreviousTerminalShortcut}" Tag="PreviousTerminalShortcut" Click="OnEditShortcut"/>
                                    <Button Grid.Column="1" Style="{StaticResource ShortcutResetButton}"
                                            Tag="PreviousTerminalShortcut" ToolTip="Restaurar padrão (Ctrl+Shift+Tab)" Click="OnResetShortcut"
                                            Visibility="{Binding IsPreviousTerminalShortcutModified, Converter={StaticResource BoolToVis}}">
                                        <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                              Fill="{DynamicResource SubtextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Alternar Sidebar" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ShortcutCaptureButton}"
                                            Content="{Binding ToggleSidebarShortcut}" Tag="ToggleSidebarShortcut" Click="OnEditShortcut"/>
                                    <Button Grid.Column="1" Style="{StaticResource ShortcutResetButton}"
                                            Tag="ToggleSidebarShortcut" ToolTip="Restaurar padrão (Ctrl+B)" Click="OnResetShortcut"
                                            Visibility="{Binding IsToggleSidebarShortcutModified, Converter={StaticResource BoolToVis}}">
                                        <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                              Fill="{DynamicResource SubtextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Focar Terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ShortcutCaptureButton}"
                                            Content="{Binding FocusTerminalShortcut}" Tag="FocusTerminalShortcut" Click="OnEditShortcut"/>
                                    <Button Grid.Column="1" Style="{StaticResource ShortcutResetButton}"
                                            Tag="FocusTerminalShortcut" ToolTip="Restaurar padrão (Ctrl+`)" Click="OnResetShortcut"
                                            Visibility="{Binding IsFocusTerminalShortcutModified, Converter={StaticResource BoolToVis}}">
                                        <Path Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                              Fill="{DynamicResource SubtextBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Expandir/Fechar Painéis Laterais" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="Ctrl+\" IsReadOnly="True" Margin="0,0,0,10"/>

                                <TextBlock Text="Ver Todos os Atalhos" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="Ctrl+/" IsReadOnly="True"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 3: APARENCIA
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Aparência">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <StackPanel>

                        <!-- Tema -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="M12 3C7.03 3 3 7.03 3 12C3 16.97 7.03 21 12 21C12.83 21 13.5 20.33 13.5 19.5C13.5 19.11 13.35 18.76 13.11 18.49C12.88 18.23 12.73 17.88 12.73 17.5C12.73 16.67 13.4 16 14.23 16H16C18.76 16 21 13.76 21 11C21 6.58 16.97 3 12 3Z M6.5 12C5.67 12 5 11.33 5 10.5C5 9.67 5.67 9 6.5 9C7.33 9 8 9.67 8 10.5C8 11.33 7.33 12 6.5 12Z M9.5 8C8.67 8 8 7.33 8 6.5C8 5.67 8.67 5 9.5 5C10.33 5 11 5.67 11 6.5C11 7.33 10.33 8 9.5 8Z M14.5 8C13.67 8 13 7.33 13 6.5C13 5.67 13.67 5 14.5 5C15.33 5 16 5.67 16 6.5C16 7.33 15.33 8 14.5 8Z M17.5 12C16.67 12 16 11.33 16 10.5C16 9.67 16.67 9 17.5 9C18.33 9 19 9.67 19 10.5C19 11.33 18.33 12 17.5 12Z"
                                      Fill="{DynamicResource AccentBrush}"
                                      Width="20" Height="20" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Tema" Style="{StaticResource SubheadingText}" Margin="0,0,0,2"/>
                                    <TextBlock Text="Escolha o esquema de cores da interface" Style="{StaticResource CaptionText}" Opacity="0.7"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding AvailableThemes}"
                                          SelectedItem="{Binding SelectedTheme}"
                                          VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Wallpaper do Canvas -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="M4 5C4 3.89543 4.89543 3 6 3H14L20 9V19C20 20.1046 19.1046 21 18 21H6C4.89543 21 4 20.1046 4 19V5Z M14 3V9H20 M9 13L11 17L13 13L15 17"
                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="20" Height="20" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Wallpaper do Canvas" Style="{StaticResource SubheadingText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Imagem de fundo na area de terminais"
                                           Style="{StaticResource CaptionText}" Margin="0,0,0,16" />
                                <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16"
                                        MinHeight="160" MaxHeight="200"
                                        Background="{DynamicResource Surface0Brush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1.5">
                                    <Grid>
                                        <Image Source="{Binding CanvasWallpaperPath, Converter={StaticResource StringToImageSource}}" Stretch="{Binding CanvasWallpaperStretch, Converter={StaticResource StringToStretch}}"
                                               Opacity="{Binding CanvasWallpaperOpacity}"
                                               Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}" />
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}, ConverterParameter=Invert}">
                                            <Path Data="M4 16L8 12L12 16M14 14L16 12L20 16M6 20H18C19.1046 20 20 19.1046 20 18V6C20 4.89543 19.1046 4 18 4H6C4.89543 4 4 4.89543 4 6V18C4 19.1046 4.89543 20 6 20Z M14.5 9.5C14.5 10.3284 13.8284 11 13 11C12.1716 11 11.5 10.3284 11.5 9.5C11.5 8.67157 12.1716 8 13 8C13.8284 8 14.5 8.67157 14.5 9.5Z"
                                                  Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="40" Height="40" Stretch="Uniform" Opacity="0.4"
                                                  HorizontalAlignment="Center" Margin="0,0,0,10" />
                                            <TextBlock Text="Nenhuma imagem selecionada" Style="{StaticResource CaptionText}" Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                            <Button Style="{StaticResource AccentButton}" Content="Escolher Imagem"
                                                    Command="{Binding BrowseWallpaperCommand}" HorizontalAlignment="Center" Padding="20,8" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8"
                                                    Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <Button Style="{StaticResource GhostButton}" Content="Trocar" FontSize="11" Command="{Binding BrowseWallpaperCommand}" Padding="12,5" Margin="0,0,4,0">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                            <Button Style="{StaticResource DangerButton}" Content="Remover" FontSize="11" Command="{Binding ClearWallpaperCommand}" Padding="12,5">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,4"
                                        Visibility="{Binding CanvasWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Opacidade" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding CanvasWallpaperOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11">
                                                    <TextBlock.Text><Binding Path="CanvasWallpaperOpacity" StringFormat="{}{0:P0}" /></TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Ajuste" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableStretchModes}" SelectedItem="{Binding CanvasWallpaperStretch}">
                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Fundo dos Terminais -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="{StaticResource TerminalIcon}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Fundo dos Terminais" Style="{StaticResource SubheadingText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Personalize o fundo dentro de cada terminal" Style="{StaticResource CaptionText}" Margin="0,0,0,16" />
                                <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16" MinHeight="180" MaxHeight="220" Background="{DynamicResource Surface0Brush}" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1.5">
                                    <Grid>
                                        <Image Source="{Binding TerminalWallpaperPath, Converter={StaticResource StringToImageSource}}" Stretch="{Binding TerminalWallpaperStretch, Converter={StaticResource StringToStretch}}" Opacity="{Binding TerminalWallpaperOpacity}" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}" />
                                        <Rectangle Opacity="{Binding TerminalWallpaperOverlayOpacity}" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Fill" Value="#000000" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TerminalWallpaperDarkOverlay}" Value="False">
                                                            <Setter Property="Fill" Value="#FFFFFF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>
                                        <StackPanel VerticalAlignment="Center" Margin="20,16" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource AccentBrush}" Opacity="0.8" Text="~/projects/commanddeck" Margin="0,0,0,2" />
                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource TextBrush}" Opacity="0.6" Text="$ dotnet build" Margin="0,0,0,2" />
                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource SubtextBrush}" Opacity="0.5" Text="Build succeeded. 0 Warning(s) 0 Error(s)" />
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}, ConverterParameter=Invert}">
                                            <Path Data="{StaticResource TerminalIcon}" Stroke="{DynamicResource SubtextBrush}" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="40" Height="40" Stretch="Uniform" Opacity="0.3" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                            <TextBlock Text="Nenhuma imagem de fundo" Style="{StaticResource CaptionText}" Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                            <Button Style="{StaticResource AccentButton}" Content="Escolher Imagem" Command="{Binding BrowseTerminalWallpaperCommand}" HorizontalAlignment="Center" Padding="20,8" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                            <Button Style="{StaticResource GhostButton}" Content="Trocar" FontSize="11" Command="{Binding BrowseTerminalWallpaperCommand}" Padding="12,5" Margin="0,0,4,0">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                            <Button Style="{StaticResource DangerButton}" Content="Remover" FontSize="11" Command="{Binding ClearTerminalWallpaperCommand}" Padding="12,5">
                                                <Button.Background><SolidColorBrush Color="#000000" Opacity="0.6" /></Button.Background>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding TerminalWallpaperStatusText}" Foreground="#F38BA8" Style="{StaticResource CaptionText}" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperStatusText, Converter={StaticResource StringToVis}}" />
                                <!-- IMAGEM controls -->
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="IMAGEM" Style="{StaticResource CaptionText}" FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Opacidade" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding TerminalWallpaperOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperOpacity" StringFormat="{}{0:P0}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Desfoque" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="30" Value="{Binding TerminalWallpaperBlurRadius}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperBlurRadius" StringFormat="{}{0:F0}px" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Ajuste" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}" ItemsSource="{Binding AvailableStretchModes}" SelectedItem="{Binding TerminalWallpaperStretch}">
                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" /></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <!-- OVERLAY controls -->
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="OVERLAY" Style="{StaticResource CaptionText}" FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Modo" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <RadioButton GroupName="TerminalOverlay" IsChecked="{Binding TerminalWallpaperDarkOverlay}" VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="12" Height="12" Fill="#1E1E2E" Stroke="{DynamicResource GlassBorderBrush}" StrokeThickness="1" Margin="0,0,5,0" />
                                                        <TextBlock Text="Escuro" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton GroupName="TerminalOverlay" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="12" Height="12" Fill="#FFFFFF" Stroke="{DynamicResource GlassBorderBrush}" StrokeThickness="1" Margin="0,0,5,0" />
                                                        <TextBlock Text="Claro" Foreground="{DynamicResource TextBrush}" FontSize="12" />
                                                    </StackPanel>
                                                </RadioButton>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Intensidade" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding TerminalWallpaperOverlayOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperOverlayOpacity" StringFormat="{}{0:P0}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <!-- AJUSTES controls -->
                                <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,8" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="AJUSTES" Style="{StaticResource CaptionText}" FontSize="10" FontWeight="SemiBold" Opacity="0.5" Margin="0,0,0,10" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Brilho" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding TerminalWallpaperBrightness}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperBrightness" StringFormat="{}{0:F2}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="44" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Contraste" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Opacity="0.7" />
                                            <Slider Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding TerminalWallpaperContrast}" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border Grid.Column="2" Background="{DynamicResource Surface1Brush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource CaptionText}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="11"><TextBlock.Text><Binding Path="TerminalWallpaperContrast" StringFormat="{}{0:F2}" /></TextBlock.Text></TextBlock>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Button Content="Restaurar Padrao" Style="{StaticResource GhostButton}" Command="{Binding ClearTerminalWallpaperCommand}" HorizontalAlignment="Left" Padding="16,6" FontSize="11" Opacity="0.7" Visibility="{Binding TerminalWallpaperPath, Converter={StaticResource StringToVis}}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                        <!-- Grade e Alinhamento do Canvas -->
                        <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="M3 3H21M3 9H21M3 15H21M3 21H21M9 3V21M15 3V21"
                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="20" Height="20" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Grade e Alinhamento do Canvas"
                                               Style="{StaticResource SubheadingText}" Margin="0" />
                                </StackPanel>
                                <TextBlock Text="Controla o snap e guias de alinhamento ao arrastar terminais"
                                           Style="{StaticResource CaptionText}" Margin="0,0,0,12" />

                                <!-- Snap to grid toggle -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Snap na Grade"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Text="Arrasta terminais encaixam na grade"
                                                   Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding CanvasSnapEnabled}"
                                              VerticalAlignment="Center" />
                                </Grid>

                                <!-- Grid size -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Tamanho da Grade"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Text="Célula em pixels (padrão: 20px)"
                                                   Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Minimum="10" Maximum="80"
                                                Value="{Binding CanvasSnapGridSize}"
                                                TickFrequency="10" IsSnapToTickEnabled="True"
                                                VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <Border Grid.Column="1" Background="{DynamicResource Surface1Brush}"
                                                CornerRadius="4" Padding="4,2" HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource CaptionText}"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="11">
                                                <TextBlock.Text>
                                                    <Binding Path="CanvasSnapGridSize" StringFormat="{}{0}px" />
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Alignment guides toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Guias de Alinhamento"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Text="Exibe linhas azuis ao alinhar com outros terminais"
                                                   Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding CanvasAlignmentGuidesEnabled}"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 4: PROVEDORES DE IA
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Provedores de IA">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Mostrar painel do Assistente -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Painel do Assistente" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Exibe o painel lateral de chat com IA" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AiAssistantVisible}"/>
                            </Grid>
                        </Border>

                        <!-- System Prompt -->
                        <TextBlock Text="System Prompt"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="12" FontWeight="Medium"
                                   Margin="0,16,0,6"/>
                        <TextBlock Text="Prompt de sistema enviado no início de cada conversa."
                                   Foreground="{DynamicResource Overlay0Brush}"
                                   FontSize="10.5" Margin="0,0,0,6"/>
                        <Border Background="{DynamicResource Surface0Brush}"
                                BorderBrush="{DynamicResource Surface1Brush}"
                                BorderThickness="1" CornerRadius="6" Padding="2">
                            <TextBox Text="{Binding AiSystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="80" VerticalScrollBarVisibility="Auto"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource TextBrush}"
                                     FontFamily="Cascadia Code, Consolas, Courier New" FontSize="11.5"
                                     Padding="8,6"/>
                        </Border>

                        <!-- Ferramenta AI padrão do dropdown -->
                        <TextBlock Text="FERRAMENTA AI PADRÃO" Style="{StaticResource CaptionText}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,16,0,8"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding AiTools}"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding DefaultAiToolId}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0,0,0,20" />

                        <!-- Lista de ferramentas AI CLI -->
                        <TextBlock Text="FERRAMENTAS DETECTADAS" Style="{StaticResource CaptionText}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding AiTools}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AiToolInfo}">
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <!-- Linha principal: ícone + nome + badge -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Ícone -->
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                                        Background="{DynamicResource Surface1Brush}" Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <Image Width="22" Height="22" RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Source" Value="{Binding IconPath}"/>
                                                                <Style.Triggers>
                                                                    <!-- Fallback quando imagem não existe é tratado silenciosamente pelo WPF -->
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Border>

                                                <!-- Nome e descrição -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource BodyText}"
                                                               FontWeight="SemiBold" FontSize="13" Margin="0"/>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}"
                                                               Opacity="0.55" FontSize="11" Margin="0,1,0,0"/>
                                                </StackPanel>

                                                <!-- Badge de status -->
                                                <Border Grid.Column="2" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#585B70" Opacity="0.3"/></Setter.Value></Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AiToolDetectionStatus.Detected}">
                                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#34D85C" Opacity="0.15"/></Setter.Value></Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AiToolDetectionStatus.NotFound}">
                                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#FF5048" Opacity="0.15"/></Setter.Value></Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AiToolDetectionStatus.Detected}">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AiToolDetectionStatus.NotFound}">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- Comando de instalação (só quando não encontrado e tem comando) -->
                                            <Border Margin="0,10,0,0" Background="{DynamicResource Surface0Brush}"
                                                    CornerRadius="6" Padding="10,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Status}" Value="{x:Static models:AiToolDetectionStatus.NotFound}"/>
                                                                    <Condition Binding="{Binding InstallCommand, Converter={StaticResource StringToVis}}" Value="Visible"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <TextBox Style="{StaticResource DarkTextBox}"
                                                             Text="{Binding InstallCommand, Mode=OneWay}"
                                                             FontFamily="Cascadia Code, Consolas, Courier New"
                                                             FontSize="12" Foreground="{DynamicResource AccentCyanBrush}"
                                                             TextWrapping="Wrap"
                                                             IsReadOnly="True"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0,0,28,0"
                                                             VerticalAlignment="Center"
                                                             Cursor="IBeam"/>
                                                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                            Command="{Binding CopyInstallCommandCommand}"
                                                            Style="{StaticResource GhostButton}"
                                                            Padding="5,4" ToolTip="Copiar comando">
                                                        <Grid Width="13" Height="13">
                                                            <Path Data="{StaticResource CopyIcon}"
                                                                  Width="13" Height="13" Stretch="Uniform"
                                                                  Fill="{DynamicResource SubtextBrush}">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCopied}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                            <Path Data="{StaticResource CheckIcon}"
                                                                  Width="13" Height="13" Stretch="Uniform"
                                                                  Fill="Transparent"
                                                                  StrokeThickness="2.5" Stroke="{DynamicResource AccentGreenBrush}"
                                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCopied}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </Grid>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- Campo API Key (só para OpenRouter) -->
                                            <StackPanel Margin="0,10,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RequiresApiKey}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="API Key" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                                <PasswordBox Style="{StaticResource DarkPasswordBox}"
                                                             helpers:PasswordBoxHelper.BoundPassword="{Binding DataContext.OpenRouterApiKey, RelativeSource={RelativeSource AncestorType=ItemsControl}, Mode=TwoWay}"
                                                             Tag="sk-or-..."/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Botão verificar novamente -->
                        <Button Command="{Binding DetectAiToolsCommand}" HorizontalAlignment="Left"
                                Margin="0,4,0,0" Padding="16,8" Style="{StaticResource GhostButton}"
                                FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x21BB;  " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Verificar Novamente" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ─── AI Orb Widget ──────────────────────────────── -->
                        <TextBlock Text="AI Orb" Style="{StaticResource SubheadingText}"
                                   Margin="0,24,0,8" FontSize="13" />

                        <!-- Toggle: Exibir AI Orb -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Exibir AI Orb" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Widget flutuante com ações rápidas de IA" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsAiOrbEnabled}"/>
                            </Grid>
                        </Border>

                        <!-- Toggle: Travar posição -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Travar posição" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                                    <TextBlock Text="Impede arrastar o orb para outra posição" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsAiOrbPositionLocked}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 5: NOTIFICAÇÕES
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Notificações">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Notificações" Style="{StaticResource SubheadingText}" Margin="0,0,0,16" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Notificações ativas" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                        <TextBlock Text="Habilita ou desabilita todas as notificações do sistema" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotificationsEnabled}" />
                                </Grid>
                            </Border>
                            <TextBlock Text="FONTES DE NOTIFICAÇÃO" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,8" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="0" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Terminal" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyTerminalEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Git" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyGitEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Processos" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyProcessEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Assistente IA" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifyAiEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Sistema" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotifySystemEvents}" IsEnabled="{Binding NotificationsEnabled}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Som de notificação" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                        <TextBlock Text="Reproduz um som ao receber notificações" Style="{StaticResource CaptionText}" Opacity="0.6" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding NotificationSoundEnabled}" IsEnabled="{Binding NotificationsEnabled}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB: WIDGETS (catálogo)
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Widgets">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header + actions -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Catálogo de Widgets" Style="{StaticResource SubheadingText}" Margin="0,0,0,4"/>
                                <TextBlock Text="Ative ou desative widgets para controlar o que aparece nos menus de adição. Widgets Core não podem ser desativados."
                                           Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Ativar Todos"
                                        Command="{Binding WidgetCatalog.EnableAllCommand}"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource GhostButton}"/>
                                <Button Content="Redefinir"
                                        Command="{Binding WidgetCatalog.ResetDefaultsCommand}"
                                        Style="{StaticResource GhostButton}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Filter bar -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource Surface0Brush}"
                                CornerRadius="8" Padding="10,0" BorderThickness="1"
                                BorderBrush="{DynamicResource Surface1Brush}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{DynamicResource SubtextBrush}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding WidgetCatalog.FilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Height="32" FontSize="13"
                                         Foreground="{DynamicResource TextBrush}"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         VerticalContentAlignment="Center">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock x:Name="ph" Text="Buscar widget..."
                                                                       VerticalAlignment="Center" FontSize="13"
                                                                       Foreground="{DynamicResource SubtextBrush}"
                                                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding WidgetCatalog.Categories}"
                                  SelectedItem="{Binding WidgetCatalog.SelectedCategory}"
                                  Style="{StaticResource DarkComboBox}" Height="32"/>
                    </Grid>

                    <!-- Widget cards grid -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding WidgetCatalog.Entries}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="240" Margin="0,0,12,12" CornerRadius="10"
                                            BorderThickness="1" Padding="14,12">
                                        <Border.Background>
                                            <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.8"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Icon + toggle -->
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Colored icon badge -->
                                                <Border Grid.Column="0" Width="36" Height="36"
                                                        CornerRadius="9" Margin="0,0,10,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding AccentColor, Converter={StaticResource StringToImageSource}}"
                                                                         Opacity="0.22"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Icon}" FontSize="18"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Name + category -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="{Binding Category}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SubtextBrush}"/>
                                                </StackPanel>

                                                <!-- Toggle switch -->
                                                <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                                          IsEnabled="{Binding IsCore, Converter={StaticResource BoolToVis}}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SubtextBrush}"
                                                       Margin="0,0,0,6"/>

                                            <!-- Preview hint -->
                                            <Border Grid.Row="2" Background="{DynamicResource Surface1Brush}"
                                                    CornerRadius="5" Padding="6,3" Margin="0,0,0,0"
                                                    Visibility="{Binding PreviewHint, Converter={StaticResource StringToVis}}">
                                                <TextBlock Text="{Binding PreviewHint}"
                                                           FontSize="10" FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>

                                            <!-- Core badge -->
                                            <Border Grid.Row="3" Margin="0,6,0,0"
                                                    Visibility="{Binding IsCore, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="🔒 Core (sempre ativo)"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtextBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB: TEMPLATES IA
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Templates IA">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Prompt Templates" Style="{StaticResource SubheadingText}" Margin="0,0,0,4"/>
                            <TextBlock Text="Templates pré-criados com campos dinâmicos. Use o botão 📝 no chat para acessá-los rapidamente."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PromptTemplatePicker.Templates}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220" Margin="0,0,12,12" CornerRadius="10"
                                            BorderThickness="1" Padding="12,10">
                                        <Border.Background>
                                            <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.8"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="{Binding Category}" FontSize="10"
                                                               Foreground="{DynamicResource SubtextBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       TextWrapping="Wrap" Foreground="{DynamicResource SubtextBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock FontSize="10" Foreground="{DynamicResource SubtextBrush}">
                                                <Run Text="{Binding Fields.Count, Mode=OneWay}"/>
                                                <Run Text=" campos dinâmicos"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 TAB 6: SOBRE
                 ═══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource SettingsTabItem}" Header="Sobre">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0" Padding="0,0,8,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Sobre" Style="{StaticResource SubheadingText}" Margin="0,0,0,16" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="10" Padding="20,18" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="42" Height="42" CornerRadius="10" Background="{DynamicResource AccentBrush}" Margin="0,0,14,0">
                                            <TextBlock Text="DW" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Command Deck" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Border CornerRadius="4" Padding="8,2" Background="{DynamicResource AccentBrush}" Margin="0,0,8,0">
                                                    <TextBlock VerticalAlignment="Center">
                                                        <Run Text="v" FontWeight="SemiBold" Foreground="White" />
                                                        <Run Text="{Binding AppVersion, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" Foreground="White" />
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="MIT License" Style="{StaticResource CaptionText}" Opacity="0.5" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Terminal manager e dashboard de desenvolvimento para Windows." Style="{StaticResource BodyText}" TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="INFORMAÇÕES" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,8" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="0" Margin="0,0,0,20">
                                <StackPanel>
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Dev" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Rony Oliveira" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Repo" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.931.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                                                  Fill="{DynamicResource SubtextBrush}" Width="13" Height="13"
                                                  Stretch="Uniform" Margin="0,0,6,0" Opacity="0.7" />
                                            <TextBlock Style="{StaticResource BodyText}" FontFamily="{StaticResource MonoFont}" FontSize="12">
                                                <Hyperlink NavigateUri="https://github.com/ronydrop/dev-workspace-hub"
                                                           RequestNavigate="OnLinkNavigate"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           TextDecorations="None">github.com/ronydrop/dev-workspace-hub</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource Surface1Brush}" Opacity="0.4" Margin="16,0" />
                                    <Grid Margin="16,12"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Stack" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text=".NET 8 + WPF + CommunityToolkit.Mvvm" Style="{StaticResource BodyText}" FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="ATUALIZAÇÕES" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{DynamicResource SubtextBrush}" Opacity="0.7" FontSize="10" Margin="4,0,0,8" />
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8" Padding="16,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Style="{StaticResource AccentButton}" Content="Verificar Atualizações" Command="{Binding CheckForUpdateCommand}" Padding="16,8" FontSize="13" Margin="0,0,10,0" />
                                        <Button Style="{StaticResource GhostButton}" Content="Baixar Atualização" Command="{Binding OpenUpdatePageCommand}" Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}" Padding="16,8" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UpdateStatusText}" Style="{StaticResource CaptionText}" Opacity="0.6" Visibility="{Binding UpdateStatusText, Converter={StaticResource NullToVis}}" />
                                </StackPanel>
                            </Border>
                            <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                                <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionText}" Opacity="0.75" FontSize="13">
                                    <Run Text="Command Deck " /><Run Text="{Binding AppVersion, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" FontWeight="SemiBold" />
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionText}" Opacity="0.55" FontSize="12" Margin="0,4,0,0">
                                    <Run Text="Desenvolvido por " /><Run Text="Rony Oliveira" FontWeight="Bold" />
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center" FontSize="12" Margin="0,3,0,0">
                                    <Hyperlink NavigateUri="https://www.instagram.com/rony_drop/"
                                               RequestNavigate="OnLinkNavigate"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextDecorations="None">@rony_drop</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- BOTÕES DE AÇÃO -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource GhostButton}" Content="Restaurar Padrões" Command="{Binding ResetDefaultsCommand}" Padding="16,8" Margin="0,0,8,0" />
            <Button Style="{StaticResource GhostButton}" Content="Cancelar" Command="{Binding CancelCommand}" Padding="16,8" Margin="0,0,8,0" />
            <Button Style="{StaticResource AccentButton}" Content="Salvar" Command="{Binding SaveCommand}" Padding="24,8" />
        </StackPanel>
    </Grid>

    <!-- ─── Overlay de captura de atalho ─────────────────────────── -->
    <Grid x:Name="ShortcutCaptureOverlay"
          Visibility="Collapsed"
          Background="#B0000000"
          Panel.ZIndex="100"
          Focusable="True"
          PreviewKeyDown="OnCapturePreviewKeyDown">
        <Border Background="{DynamicResource Surface1Brush}"
                CornerRadius="16"
                Padding="40,32"
                Width="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="0" Opacity="0.55"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="EDITAR ATALHO"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Center" Opacity="0.6"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="CaptureActionLabel"
                           Text="Atalho"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Área de exibição das teclas -->
                <Border x:Name="CaptureKeyDisplay"
                        Background="{DynamicResource Surface0Brush}"
                        CornerRadius="10" Padding="24,18"
                        MinWidth="300"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <Grid>
                        <TextBlock x:Name="CaptureKeysText"
                                   Text="Aguardando teclas..."
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center"/>
                        <!-- Badge de sucesso -->
                        <Border x:Name="CaptureSuccessBadge"
                                Background="{DynamicResource AccentGreenBrush}"
                                CornerRadius="10" Padding="10,3"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-10,-10,0"
                                Visibility="Collapsed">
                            <TextBlock Text="✓" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Text="Pressione a combinação desejada  ·  ESC para cancelar"
                           FontSize="12"
                           Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Center"
                           Opacity="0.55"
                           Margin="0,0,0,28"/>

                <Button Content="Cancelar"
                        Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Center"
                        Padding="24,8"
                        Click="OnCancelCapture"/>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</UserControl>
