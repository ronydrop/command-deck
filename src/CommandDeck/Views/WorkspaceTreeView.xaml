<UserControl x:Class="CommandDeck.Views.WorkspaceTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:models="clr-namespace:CommandDeck.Models"
             mc:Ignorable="d"
             d:DesignWidth="280" d:DesignHeight="250">

    <UserControl.Resources>

        <!-- Converters (local instances — same classes as in MainWindow.Resources) -->
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter  x:Key="NullToVis"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
        <conv:HexColorToBrushConverter   x:Key="HexToBrush"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <!-- ═══════════════════════════════════════════════════════════════
             SHARED NODE VISUAL TEMPLATE
             Used by both the hierarchical TreeView and the flat search ListBox.
             DataContext for this template is WorkspaceTreeNodeViewModel.
             ═══════════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="NodeVisualTemplate"
                      DataType="{x:Type vm:WorkspaceTreeNodeViewModel}">
            <Grid Margin="0,1"
                  Cursor="Hand"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Renomear"
                                  Command="{Binding PlacementTarget.Tag.StartRenameNodeCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Alterar Cor">
                            <MenuItem Header="Roxo"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#CBA6F7">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#CBA6F7"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Azul"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#89B4FA">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#89B4FA"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Verde"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#A6E3A1">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#A6E3A1"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Amarelo"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#F9E2AF">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#F9E2AF"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Laranja"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#FAB387">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#FAB387"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Rosa"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#F38BA8">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#F38BA8"/></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Ciano"
                                      Command="{Binding PlacementTarget.Tag.ChangeNodeColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="#89DCEB">
                                <MenuItem.Icon><Border Width="12" Height="12" CornerRadius="2" Background="#89DCEB"/></MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Excluir"
                                  Command="{Binding PlacementTarget.Tag.DeleteSelectedCommand,
                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <!-- Col 0: chevron slot (always 16 px so items stay aligned) -->
                    <ColumnDefinition Width="16"/>
                    <!-- Col 1: small gap -->
                    <ColumnDefinition Width="5"/>
                    <!-- Col 2: color badge (3 px wide) -->
                    <ColumnDefinition Width="3"/>
                    <!-- Col 3: gap -->
                    <ColumnDefinition Width="5"/>
                    <!-- Col 4: type icon -->
                    <ColumnDefinition Width="14"/>
                    <!-- Col 5: gap -->
                    <ColumnDefinition Width="5"/>
                    <!-- Col 6: name + caption -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Chevron: visible only when the node has children ── -->
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Padding="0"
                        Width="16" Height="16"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Command="{Binding ToggleExpandCommand}"
                        Visibility="{Binding Children.Count,
                                             Converter={StaticResource CountToVis}}">
                    <Path Width="9" Height="9"
                          Stretch="Uniform"
                          StrokeThickness="2"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Stroke="{DynamicResource SubtextBrush}">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Data" Value="{StaticResource ChevronRightIcon}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="Data" Value="{StaticResource ChevronDownIcon}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>

                <!-- ── Color badge: 3 × 14 px ── -->
                <Border Grid.Column="2"
                        Width="3" Height="14"
                        CornerRadius="2"
                        VerticalAlignment="Center"
                        Background="{Binding Color, Converter={StaticResource HexToBrush}}"/>

                <!-- ── Type icon (driven by NodeType via DataTrigger) ── -->
                <Path Grid.Column="4"
                      Width="14" Height="14"
                      Stretch="Uniform"
                      StrokeThickness="1.5"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      VerticalAlignment="Center">
                    <Path.Style>
                        <Style TargetType="Path">
                            <!-- Default: Group → FolderIcon, SubtextBrush -->
                            <Setter Property="Stroke" Value="{DynamicResource SubtextBrush}"/>
                            <Setter Property="Data"   Value="{StaticResource FolderIcon}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NodeType}"
                                             Value="{x:Static models:WorkspaceNodeType.Project}">
                                    <Setter Property="Data"   Value="{StaticResource FolderIcon}"/>
                                    <Setter Property="Stroke" Value="{DynamicResource AccentYellowBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NodeType}"
                                             Value="{x:Static models:WorkspaceNodeType.Terminal}">
                                    <Setter Property="Data"   Value="{StaticResource TerminalIcon}"/>
                                    <Setter Property="Stroke" Value="{DynamicResource AccentGreenBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>

                <!-- ── Name + type caption (hidden when editing) ── -->
                <StackPanel Grid.Column="6"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding Name}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding NodeType}"
                               Style="{StaticResource CaptionText}"
                               FontSize="10"
                               Margin="0,1,0,0"/>
                </StackPanel>
                <!-- ── Inline rename TextBox (visible when editing) ── -->
                <TextBox Grid.Column="6"
                         x:Name="NodeRenameTextBox"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" Padding="2,1" VerticalAlignment="Center"
                         KeyDown="NodeRenameTextBox_KeyDown"
                         LostFocus="NodeRenameTextBox_LostFocus"
                         Loaded="NodeRenameTextBox_Loaded">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </DataTemplate>

        <!-- ═══════════════════════════════════════════════════════════════
             TREEVIEWITEM STYLE
             - Removes native connection lines, expand toggle and focus rect
             - Provides hover (Surface0) and selected (Surface1) backgrounds
             - Indents children by 16 px
             - Binds IsExpanded TwoWay so the chevron button drives expansion
             - Self-references ItemContainerStyle so every nesting level inherits
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="WorkspaceTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding"                   Value="4,2"/>
            <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="IsExpanded"                Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <!-- Recursively apply this same style to all child containers -->
            <Setter Property="ItemContainerStyle" Value="{DynamicResource WorkspaceTreeItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- Row that holds the node content -->
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="4"
                                    Margin="2,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Stretch"/>
                            </Border>

                            <!-- Children (collapsed when IsExpanded = false) -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="16,0,0,0"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <!-- Hide children when collapsed -->
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Hover (only when not already selected) -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource Surface0Brush}"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                            <!-- Selected -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Surface1Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
             LISTBOXITEM STYLE (flat search results)
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="SearchResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding"          Value="4,2"/>
            <Setter Property="Margin"           Value="2,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource Surface0Brush}"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Surface1Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         MAIN LAYOUT
         ═══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ══════════════════════════════════════════════════════════
             EMPTY STATE (shown when no nodes exist)
             ══════════════════════════════════════════════════════════ -->
        <StackPanel HorizontalAlignment="Center"
                    Margin="16,12">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RootNodes.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Path Data="{StaticResource FolderIcon}"
                  Stroke="{DynamicResource Overlay0Brush}"
                  StrokeThickness="1.5"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Stretch="Uniform"
                  Width="28" Height="28"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,8"/>
            <TextBlock Text="Workspace vazio"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Adicione grupos e projetos"
                       Style="{StaticResource CaptionText}"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,8"/>
            <Button Style="{StaticResource GhostButton}"
                    Command="{Binding AddGroupCommand}"
                    HorizontalAlignment="Center"
                    Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource PlusIcon}"
                          Style="{StaticResource IconPathSmall}"
                          Margin="0,0,6,0"/>
                    <TextBlock Text="Adicionar Grupo"
                               FontSize="12"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <TreeView x:Name="HierarchyTree"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="4,0,4,4"
                  FocusVisualStyle="{x:Null}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ItemsSource="{Binding RootNodes}"
                  ItemContainerStyle="{StaticResource WorkspaceTreeItemStyle}"
                  SelectedItemChanged="HierarchyTree_SelectedItemChanged"
                  MouseDoubleClick="HierarchyTree_MouseDoubleClick">
            <TreeView.Style>
                <Style TargetType="TreeView">
                    <Setter Property="Visibility" Value="{Binding RootNodes.Count, Converter={StaticResource CountToVis}}"/>
                </Style>
            </TreeView.Style>
            <TreeView.ItemTemplate>
                <!--
                    HierarchicalDataTemplate:
                    - ItemsSource feeds the children to the nested TreeViewItems
                    - ContentControl re-uses the shared NodeVisualTemplate
                -->
                <HierarchicalDataTemplate DataType="{x:Type vm:WorkspaceTreeNodeViewModel}"
                                          ItemsSource="{Binding Children}">
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource NodeVisualTemplate}"
                                    Focusable="False"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>


    </Grid>
</UserControl>
