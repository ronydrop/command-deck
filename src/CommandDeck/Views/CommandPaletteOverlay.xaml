<ctrl:SearchOverlayControlBase x:Class="CommandDeck.Views.CommandPaletteOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type vm:CommandPaletteViewModel}}"
             Focusable="True"
             KeyDown="OnKeyDown">
    <ctrl:SearchOverlayControlBase.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </ctrl:SearchOverlayControlBase.Resources>

    <!-- Full-screen dim overlay — click outside to close -->
    <Grid>
        <Rectangle Fill="#000000" Opacity="0.55"
                   MouseDown="OnDimLayerClick" />

        <!-- Palette panel — centred, fixed width -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,80,0,0"
                Width="560"
                MaxHeight="420"
                CornerRadius="10"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource Surface1Brush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Search box -->
                    <RowDefinition Height="48" />
                    <!-- Separator -->
                    <RowDefinition Height="1" />
                    <!-- Results -->
                    <RowDefinition Height="*" />
                    <!-- Footer hint -->
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>

                <!-- ── Search input ── -->
                <Grid Grid.Row="0" Margin="12,0">
                    <Path Data="{StaticResource SearchIcon}"
                          Stroke="{DynamicResource SubtextBrush}"
                          StrokeThickness="1.5"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="16" Height="16"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center" />
                    <TextBox x:Name="SearchBox"
                             Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="{DynamicResource TextBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             BorderThickness="0"
                             FontSize="15"
                             Padding="34,0,0,0"
                             IsUndoEnabled="False"
                             SelectionBrush="{DynamicResource AccentBrush}">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Focusable="False"
                                                  Margin="0"
                                                  Padding="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden" />
                                </Border>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>
                    <TextBlock Text="Pesquisar comandos..."
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="15"
                               Padding="34,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Query}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- ── Separator ── -->
                <Rectangle Grid.Row="1" Fill="{DynamicResource Surface1Brush}" />

                <!-- ── Results list ── -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ItemBg"
                                        Padding="12,8"
                                        Cursor="Hand"
                                        MouseDown="OnResultClick"
                                        CornerRadius="6"
                                        Margin="6,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.SelectedResult,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                             Value="{Binding}">
                                                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <DockPanel>
                        <!-- Icon -->
                        <Border DockPanel.Dock="Left"
                                Width="28" Height="28"
                                CornerRadius="6"
                                Background="{DynamicResource Surface1Brush}"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="›"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                                        <!-- Shortcut badge (right) -->
                                        <Border DockPanel.Dock="Right"
                                                Background="{DynamicResource Surface1Brush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"
                                                        Visibility="{Binding ShortcutHint,
                                                    Converter={StaticResource NullToVis}}">
                                            <TextBlock Text="{Binding ShortcutHint}"
                                                       Style="{StaticResource CaptionText}"
                                                       FontFamily="{StaticResource MonoFont}" />
                                        </Border>

                                        <!-- Title + subtitle -->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextBrush}" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SubtextBrush}"
                                                       Margin="0,1,0,0"
                                                       Opacity="0.8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Subtitle}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── Footer ── -->
                <Border Grid.Row="3"
                        Background="{DynamicResource MantelBgBrush}"
                        CornerRadius="0,0,10,10"
                        Padding="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="↑↓ navegar" Style="{StaticResource CaptionText}" Margin="0,0,12,0" />
                        <TextBlock Text="↵ executar" Style="{StaticResource CaptionText}" Margin="0,0,12,0" />
                        <TextBlock Text="ESC fechar"  Style="{StaticResource CaptionText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ctrl:SearchOverlayControlBase>
