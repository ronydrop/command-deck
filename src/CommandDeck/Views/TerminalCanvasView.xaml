<UserControl x:Class="CommandDeck.Views.TerminalCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             Background="{DynamicResource BaseBgBrush}"
             Loaded="OnLoaded"
             KeyDown="OnKeyDown">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter     x:Key="BoolToVis" />
        <conv:CountToVisibilityConverter x:Key="EmptyVisConverter" />
        <conv:ShellTypeToIconConverter      x:Key="ShellIconConverter" />
        <conv:CanvasItemTypeIconConverter   x:Key="ItemTypeIconConverter" />
        <conv:FirstLetterConverter          x:Key="FirstLetterConverter" />
        <conv:ZoomLevelConverter            x:Key="ZoomLevelConverter" />
        <conv:LayoutModeToVisibilityConverter x:Key="LayoutModeToVis" />
    </UserControl.Resources>

    <!-- Root: toolbar (top) + workspace area (bottom) -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             TOOLBAR — premium with grouped separators and smart zoom badge
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource GlassToolbarBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <!-- Mirror the sidebar column width so the right group aligns with the terminal panel edge -->
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="220" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsTerminalPanelVisible,
                                                 RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="False">
                                        <Setter Property="Width" Value="28" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="10,0">

                <!-- ── RIGHT GROUP: zoom badge + exit-focus + Open + Commit ── -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Exit focus mode button (collapsed by default) -->
                    <Button x:Name="BtnVerTodos"
                            Style="{StaticResource GhostButton}"
                            Padding="10,4"
                            Margin="4,0"
                            Visibility="Collapsed"
                            Click="OnVerTodosClick"
                            ToolTip="Voltar à visão geral (ESC)">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M 2 2 L 10 2 L 10 10 L 2 10 Z M 14 2 L 22 2 L 22 10 L 14 10 Z M 2 14 L 10 14 L 10 22 L 2 22 Z M 14 14 L 22 14 L 22 22 L 14 22 Z"
                                  Stroke="{DynamicResource SubtextBrush}"
                                  Fill="Transparent"
                                  StrokeThickness="1.5"
                                  Width="12" Height="12"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0" />
                            <TextBlock Text="Ver Todos"
                                       Style="{StaticResource BodyText}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Toggle terminal panel button (visible when panel is hidden) -->
                    <Button Style="{StaticResource GhostButton}"
                            Padding="6,4"
                            Margin="4,0"
                            Command="{Binding DataContext.ToggleTerminalPanelCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Mostrar painel de terminais"
                            Visibility="{Binding DataContext.IsTerminalPanelVisible,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource BoolToVis},
                                         ConverterParameter=Invert}">
                        <Path Data="{StaticResource TerminalIcon}"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <!-- Vertical separator before zoom badge (hidden in tiled mode) -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="6,0"
                               Visibility="{Binding CanvasViewModel.IsCanvasMode, Converter={StaticResource BoolToVis}}" />

                    <!-- Zoom badge — hidden in tiled mode -->
                    <Border x:Name="ZoomBadge"
                            Visibility="{Binding CanvasViewModel.IsCanvasMode, Converter={StaticResource BoolToVis}}"
                            CornerRadius="4"
                            Padding="8,3"
                            Margin="4,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- Default: Surface0 neutral -->
                                <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                <Style.Triggers>
                                    <!-- High zoom (> 150 %) → blue accent background -->
                                    <DataTrigger Binding="{Binding CanvasViewModel.ZoomPercent,
                                                     Converter={StaticResource ZoomLevelConverter}}"
                                                 Value="high">
                                        <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock x:Name="ZoomLabel"
                                   Text="100%"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <!-- Default colour from CaptionText (Overlay0) -->
                                    <Style.Triggers>
                                        <!-- On high zoom the badge bg is coloured → use dark text -->
                                        <DataTrigger Binding="{Binding CanvasViewModel.ZoomPercent,
                                                         Converter={StaticResource ZoomLevelConverter}}"
                                                     Value="high">
                                            <Setter Property="Foreground" Value="{DynamicResource CrustBgBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Vertical separator -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="0,0,8,0" />

                    <!-- Open split button -->
                    <Border CornerRadius="20" Background="{DynamicResource AccentBrush}"
                            ClipToBounds="True" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButtonLeft}"
                                    Command="{Binding DataContext.Dashboard.OpenInCursorCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Abrir no Cursor (Ctrl+O)">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FolderIcon}"
                                          Stroke="White" StrokeThickness="1.5"
                                          Fill="Transparent" Stretch="Uniform"
                                          Width="14" Height="14"
                                          Margin="0,0,6,0" />
                                    <TextBlock Text="Open" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Fill="White" Opacity="0.2"
                                       VerticalAlignment="Stretch" Margin="0,6" />
                            <Button x:Name="ToolbarOpenDropdownBtn"
                                    Style="{StaticResource AccentButtonRight}"
                                    Tag="{Binding DataContext.Dashboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Mais opções"
                                    Click="OnToolbarOpenDropdownClick">
                                <Path Data="{StaticResource ChevronDownIcon}"
                                      Stroke="White" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Fill="Transparent"
                                      Width="10" Height="10" Stretch="Uniform" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.OpenInCursorCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/Images/cursor.png"
                                                           Width="14" Height="14" Margin="0,0,8,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="Cursor" VerticalAlignment="Center" />
                                                    <TextBlock Text="Ctrl+O" Margin="20,0,0,0"
                                                               Foreground="{DynamicResource SubtextBrush}"
                                                               FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.OpenInVsCodeCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/Images/vscode.png"
                                                           Width="14" Height="14" Margin="0,0,8,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="VS Code" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.OpenInExplorerCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/Images/explorer.png"
                                                           Width="14" Height="14" Margin="0,0,8,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="Explorer" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Commit split button (always visible; disabled when no git info) -->
                    <Border CornerRadius="20" Background="{DynamicResource AccentGreenBrush}"
                            ClipToBounds="True" Margin="0,0,8,0" VerticalAlignment="Center"
                            IsEnabled="{Binding DataContext.Dashboard.HasGitInfo,
                                        RelativeSource={RelativeSource AncestorType=Window}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.38" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButtonLeft}"
                                    Command="{Binding DataContext.Dashboard.GitCommitCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Git Commit">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource GitBranchIcon}"
                                          Stroke="White" StrokeThickness="1.5"
                                          Fill="Transparent" Stretch="Uniform"
                                          Width="14" Height="14"
                                          Margin="0,0,6,0" />
                                    <TextBlock Text="Commit" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Fill="White" Opacity="0.2"
                                       VerticalAlignment="Stretch" Margin="0,6" />
                            <Button x:Name="ToolbarCommitDropdownBtn"
                                    Style="{StaticResource AccentButtonRight}"
                                    Tag="{Binding DataContext.Dashboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Mais opções Git"
                                    Click="OnToolbarCommitDropdownClick">
                                <Path Data="{StaticResource ChevronDownIcon}"
                                      Stroke="White" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Fill="Transparent"
                                      Width="10" Height="10" Stretch="Uniform" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.GitCommitCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource GitBranchIcon}"
                                                          Stroke="{DynamicResource TextBrush}"
                                                          StrokeThickness="1.5" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          Margin="0,0,8,0" />
                                                    <TextBlock Text="Commit" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.GitPushCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M12 19V5M12 5L5 12M12 5L19 12"
                                                          Stroke="{DynamicResource AccentGreenBrush}"
                                                          StrokeThickness="1.5" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          Margin="0,0,8,0" />
                                                    <TextBlock Text="Push" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.GitCreatePrCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M18 15L22 19L18 23M6 9L2 5L6 1M14 3L10 21"
                                                          Stroke="{DynamicResource AccentBlueBrush}"
                                                          StrokeThickness="1.5" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          Margin="0,0,8,0" />
                                                    <TextBlock Text="Create PR" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── LEFT GROUP: new terminal + title label ─────────────────── -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- ── Novo Terminal split button + AI dropdown + Layout toggle (unified group) ── -->
                    <Border CornerRadius="20" Background="{DynamicResource AccentBrush}" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal">
                            <!-- Main: new terminal -->
                            <Button Style="{StaticResource AccentButtonLeft}"
                                    Command="{Binding DataContext.NewTerminalCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Novo Terminal (Ctrl+Shift+T)">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="14" Height="14"
                                          VerticalAlignment="Center"
                                          Margin="0,0,7,0">
                                        <Path Data="M2 3 L7 7 L2 11"
                                              Stroke="White"
                                              StrokeThickness="1.8"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Stretch="None" />
                                        <Rectangle Width="5" Height="1.5"
                                                   Fill="White"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="0,2,0,0" />
                                    </Grid>
                                    <TextBlock Text="Novo Terminal"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Divisória sutil -->
                            <Rectangle Width="1" Fill="White" Opacity="0.2"
                                       VerticalAlignment="Stretch" Margin="0,6" />

                            <!-- Dropdown chevron (AI options) -->
                            <Button x:Name="AiDropdownBtn"
                                    Style="{StaticResource AccentButtonRight}"
                                    ToolTip="Abrir terminal AI"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Click="OnAiDropdownClick">
                                <Path Data="{StaticResource ChevronDownIcon}"
                                      Stroke="White"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="10" Height="10"
                                      Stretch="Uniform" />
                                <Button.ContextMenu>
                                    <ContextMenu Placement="Bottom" />
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Layout mode toggle (Canvas / Tiled) ── -->
                    <Border CornerRadius="20"
                            Margin="6,0,0,0"
                            Background="{DynamicResource Surface0Brush}"
                            BorderBrush="{DynamicResource Surface2Brush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <!-- Canvas mode button -->
                            <Button Padding="8,4"
                                    Command="{Binding CanvasViewModel.SetCanvasModeCommand}"
                                    ToolTip="Modo Canvas — layout livre (Ctrl+Shift+L)"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LayoutModeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanvasViewModel.IsCanvasMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2 2H8V8H2Z M12 2H18V8H12Z M2 12H8V18H2Z M12 14H18V18H12Z"
                                          Stroke="{DynamicResource TextBrush}"
                                          StrokeThickness="1.2"
                                          Fill="Transparent"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0" />
                                    <TextBlock Text="Canvas"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Tiled mode button -->
                            <Button Padding="8,4"
                                    Command="{Binding CanvasViewModel.SetTiledModeCommand}"
                                    ToolTip="Modo Tiled — layout em grade (Ctrl+Shift+L)"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LayoutModeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2 2H10V10H2Z M12 2H20V10H12Z M2 12H10V20H2Z M12 12H20V20H12Z"
                                          Stroke="{DynamicResource TextBrush}"
                                          StrokeThickness="1.2"
                                          Fill="Transparent"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0" />
                                    <TextBlock Text="Tiled"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Split Pane mode button -->
                            <Button Padding="8,4"
                                    Command="{Binding CanvasViewModel.SetSplitPaneModeCommand}"
                                    ToolTip="Modo Split Pane — layout binário ajustável"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LayoutModeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanvasViewModel.IsSplitPaneMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬜⬜" FontSize="9" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Split"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Bento mode button -->
                            <Button Padding="8,4"
                                    Command="{Binding CanvasViewModel.SetBentoModeCommand}"
                                    ToolTip="Modo Bento — grid 3×3 com slots e painel de blocos"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LayoutModeButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanvasViewModel.IsBentoMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2 2H8V8H2Z M10 2H16V8H10Z M18 2H22V8H18Z M2 10H8V16H2Z M18 10H22V16H18Z M2 18H8V22H2Z M10 18H16V22H10Z M18 18H22V22H18Z"
                                          Stroke="{DynamicResource TextBrush}"
                                          StrokeThickness="1.2"
                                          Fill="Transparent"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0" />
                                    <TextBlock Text="Bento"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Auto-arrange button ── -->

                    <!-- Vertical separator -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="10,0" />

                    <!-- Project name label -->
                    <TextBlock Text="{Binding DataContext.CurrentProject.Name,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     FallbackValue='Workspace'}"
                               Style="{StaticResource BodyText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Opacity="0.85" />

                    <!-- Vertical separator -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="10,0" />


                </StackPanel>
            </DockPanel>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             WORKSPACE AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Canvas viewport -->
                <ColumnDefinition Width="*" />
                <!-- Sidebar (28px collapsed strip when hidden, 220px when expanded) -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="220" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsTerminalPanelVisible,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="False">
                                    <Setter Property="Width" Value="28" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- ── Infinite canvas viewport ──────────────────────────────── -->
            <Grid Grid.Column="0"
                  x:Name="ViewportArea"
                  Background="{DynamicResource CanvasDepthBrush}"
                  ClipToBounds="True"
                  PreviewMouseDown="OnViewportPreviewMouseDown"
                  MouseDown="OnViewportMouseDown"
                  MouseMove="OnViewportMouseMove"
                  MouseUp="OnViewportMouseUp"
                  MouseLeave="OnViewportMouseLeave"
                  MouseWheel="OnViewportMouseWheel"
                  MouseRightButtonUp="OnViewportRightClick"
                  AllowDrop="True"
                  Drop="OnViewportDrop"
                  DragOver="OnViewportDragOver"
                  Cursor="Arrow">

                <Grid.ContextMenu>
                    <ContextMenu x:Name="CanvasContextMenu" Opened="OnCanvasContextMenuOpened">
                        <!-- Add tiles section — visibility controlled by Widget Catalog -->
                        <MenuItem Header="➕ Novo Terminal" Click="OnContextAddTerminal"/>
                        <MenuItem x:Name="CtxAddChat"          Header="💬 Chat IA"                   Click="OnContextAddChat"/>
                        <MenuItem x:Name="CtxAddCodeEditor"    Header="⌨ Editor de Código"            Click="OnContextAddCodeEditor"/>
                        <MenuItem x:Name="CtxAddFileExplorer"  Header="📁 Explorador de Arquivos"     Click="OnContextAddFileExplorer"/>
                        <MenuItem x:Name="CtxAddBrowser"       Header="🌐 Browser"                    Click="OnContextAddBrowser"/>
                        <MenuItem x:Name="CtxAddNote"          Header="📝 Nota"                       Click="OnContextAddNote"/>
                        <MenuItem x:Name="CtxAddGit"           Header="🌿 Git Status"                 Click="OnContextAddGit"/>
                        <MenuItem x:Name="CtxAddProcess"       Header="📊 Monitor de Processos"       Click="OnContextAddProcess"/>
                        <MenuItem x:Name="CtxAddSystemMonitor" Header="🖥 Monitor do Sistema"          Click="OnContextAddSystemMonitor"/>
                        <MenuItem x:Name="CtxAddKanban"        Header="🗂 Kanban"                     Click="OnContextAddKanban"/>
                        <MenuItem x:Name="CtxAddPomodoro"      Header="🍅 Pomodoro"                   Click="OnContextAddPomodoro"/>
                        <MenuItem x:Name="CtxAddTokenCounter"  Header="🔢 Contador de Tokens"         Click="OnContextAddTokenCounter"/>
                        <MenuItem x:Name="CtxAddActivityFeed"  Header="📋 Activity Feed"               Click="OnContextAddActivityFeed"/>
                        <Separator/>
                        <!-- Canvas actions -->
                        <MenuItem Header="🎯 Centralizar Tudo (Home)" Click="OnContextFitAll"/>
                        <MenuItem Header="📷 Capturar Canvas"         Click="OnContextCapture"/>
                        <Separator/>
                        <!-- Selection actions (only visible when items are selected) -->
                        <MenuItem x:Name="CtxDeleteSelected" Header="🗑 Excluir Selecionados"
                                  Click="OnContextDeleteSelected"/>
                        <MenuItem x:Name="CtxColorPicker"   Header="🎨 Cor do Tile"
                                  Click="OnContextColorPicker"/>
                        <MenuItem x:Name="CtxSetLabel"      Header="🏷 Renomear Tile"
                                  Click="OnContextSetLabel"/>
                        <MenuItem x:Name="CtxToggleTitlebar" Header="👁 Ocultar/Mostrar Barra"
                                  Click="OnContextToggleTitlebar"/>
                        <MenuItem x:Name="CtxConnect"        Header="🔗 Conectar Tiles"
                                  Click="OnContextConnect"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- Bento Layout Presenter — visible only in Bento mode -->
                <ctrl:BentoLayoutPresenter
                    x:Name="BentoPresenter"
                    Panel.ZIndex="10"
                    DataContext="{Binding CanvasViewModel}"
                    Visibility="{Binding LayoutMode,
                                 Converter={StaticResource LayoutModeToVis},
                                 ConverterParameter=Bento}" />

                <!-- ── Wallpaper background layer (hidden in tiled mode) ── -->
                <Image Source="{Binding CanvasViewModel.WallpaperSource}"
                       Stretch="{Binding CanvasViewModel.WallpaperStretch}"
                       Opacity="{Binding CanvasViewModel.WallpaperOpacity}"
                       Visibility="{Binding CanvasViewModel.HasWallpaper, Converter={StaticResource BoolToVis}}"
                       IsHitTestVisible="False">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- World canvas: holds all items, panned + zoomed via RenderTransform -->
                <Canvas x:Name="WorldCanvas"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        IsHitTestVisible="{Binding CanvasViewModel.HasTerminals}"
                        Visibility="{Binding CanvasViewModel.LayoutMode,
                                     Converter={StaticResource LayoutModeToVis},
                                     ConverterParameter=NotBento}">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="CanvasTranslate" X="40" Y="40" />
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- World-space dot grid — moves and scales with the canvas (pan/zoom) -->
                    <Canvas x:Name="WorldGrid"
                            Width="20000" Height="20000"
                            Canvas.Left="-10000" Canvas.Top="-10000"
                            IsHitTestVisible="False"
                            Panel.ZIndex="-1">
                        <Canvas.Style>
                            <Style TargetType="Canvas">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Canvas.Style>
                        <Canvas.Background>
                            <DrawingBrush TileMode="Tile"
                                          ViewportUnits="Absolute"
                                          Viewport="0,0,32,32">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <!-- Dot at each tile origin — color from theme token -->
                                        <GeometryDrawing Brush="{DynamicResource DotGridDotBrush}">
                                            <GeometryDrawing.Geometry>
                                                <EllipseGeometry Center="2,2" RadiusX="1.2" RadiusY="1.2" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Canvas.Background>
                    </Canvas>

                    <!-- World-space GLOW grid — same geometry as WorldGrid, painted with
                         the theme accent, then revealed only inside a cursor-following
                         OpacityMask (built in code-behind). Drawn just above WorldGrid so
                         the revealed dots overlay the gray base dots. -->
                    <Canvas x:Name="WorldGlowGrid"
                            Width="20000" Height="20000"
                            Canvas.Left="-10000" Canvas.Top="-10000"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Panel.ZIndex="-1">
                        <Canvas.Style>
                            <Style TargetType="Canvas">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Canvas.Style>
                        <Canvas.Background>
                            <DrawingBrush TileMode="Tile"
                                          ViewportUnits="Absolute"
                                          Viewport="0,0,32,32">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <!-- Glow dot at each tile origin — same positions as base grid -->
                                        <GeometryDrawing Brush="{DynamicResource DotGridGlowBrush}">
                                            <GeometryDrawing.Geometry>
                                                <EllipseGeometry Center="2,2" RadiusX="1.6" RadiusY="1.6" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Canvas.Background>
                    </Canvas>

                    <!-- ItemsControl: binds to TerminalCanvasViewModel.Items
                         Each item is positioned absolutely via Canvas.Left/Top bindings -->
                    <ItemsControl x:Name="ItemsHost"
                                  ItemsSource="{Binding CanvasViewModel.Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="{Binding Y}" />
                                <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                <Setter Property="Width"  Value="{Binding Width}" />
                                <Setter Property="Height" Value="{Binding Height}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ctrl:CanvasCardControl
                                    CardCloseRequested="OnCardCloseRequested"
                                    CardFocusRequested="OnCardFocusRequested"
                                    CardActivated="OnCardActivated"
                                    AiActionRequested="OnAiActionRequested" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bézier connection overlay — rendered above tiles, no hit-testing -->
                    <ctrl:CanvasConnectionOverlay
                        x:Name="ConnectionOverlay"
                        IsHitTestVisible="False"
                        Panel.ZIndex="50"
                        Width="10000" Height="10000"
                        Canvas.Left="-5000" Canvas.Top="-5000" />

                </Canvas>

                <!-- Rubber-band selection rectangle (viewport-space, drawn above cards) -->
                <Canvas x:Name="SelectionCanvas"
                        IsHitTestVisible="False"
                        Panel.ZIndex="99">
                    <Rectangle x:Name="SelectionRect"
                               Stroke="{DynamicResource AccentBrush}"
                               StrokeThickness="1.5"
                               StrokeDashArray="5 3"
                               Fill="#2200A8E0"
                               Visibility="Collapsed" />

                    <!-- Horizontal alignment guide (appears during drag when aligned with another item's edge) -->
                    <Line x:Name="AlignGuideH"
                          X1="0" Y1="0" X2="10000" Y2="0"
                          Stroke="{DynamicResource AccentBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="4 3"
                          Opacity="0.7"
                          Visibility="Collapsed" />

                    <!-- Vertical alignment guide -->
                    <Line x:Name="AlignGuideV"
                          X1="0" Y1="0" X2="0" Y2="10000"
                          Stroke="{DynamicResource AccentBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="4 3"
                          Opacity="0.7"
                          Visibility="Collapsed" />
                </Canvas>

                <!-- Mini-map overlay -->
                <ctrl:MiniMapControl
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    Panel.ZIndex="100"
                    DataContext="{Binding CanvasViewModel.MiniMap}"
                    HasTerminals="{Binding DataContext.CanvasViewModel.HasTerminals,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />

                <!-- ── Arrange Toolbar — floats top-center when ≥2 items selected ── -->
                <Border x:Name="ArrangeToolbar"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,10,0,0"
                        Panel.ZIndex="110"
                        CornerRadius="8"
                        Padding="6,4"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface0}" Opacity="0.96"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource Surface2}" Opacity="0.6"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.35" Color="#000000"/>
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanvasViewModel.SelectedCount}"
                                             Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel Orientation="Horizontal">
                        <!-- Selection count badge -->
                        <Border Background="#30C5F467" CornerRadius="4" Padding="5,1" Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="{DynamicResource SubtextBrush}">
                                <Run Text="{Binding CanvasViewModel.SelectedCount, Mode=OneWay}"/>
                                <Run Text=" selecionados"/>
                            </TextBlock>
                        </Border>

                        <!-- Separator -->
                        <Separator Width="1" Margin="2,2" Background="{DynamicResource Surface2Brush}"/>

                        <!-- Align Left -->
                        <Button Content="⬤◻◻" ToolTip="Alinhar à esquerda"
                                Command="{Binding CanvasViewModel.AlignLeftCommand}"
                                Width="28" Height="24" FontSize="9" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Align Right -->
                        <Button Content="◻◻⬤" ToolTip="Alinhar à direita"
                                Command="{Binding CanvasViewModel.AlignRightCommand}"
                                Width="28" Height="24" FontSize="9" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Align Top -->
                        <Button Content="⬛" ToolTip="Alinhar ao topo"
                                Command="{Binding CanvasViewModel.AlignTopCommand}"
                                Width="28" Height="24" FontSize="10" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Align Bottom -->
                        <Button Content="⬛" ToolTip="Alinhar à base"
                                Command="{Binding CanvasViewModel.AlignBottomCommand}"
                                Width="28" Height="24" FontSize="10" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Center H -->
                        <Button Content="↕" ToolTip="Centralizar verticalmente"
                                Command="{Binding CanvasViewModel.AlignCenterHCommand}"
                                Width="28" Height="24" FontSize="14" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Center V -->
                        <Button Content="↔" ToolTip="Centralizar horizontalmente"
                                Command="{Binding CanvasViewModel.AlignCenterVCommand}"
                                Width="28" Height="24" FontSize="14" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>

                        <Separator Width="1" Margin="2,2" Background="{DynamicResource Surface2Brush}"/>

                        <!-- Distribute H -->
                        <Button Content="⇹" ToolTip="Distribuir horizontalmente"
                                Command="{Binding CanvasViewModel.DistributeHCommand}"
                                Width="28" Height="24" FontSize="13" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Distribute V -->
                        <Button Content="⇳" ToolTip="Distribuir verticalmente"
                                Command="{Binding CanvasViewModel.DistributeVCommand}"
                                Width="28" Height="24" FontSize="13" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>

                        <Separator Width="1" Margin="2,2" Background="{DynamicResource Surface2Brush}"/>

                        <!-- Equalize Width -->
                        <Button Content="↔=" ToolTip="Igualar largura"
                                Command="{Binding CanvasViewModel.EqualizeWidthCommand}"
                                Width="30" Height="24" FontSize="10" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                        <!-- Equalize Height -->
                        <Button Content="↕=" ToolTip="Igualar altura"
                                Command="{Binding CanvasViewModel.EqualizeHeightCommand}"
                                Width="30" Height="24" FontSize="10" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>

                        <Separator Width="1" Margin="2,2" Background="{DynamicResource Surface2Brush}"/>

                        <!-- Deselect all -->
                        <Button Content="✕" ToolTip="Desselecionar tudo (Esc)"
                                Click="OnClearSelectionClick"
                                Width="24" Height="24" FontSize="10" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Lock overlay: covers canvas when no terminals exist, blocks interaction -->
                <Border x:Name="CanvasLockOverlay"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0" />
                            <Setter Property="IsHitTestVisible" Value="False" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanvasViewModel.HasTerminals}" Value="False">
                                    <Setter Property="IsHitTestVisible" Value="True" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <!-- Overlay background -->
                        <Rectangle>
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{DynamicResource CrustBg}" Opacity="0.88" />
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Subtle diagonal stripe pattern: signals "restricted area" -->
                        <Rectangle Opacity="0.04">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile"
                                              Viewport="0,0,20,20"
                                              ViewportUnits="Absolute"
                                              Viewbox="0,0,20,20"
                                              ViewboxUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="White" Thickness="1" />
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <LineGeometry StartPoint="0,20" EndPoint="20,0" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Centered content -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Lock icon: primary signal -->
                            <Path Data="{StaticResource LockIcon}"
                                  Width="48" Height="48"
                                  Stroke="{DynamicResource Surface2Brush}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  Opacity="0.7"
                                  Margin="0,0,0,12" />

                            <!-- Terminal icon: secondary hint -->
                            <Path Data="{StaticResource TerminalIcon}"
                                  Style="{StaticResource IconPath}"
                                  Width="24" Height="24"
                                  Stroke="{DynamicResource Overlay0Brush}"
                                  HorizontalAlignment="Center"
                                  Opacity="0.5"
                                  Margin="0,0,0,20" />

                            <TextBlock Text="Nenhum terminal aberto"
                                       Style="{StaticResource SubheadingText}"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource Overlay0Brush}" />

                            <TextBlock Text="Clique em &quot;Novo Terminal&quot; ou pressione Ctrl+Shift+T"
                                       Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Focus overlay (semi-transparent black, shown in focus mode) -->
                <Rectangle x:Name="FocusOverlay"
                           Fill="#000000"
                           Opacity="0"
                           IsHitTestVisible="False" />
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 RIGHT SIDEBAR — premium with avatar, accent indicator,
                 rounded items and hover transitions
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource GlassSidebarBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>

                    <!-- ── COLLAPSED STRIP (visible when panel is hidden) ── -->
                    <Border Visibility="{Binding DataContext.IsTerminalPanelVisible,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={StaticResource BoolToVis},
                                        ConverterParameter=Invert}"
                            Background="Transparent"
                            Cursor="Hand"
                            ToolTip="Mostrar painel de chats (Ctrl+Shift+B)">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.ToggleTerminalPanelCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}" />
                        </Border.InputBindings>
                        <Button Style="{StaticResource GhostButton}"
                                Padding="0"
                                Width="20" Height="20"
                                VerticalAlignment="Top"
                                Margin="4,10,0,0"
                                Command="{Binding DataContext.ToggleTerminalPanelCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="Mostrar painel de chats">
                            <Path Data="M 7 1 L 3 5 L 7 9"
                                  Stroke="{DynamicResource SubtextBrush}"
                                  StrokeThickness="1.5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Width="8" Height="10"
                                  Stretch="Uniform" />
                        </Button>
                    </Border>

                    <!-- ── EXPANDED CONTENT ── -->
                    <DockPanel Visibility="{Binding DataContext.IsTerminalPanelVisible,
                                           RelativeSource={RelativeSource AncestorType=Window},
                                           Converter={StaticResource BoolToVis}}">

                    <!-- ── Sidebar header with icon + label + collapse button ──── -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,7">
                        <DockPanel>
                            <!-- Collapse button (right) -->
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource GhostButton}"
                                    Padding="2"
                                    Width="20" Height="20"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.ToggleTerminalPanelCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Ocultar painel (Ctrl+Shift+B)">
                                <Path Data="M 3 1 L 7 5 L 3 9"
                                      Stroke="{DynamicResource SubtextBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="8" Height="10"
                                      Stretch="Uniform" />
                            </Button>
                            <!-- Icon + label (left) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource ChatIcon}"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center"
                                      Margin="0,0,7,0" />
                                <TextBlock Text="Chats"
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ── Chat list ──────────────────────────────────────────────── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="6,4">
                        <ItemsControl ItemsSource="{Binding CanvasViewModel.ChatItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Outer container holds accent bar + item body -->
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <!-- 3 px accent bar (left) -->
                                            <ColumnDefinition Width="3" />
                                            <!-- Item body -->
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Accent indicator bar (visible only when IsSelected) -->
                                        <Rectangle Grid.Column="0"
                                                   RadiusX="2" RadiusY="2"
                                                   Fill="{DynamicResource AccentBrush}">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Item body -->
                                        <Border Grid.Column="1"
                                                x:Name="ChatSidebarItem"
                                                CornerRadius="6"
                                                Padding="8,6"
                                                Margin="3,0,0,0"
                                                Cursor="Hand"
                                                MouseDown="OnSidebarChatItemClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{DynamicResource Surface0Brush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <!-- Mouse enter/leave: animate hover overlay opacity -->
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="ChatHoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="1"
                                                                Duration="0:0:0.150">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <QuadraticEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="ChatCloseBtn"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="1"
                                                                Duration="0:0:0.150" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="ChatHoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="0"
                                                                Duration="0:0:0.200">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <QuadraticEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="ChatCloseBtn"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="0"
                                                                Duration="0:0:0.200" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>

                                            <Grid>
                                                <!-- Hover background overlay -->
                                                <Border x:Name="ChatHoverOverlay"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource Surface0Brush}"
                                                        Opacity="0"
                                                        IsHitTestVisible="False"
                                                        Margin="-8,-6,-8,-6" />

                                                <DockPanel>
                                                    <!-- Close button (right-aligned, visible on hover) -->
                                                    <Button x:Name="ChatCloseBtn"
                                                            DockPanel.Dock="Right"
                                                            Style="{StaticResource GhostButton}"
                                                            Width="20" Height="20"
                                                            Padding="0"
                                                            Opacity="0"
                                                            VerticalAlignment="Center"
                                                            Margin="4,0,0,0"
                                                            ToolTip="Fechar chat"
                                                            Click="OnSidebarChatCloseClick">
                                                        <Path Data="M 3 3 L 9 9 M 9 3 L 3 9"
                                                              Stroke="{DynamicResource SubtextBrush}"
                                                              StrokeThickness="1.5"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Width="10" Height="10"
                                                              Stretch="Uniform" />
                                                    </Button>

                                                    <!-- Loading dot -->
                                                    <Ellipse DockPanel.Dock="Right"
                                                             Width="6" Height="6"
                                                             VerticalAlignment="Center"
                                                             Margin="4,0,0,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill"
                                                                        Value="{DynamicResource Surface2Brush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLoading}"
                                                                                 Value="True">
                                                                        <Setter Property="Fill"
                                                                                Value="{DynamicResource AccentBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>

                                                    <!-- Chat icon -->
                                                    <Path DockPanel.Dock="Left"
                                                          Data="{StaticResource ChatIcon}"
                                                          Stroke="{DynamicResource AccentBrush}"
                                                          StrokeThickness="1.2"
                                                          StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Fill="Transparent"
                                                          Stretch="Uniform"
                                                          Width="14" Height="14"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0" />

                                                    <!-- Title + provider -->
                                                    <StackPanel VerticalAlignment="Center"
                                                                Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding ChatTitle}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="130" />
                                                        <TextBlock Text="{Binding SelectedProviderLabel}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource SubtextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Opacity="0.7"
                                                                   MaxWidth="130"
                                                                   Margin="0,1,0,0" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
