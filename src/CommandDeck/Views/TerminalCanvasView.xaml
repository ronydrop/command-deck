<UserControl x:Class="CommandDeck.Views.TerminalCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             xmlns:ctrl="clr-namespace:CommandDeck.Controls"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             Background="{DynamicResource BaseBgBrush}"
             Loaded="OnLoaded"
             KeyDown="OnKeyDown">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter     x:Key="BoolToVis" />
        <conv:InverseCountToVisibilityConverter x:Key="EmptyVisConverter" />
        <conv:ShellTypeToIconConverter      x:Key="ShellIconConverter" />
        <conv:CanvasItemTypeIconConverter   x:Key="ItemTypeIconConverter" />
        <conv:FirstLetterConverter          x:Key="FirstLetterConverter" />
        <conv:ZoomLevelConverter            x:Key="ZoomLevelConverter" />
    </UserControl.Resources>

    <!-- Root: toolbar (top) + workspace area (bottom) -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             TOOLBAR — premium with grouped separators and smart zoom badge
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource GlassToolbarBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="10,0">

                <!-- ── RIGHT GROUP: Open + Commit + zoom badge + fit-all + exit-focus ── -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Open split button -->
                    <Border CornerRadius="8" Background="{DynamicResource AccentBrush}"
                            ClipToBounds="True" Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButtonLeft}"
                                    Command="{Binding DataContext.Dashboard.OpenInCursorCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Abrir no Cursor (Ctrl+O)">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource FolderIcon}"
                                          Stroke="White" StrokeThickness="1.5"
                                          Fill="Transparent" Stretch="Uniform"
                                          Width="14" Height="14"
                                          Margin="0,0,6,0" />
                                    <TextBlock Text="Open" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Fill="White" Opacity="0.2"
                                       VerticalAlignment="Stretch" Margin="0,6" />
                            <Button x:Name="ToolbarOpenDropdownBtn"
                                    Style="{StaticResource AccentButtonRight}"
                                    Tag="{Binding DataContext.Dashboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Mais opções"
                                    Click="OnToolbarOpenDropdownClick">
                                <Path Data="{StaticResource ChevronDownIcon}"
                                      Stroke="White" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Fill="Transparent"
                                      Width="10" Height="10" Stretch="Uniform" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.OpenInCursorCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/Images/cursor.png"
                                                           Width="14" Height="14" Margin="0,0,8,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="Cursor" VerticalAlignment="Center" />
                                                    <TextBlock Text="Ctrl+O" Margin="20,0,0,0"
                                                               Foreground="{DynamicResource SubtextBrush}"
                                                               FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.OpenInVsCodeCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/Images/vscode.png"
                                                           Width="14" Height="14" Margin="0,0,8,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="VS Code" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.OpenInExplorerCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="/Resources/Images/explorer.png"
                                                           Width="14" Height="14" Margin="0,0,8,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="Explorer" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Commit split button (visible only when project has git) -->
                    <Border CornerRadius="8" Background="{DynamicResource Surface0Brush}"
                            ClipToBounds="True" Margin="0,0,8,0" VerticalAlignment="Center"
                            Visibility="{Binding DataContext.Dashboard.HasGitInfo,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButtonLeft}"
                                    Command="{Binding DataContext.Dashboard.GitCommitCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Git Commit">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource GitBranchIcon}"
                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"
                                          Fill="Transparent" Stretch="Uniform"
                                          Width="14" Height="14"
                                          Margin="0,0,6,0" />
                                    <TextBlock Text="Commit" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Fill="{DynamicResource TextBrush}" Opacity="0.2"
                                       VerticalAlignment="Stretch" Margin="0,6" />
                            <Button x:Name="ToolbarCommitDropdownBtn"
                                    Style="{StaticResource AccentButtonRight}"
                                    Tag="{Binding DataContext.Dashboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Mais opções Git"
                                    Click="OnToolbarCommitDropdownClick">
                                <Path Data="{StaticResource ChevronDownIcon}"
                                      Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Fill="Transparent"
                                      Width="10" Height="10" Stretch="Uniform" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.GitCommitCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource GitBranchIcon}"
                                                          Stroke="{DynamicResource TextBrush}"
                                                          StrokeThickness="1.5" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          Margin="0,0,8,0" />
                                                    <TextBlock Text="Commit" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.GitPushCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M12 19V5M12 5L5 12M12 5L19 12"
                                                          Stroke="{DynamicResource AccentGreenBrush}"
                                                          StrokeThickness="1.5" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          Margin="0,0,8,0" />
                                                    <TextBlock Text="Push" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.GitCreatePrCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M18 15L22 19L18 23M6 9L2 5L6 1M14 3L10 21"
                                                          Stroke="{DynamicResource AccentBlueBrush}"
                                                          StrokeThickness="1.5" Fill="Transparent"
                                                          Stretch="Uniform" Width="14" Height="14"
                                                          Margin="0,0,8,0" />
                                                    <TextBlock Text="Create PR" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Vertical separator -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="0,0,8,0" />

                    <!-- Exit focus mode button (collapsed by default) -->
                    <Button x:Name="BtnVerTodos"
                            Style="{StaticResource GhostButton}"
                            Padding="10,4"
                            Margin="4,0"
                            Visibility="Collapsed"
                            Click="OnVerTodosClick"
                            ToolTip="Voltar à visão geral (ESC)">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M 2 2 L 10 2 L 10 10 L 2 10 Z M 14 2 L 22 2 L 22 10 L 14 10 Z M 2 14 L 10 14 L 10 22 L 2 22 Z M 14 14 L 22 14 L 22 22 L 14 22 Z"
                                  Stroke="{DynamicResource SubtextBrush}"
                                  Fill="Transparent"
                                  StrokeThickness="1.5"
                                  Width="12" Height="12"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0" />
                            <TextBlock Text="Ver Todos"
                                       Style="{StaticResource BodyText}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Toggle terminal panel button (visible when panel is hidden) -->
                    <Button Style="{StaticResource GhostButton}"
                            Padding="6,4"
                            Margin="4,0"
                            Command="{Binding DataContext.ToggleTerminalPanelCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Mostrar painel de terminais"
                            Visibility="{Binding DataContext.IsTerminalPanelVisible,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource BoolToVis},
                                         ConverterParameter=Invert}">
                        <Path Data="{StaticResource TerminalIcon}"
                              Stroke="{DynamicResource SubtextBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <!-- Vertical separator before zoom badge (hidden in tiled mode) -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="6,0"
                               Visibility="{Binding CanvasViewModel.IsCanvasMode, Converter={StaticResource BoolToVis}}" />

                    <!-- Zoom badge — hidden in tiled mode -->
                    <Border x:Name="ZoomBadge"
                            Visibility="{Binding CanvasViewModel.IsCanvasMode, Converter={StaticResource BoolToVis}}"
                            CornerRadius="4"
                            Padding="8,3"
                            Margin="4,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <!-- Default: Surface0 neutral -->
                                <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                <Style.Triggers>
                                    <!-- Low zoom  (< 50 %)  → yellow accent background -->
                                    <DataTrigger Binding="{Binding CanvasViewModel.ZoomPercent,
                                                     Converter={StaticResource ZoomLevelConverter}}"
                                                 Value="low">
                                        <Setter Property="Background" Value="{DynamicResource AccentYellowBrush}" />
                                    </DataTrigger>
                                    <!-- High zoom (> 150 %) → blue accent background -->
                                    <DataTrigger Binding="{Binding CanvasViewModel.ZoomPercent,
                                                     Converter={StaticResource ZoomLevelConverter}}"
                                                 Value="high">
                                        <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock x:Name="ZoomLabel"
                                   Text="100%"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <!-- Default colour from CaptionText (Overlay0) -->
                                    <Style.Triggers>
                                        <!-- On low/high the badge bg is coloured → use dark text -->
                                        <DataTrigger Binding="{Binding CanvasViewModel.ZoomPercent,
                                                         Converter={StaticResource ZoomLevelConverter}}"
                                                     Value="low">
                                            <Setter Property="Foreground" Value="{DynamicResource CrustBgBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CanvasViewModel.ZoomPercent,
                                                         Converter={StaticResource ZoomLevelConverter}}"
                                                     Value="high">
                                            <Setter Property="Foreground" Value="{DynamicResource CrustBgBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- ── LEFT GROUP: new terminal + title label ─────────────────── -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- ── Novo Terminal split button + AI dropdown + Layout toggle (unified group) ── -->
                    <Border CornerRadius="8" Background="{DynamicResource AccentBrush}" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal">
                            <!-- Main: new terminal -->
                            <Button Style="{StaticResource AccentButtonLeft}"
                                    Command="{Binding DataContext.NewTerminalCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Novo Terminal (Ctrl+Shift+T)">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="14" Height="14"
                                          VerticalAlignment="Center"
                                          Margin="0,0,7,0">
                                        <Path Data="M2 3 L7 7 L2 11"
                                              Stroke="White"
                                              StrokeThickness="1.8"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Stretch="None" />
                                        <Rectangle Width="5" Height="1.5"
                                                   Fill="White"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="0,2,0,0" />
                                    </Grid>
                                    <TextBlock Text="Novo Terminal"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Divisória sutil -->
                            <Rectangle Width="1" Fill="White" Opacity="0.2"
                                       VerticalAlignment="Stretch" Margin="0,6" />

                            <!-- Dropdown chevron (AI options) -->
                            <Button x:Name="AiDropdownBtn"
                                    Style="{StaticResource AccentButtonRight}"
                                    ToolTip="Abrir terminal AI"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Click="OnAiDropdownClick">
                                <Path Data="{StaticResource ChevronDownIcon}"
                                      Stroke="White"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="10" Height="10"
                                      Stretch="Uniform" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="claude"
                                                  Command="{Binding PlacementTarget.Tag.LaunchClaudeCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="claude --resume"
                                                  Command="{Binding PlacementTarget.Tag.LaunchClaudeResumeCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="cc (Claude Code)"
                                                  Command="{Binding PlacementTarget.Tag.LaunchCcCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="cc run sonnet"
                                                  Command="{Binding PlacementTarget.Tag.LaunchCcSonnetCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="cc run opus"
                                                  Command="{Binding PlacementTarget.Tag.LaunchCcOpusCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="cc run haiku"
                                                  Command="{Binding PlacementTarget.Tag.LaunchCcHaikuCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="cc run agent"
                                                  Command="{Binding PlacementTarget.Tag.LaunchCcAgentCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="cc or (OpenRouter)"
                                                  Command="{Binding PlacementTarget.Tag.LaunchCcOpenRouterCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Layout mode toggle (Canvas / Tiled) ── -->
                    <Border CornerRadius="4"
                            Margin="6,0,0,0"
                            Background="{DynamicResource Surface0Brush}"
                            Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <!-- Canvas mode button -->
                            <Button Padding="8,4"
                                    Command="{Binding CanvasViewModel.ToggleLayoutModeCommand}"
                                    ToolTip="Modo Canvas — layout livre (Ctrl+Shift+L)"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanvasViewModel.IsCanvasMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2 2H8V8H2Z M12 2H18V8H12Z M2 12H8V18H2Z M12 14H18V18H12Z"
                                          Stroke="{DynamicResource TextBrush}"
                                          StrokeThickness="1.2"
                                          Fill="Transparent"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0" />
                                    <TextBlock Text="Canvas"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Tiled mode button -->
                            <Button Padding="8,4"
                                    Command="{Binding CanvasViewModel.ToggleLayoutModeCommand}"
                                    ToolTip="Modo Tiled — layout em grade (Ctrl+Shift+L)"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2 2H10V10H2Z M12 2H20V10H12Z M2 12H10V20H2Z M12 12H20V20H12Z"
                                          Stroke="{DynamicResource TextBrush}"
                                          StrokeThickness="1.2"
                                          Fill="Transparent"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0" />
                                    <TextBlock Text="Tiled"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Auto-arrange button ── -->
                    <Button Padding="6,4"
                            Margin="4,0,0,0"
                            Command="{Binding CanvasViewModel.AutoArrangeCommand}"
                            ToolTip="Organizar terminais automaticamente"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Opacity" Value="0.6" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource Surface0Brush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <!-- Grid/arrange icon (4 arrows pointing outward) -->
                        <Path Data="M4 1L4 5M1 4L5 4 M16 1L16 5M13 4L17 4 M4 15L4 19M1 16L5 16 M16 15L16 19M13 16L17 16 M7 7H13V13H7Z"
                              Stroke="{DynamicResource TextBrush}"
                              StrokeThickness="1.2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Width="14" Height="14"
                              Stretch="Uniform"
                              VerticalAlignment="Center" />
                    </Button>

                    <!-- Vertical separator -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="10,0" />

                    <!-- Project name label -->
                    <TextBlock Text="{Binding DataContext.CurrentProject.Name,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     FallbackValue='Workspace'}"
                               Style="{StaticResource BodyText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Opacity="0.85" />

                    <!-- Vertical separator -->
                    <Rectangle Width="1" Height="20"
                               Fill="{DynamicResource Surface1Brush}"
                               Opacity="0.6"
                               Margin="10,0" />

                    <!-- Browser button -->
                    <Button Command="{Binding DataContext.NavigateToCommand,
                                     RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{x:Static vm:ViewType.Browser}"
                            ToolTip="Abrir Browser do projeto"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Padding" Value="8,4" />
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌐"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Text="Browser"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             WORKSPACE AREA
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Canvas viewport -->
                <ColumnDefinition Width="*" />
                <!-- Sidebar (0 when hidden) -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="220" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsTerminalPanelVisible,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="False">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- ── Infinite canvas viewport ──────────────────────────────── -->
            <Grid Grid.Column="0"
                  x:Name="ViewportArea"
                  Background="{DynamicResource CanvasDepthBrush}"
                  ClipToBounds="True"
                  MouseDown="OnViewportMouseDown"
                  MouseMove="OnViewportMouseMove"
                  MouseUp="OnViewportMouseUp"
                  MouseWheel="OnViewportMouseWheel"
                  AllowDrop="True"
                  Drop="OnViewportDrop"
                  DragOver="OnViewportDragOver"
                  Cursor="Arrow">

                <!-- ── Wallpaper background layer (hidden in tiled mode) ── -->
                <Image Source="{Binding CanvasViewModel.WallpaperSource}"
                       Stretch="{Binding CanvasViewModel.WallpaperStretch}"
                       Opacity="{Binding CanvasViewModel.WallpaperOpacity}"
                       Visibility="{Binding CanvasViewModel.HasWallpaper, Converter={StaticResource BoolToVis}}"
                       IsHitTestVisible="False">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- ── Dot-grid overlay — always visible on top of wallpaper (hidden in tiled mode) ── -->
                <Canvas IsHitTestVisible="False">
                    <Canvas.Style>
                        <Style TargetType="Canvas">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanvasViewModel.IsTiledMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Canvas.Style>
                    <Canvas.Background>
                        <DrawingBrush TileMode="Tile"
                                      ViewportUnits="Absolute"
                                      Viewport="0,0,32,32">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>

                                    <!-- Layer 1: dot at each tile origin -->
                                    <GeometryDrawing>
                                        <GeometryDrawing.Brush>
                                            <SolidColorBrush Color="#FFFFFF"
                                                             Opacity="0.18" />
                                        </GeometryDrawing.Brush>
                                        <GeometryDrawing.Geometry>
                                            <EllipseGeometry Center="2,2"
                                                             RadiusX="1.2"
                                                             RadiusY="1.2" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <!-- Layer 2a: faint horizontal hairline -->
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Thickness="0.5">
                                                <Pen.Brush>
                                                    <SolidColorBrush Color="#FFFFFF"
                                                                     Opacity="0.06" />
                                                </Pen.Brush>
                                            </Pen>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <LineGeometry StartPoint="0,0" EndPoint="32,0" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <!-- Layer 2b: faint vertical hairline -->
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Thickness="0.5">
                                                <Pen.Brush>
                                                    <SolidColorBrush Color="#FFFFFF"
                                                                     Opacity="0.06" />
                                                </Pen.Brush>
                                            </Pen>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <LineGeometry StartPoint="0,0" EndPoint="0,32" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Canvas.Background>
                </Canvas>

                <!-- World canvas: holds all items, panned + zoomed via RenderTransform -->
                <Canvas x:Name="WorldCanvas"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="Transparent">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="CanvasTranslate" X="40" Y="40" />
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- ItemsControl: binds to TerminalCanvasViewModel.Items
                         Each item is positioned absolutely via Canvas.Left/Top bindings -->
                    <ItemsControl x:Name="ItemsHost"
                                  ItemsSource="{Binding CanvasViewModel.Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="{Binding Y}" />
                                <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                <Setter Property="Width"  Value="{Binding Width}" />
                                <Setter Property="Height" Value="{Binding Height}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ctrl:CanvasCardControl
                                    CardCloseRequested="OnCardCloseRequested"
                                    CardFocusRequested="OnCardFocusRequested"
                                    CardActivated="OnCardActivated"
                                    AiActionRequested="OnAiActionRequested" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <!-- Mini-map overlay -->
                <ctrl:MiniMapControl
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    Panel.ZIndex="100"
                    DataContext="{Binding CanvasViewModel.MiniMap}"
                    Visibility="Visible" />

                <!-- Focus overlay (semi-transparent black, shown in focus mode) -->
                <Rectangle x:Name="FocusOverlay"
                           Fill="#000000"
                           Opacity="0"
                           IsHitTestVisible="False" />

                <!-- Empty state (lives outside WorldCanvas but follows pan/zoom via its own transform) -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            RenderTransformOrigin="0.5,0.5"
                            Visibility="{Binding CanvasViewModel.Items.Count,
                                         Converter={StaticResource EmptyVisConverter}}">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="EmptyStateTranslate" X="0" Y="0" />
                    </StackPanel.RenderTransform>
                    <Path Data="{StaticResource TerminalIcon}"
                          Style="{StaticResource IconPathLarge}"
                          Width="56" Height="56"
                          Stroke="{DynamicResource Surface2Brush}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20" />
                    <TextBlock Text="Nenhum terminal aberto"
                               Style="{StaticResource SubheadingText}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Surface2Brush}" />
                    <TextBlock Text="Clique em &quot;Novo Terminal&quot; ou pressione Ctrl+Shift+T"
                               Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 RIGHT SIDEBAR — premium with avatar, accent indicator,
                 rounded items and hover transitions
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource GlassSidebarBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding DataContext.IsTerminalPanelVisible,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 Converter={StaticResource BoolToVis}}">
                <DockPanel>

                    <!-- ── Sidebar header with icon + label + collapse button ──── -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <DockPanel>
                            <!-- Collapse button (right) -->
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource GhostButton}"
                                    Padding="2"
                                    Width="20" Height="20"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.ToggleTerminalPanelCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    ToolTip="Ocultar painel (Ctrl+Shift+B)">
                                <Path Data="M 3 1 L 7 5 L 3 9"
                                      Stroke="{DynamicResource SubtextBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="8" Height="10"
                                      Stretch="Uniform" />
                            </Button>
                            <!-- Icon + label (left) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource TerminalIcon}"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center"
                                      Margin="0,0,7,0" />
                                <TextBlock Text="Terminais"
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ── Toggle widget buttons ──────────────────────────────────── -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,8">
                        <!-- Git widget -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Widget Git"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,5" FontSize="11"
                                    Click="OnToggleGitWidgetClick" />
                            <Border Grid.Column="1" Width="16" Height="16" CornerRadius="8"
                                    VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Help"
                                    ToolTip="Exibe a branch atual, arquivos modificados, staged e novos, alem do ultimo commit do repositorio."
                                    Background="Transparent">
                                <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource SubtextBrush}" Opacity="0.6"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <!-- Process widget -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Widget Processos"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,5" FontSize="11"
                                    Click="OnToggleProcessWidgetClick" />
                            <Border Grid.Column="1" Width="16" Height="16" CornerRadius="8"
                                    VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Help"
                                    ToolTip="Monitora processos de desenvolvimento ativos (node, npm, php, python, docker) com uso de CPU e memoria."
                                    Background="Transparent">
                                <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource SubtextBrush}" Opacity="0.6"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <!-- Note widget -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Widget Notas"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,5" FontSize="11"
                                    Click="OnAddNoteWidgetClick" />
                            <Border Grid.Column="1" Width="16" Height="16" CornerRadius="8"
                                    VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Help"
                                    ToolTip="Cria um bloco de notas rapido no canvas. Ideal para lembretes, TODOs e anotacoes durante o desenvolvimento."
                                    Background="Transparent">
                                <TextBlock Text="?" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource SubtextBrush}" Opacity="0.6"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Separator DockPanel.Dock="Bottom"
                               Background="{DynamicResource Surface1Brush}"
                               Margin="0" />

                    <!-- ── Terminal list ──────────────────────────────────────────── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="6,4">
                        <ItemsControl ItemsSource="{Binding CanvasViewModel.TerminalItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Outer container holds accent bar + item body -->
                                    <Grid Margin="0,2"
                                          x:Name="SidebarRow">
                                        <Grid.ColumnDefinitions>
                                            <!-- 3 px accent bar (left) -->
                                            <ColumnDefinition Width="3" />
                                            <!-- Item body -->
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Accent indicator bar (visible only when IsSelected) -->
                                        <Rectangle Grid.Column="0"
                                                   RadiusX="2" RadiusY="2"
                                                   Fill="{DynamicResource AccentBrush}">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Item body -->
                                        <Border Grid.Column="1"
                                                x:Name="SidebarItem"
                                                CornerRadius="6"
                                                Padding="8,6"
                                                Margin="3,0,0,0"
                                                Cursor="Hand"
                                                MouseDown="OnSidebarItemClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{DynamicResource Surface0Brush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <!-- Mouse enter/leave: animate hover overlay opacity -->
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="HoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="1"
                                                                Duration="0:0:0.150">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <QuadraticEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="CloseBtn"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="1"
                                                                Duration="0:0:0.150" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="HoverOverlay"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="0"
                                                                Duration="0:0:0.200">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <QuadraticEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="CloseBtn"
                                                                Storyboard.TargetProperty="Opacity"
                                                                To="0"
                                                                Duration="0:0:0.200" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>

                                            <Grid>
                                                <!-- Hover background overlay -->
                                                <Border x:Name="HoverOverlay"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource Surface0Brush}"
                                                        Opacity="0"
                                                        IsHitTestVisible="False"
                                                        Margin="-8,-6,-8,-6" />

                                                <DockPanel>
                                                    <!-- Close button (right-aligned, visible on hover) -->
                                                    <Button x:Name="CloseBtn"
                                                            DockPanel.Dock="Right"
                                                            Style="{StaticResource GhostButton}"
                                                            Width="20" Height="20"
                                                            Padding="0"
                                                            Opacity="0"
                                                            VerticalAlignment="Center"
                                                            Margin="4,0,0,0"
                                                            ToolTip="Fechar terminal"
                                                            Click="OnSidebarCloseClick">
                                                        <Path Data="M 3 3 L 9 9 M 9 3 L 3 9"
                                                              Stroke="{DynamicResource SubtextBrush}"
                                                              StrokeThickness="1.5"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Width="10" Height="10"
                                                              Stretch="Uniform" />
                                                    </Button>

                                                    <!-- Status dot -->
                                                    <Ellipse DockPanel.Dock="Right"
                                                             Width="6" Height="6"
                                                             VerticalAlignment="Center"
                                                             Margin="4,0,0,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill"
                                                                        Value="{DynamicResource Surface2Brush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Terminal.IsConnected}"
                                                                                 Value="True">
                                                                        <Setter Property="Fill"
                                                                                Value="{DynamicResource AccentGreenBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>

                                                    <!-- Terminal icon -->
                                                    <Path DockPanel.Dock="Left"
                                                          Data="{StaticResource TerminalIcon}"
                                                          Stroke="{DynamicResource AccentGreenBrush}"
                                                          StrokeThickness="1.2"
                                                          StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Fill="Transparent"
                                                          Stretch="Uniform"
                                                          Width="14" Height="14"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Stroke"
                                                                                Value="{DynamicResource AccentBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>

                                                    <!-- Title + shell type -->
                                                    <StackPanel VerticalAlignment="Center"
                                                                Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="140" />
                                                        <TextBlock FontSize="10"
                                                                   Foreground="{DynamicResource SubtextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Opacity="0.7"
                                                                   MaxWidth="140"
                                                                   Margin="0,1,0,0">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}">
                                                                    <Binding Path="ShellType" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
