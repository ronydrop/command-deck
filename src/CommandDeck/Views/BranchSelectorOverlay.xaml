<UserControl x:Class="CommandDeck.Views.BranchSelectorOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CommandDeck.ViewModels"
             xmlns:conv="clr-namespace:CommandDeck.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type vm:BranchSelectorViewModel}}"
             Focusable="True"
             KeyDown="OnKeyDown">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <!-- Full-screen dim overlay — click outside to close -->
    <Grid>
        <Rectangle Fill="#000000" Opacity="0.55"
                   MouseDown="OnDimLayerClick" />

        <!-- Selector panel -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,80,0,0"
                Width="480"
                MaxHeight="440"
                CornerRadius="10"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource Surface1Brush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.6" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Search box -->
                    <RowDefinition Height="48" />
                    <!-- Separator -->
                    <RowDefinition Height="1" />
                    <!-- Warning / error area -->
                    <RowDefinition Height="Auto" />
                    <!-- Results -->
                    <RowDefinition Height="*" />
                    <!-- Footer hint -->
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>

                <!-- ── Search input ── -->
                <Grid Grid.Row="0" Margin="12,0">
                    <Path Data="{StaticResource GitBranchIcon}"
                          Stroke="{DynamicResource SubtextBrush}"
                          StrokeThickness="1.5"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="16" Height="16"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center" />
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="{DynamicResource TextBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             BorderThickness="0"
                             FontSize="15"
                             Padding="34,0,0,0"
                             VerticalContentAlignment="Center"
                             IsUndoEnabled="False"
                             SelectionBrush="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Pesquisar branches..."
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="15"
                               Padding="34,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- ── Separator ── -->
                <Rectangle Grid.Row="1" Fill="{DynamicResource Surface1Brush}" />

                <!-- ── Warning / Error area ── -->
                <StackPanel Grid.Row="2">

                    <!-- Uncommitted changes warning -->
                    <Border Background="{DynamicResource Surface1Brush}"
                            CornerRadius="6"
                            Margin="8,6,8,0"
                            Padding="12,8"
                            Visibility="{Binding HasUncommittedChanges, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Existem alterações não commitadas."
                                       Foreground="{DynamicResource AccentYellowBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Trocar mesmo assim"
                                        Style="{StaticResource AccentButton}"
                                        FontSize="12"
                                        Padding="10,4"
                                        Command="{Binding StashAndSwitchCommand}"
                                        Margin="0,0,6,0" />
                                <Button Content="Cancelar"
                                        Style="{StaticResource GhostButton}"
                                        FontSize="12"
                                        Padding="10,4"
                                        Command="{Binding CloseCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Error message -->
                    <Border Background="{DynamicResource Surface1Brush}"
                            CornerRadius="6"
                            Margin="8,6,8,0"
                            Padding="12,8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource AccentRedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Border>

                    <!-- Loading indicator -->
                    <Border Padding="12,8"
                            Visibility="{Binding IsSwitching, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Trocando branch..."
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- ── Branch list ── -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredBranches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ItemBg"
                                        Padding="12,8"
                                        Cursor="Hand"
                                        MouseDown="OnBranchClick"
                                        CornerRadius="6"
                                        Margin="6,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.SelectedBranch,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                             Value="{Binding}">
                                                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <DockPanel>
                                        <!-- Branch icon -->
                                        <Border DockPanel.Dock="Left"
                                                Width="28" Height="28"
                                                CornerRadius="6"
                                                Background="{DynamicResource Surface1Brush}"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <Path Data="{StaticResource GitBranchIcon}"
                                                  Stroke="{DynamicResource AccentMauveBrush}"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"
                                                  Stretch="Uniform"
                                                  Width="12" Height="12" />
                                        </Border>

                                        <!-- Badges (right side) -->
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <!-- "atual" badge -->
                                            <Border Background="{DynamicResource AccentGreenBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="4,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="atual"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource BaseBgBrush}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <!-- "remoto" badge -->
                                            <Border Background="{DynamicResource AccentMauveBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="4,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="remoto"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource BaseBgBrush}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Branch name -->
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── Footer ── -->
                <Border Grid.Row="4"
                        Background="{DynamicResource MantelBgBrush}"
                        CornerRadius="0,0,10,10"
                        Padding="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="↑↓ navegar" Style="{StaticResource CaptionText}" Margin="0,0,12,0" />
                        <TextBlock Text="↵ trocar"   Style="{StaticResource CaptionText}" Margin="0,0,12,0" />
                        <TextBlock Text="ESC fechar" Style="{StaticResource CaptionText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
